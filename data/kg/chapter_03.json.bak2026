 dính nhau, ví dụ như không còn dính ở phần lưng hoặc bụng.\n\nDa cá vẫn còn trên miếng phi-lê không ảnh hưởng đến việc phân loại các sản phẩm này vì cũng có khi phải để lại da cho miếng phi-lê chắc hoặc dễ thái lát sau này. Tương tự, việc phân loại cũng không bị ảnh hưởng nếu miếng phi-lê còn có xương dăm hoặc xương rất nhỏ chưa được loại bỏ hết.\n\nPhi-lê cá cắt thành miếng nhỏ cũng được phân loại như phi-lê trong nhóm này. Phi-lê cá đã chín, và phi-lê chỉ bao bột hoặc bao vụn bánh mì, có hoặc không đông lạnh, được phân loại vào nhóm 16.04.\n\n(2) Tất cả các loại thịt cá khác (đã hoặc chưa xay, nghiền) tức là thịt cá mà đã được loại bỏ xương. Như trong trường hợp phi-lê cá, sự có mặt của xương rất nhỏ có thể chưa được loại bỏ hoàn toàn cũng không thay đổi việc phân loại thịt cá.\n\n* *   * Nhóm này bao gồm phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:\n(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này.","chu_giai_dong":null,"bao_gom":["phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:","(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này."],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":"khối đông lạnh","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES","van_ban":"17/2023/TT-BNNPTNT","danh_muc":null,"co_quan":"BNNPTNT","loai":"lam_san_cites","tier":3,"loai_ten":"Mẫu vật CITES — động vật rừng nguy cấp, quý, hiếm","don_vi":"Cơ quan Quản lý CITES Việt Nam"},{"mo_ta":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M5","co_quan":"BNNPTNT","loai":"kiem_dich_thuc_vat","tier":3,"loai_ten":"Kiểm dịch thực vật","don_vi":"Cục Bảo vệ thực vật"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.04","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.04"],"conflict":{"has_conflict":true,"count":1,"items":[{"type":"C2","severity":"MEDIUM","desc":"BNNPTNT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: lam_san_cites, kiem_dich_thuc_vat"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":true,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030439","ahtn_8so":"03043900","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03044100":{"hs":"03044100","chapter":3,"heading":"0304","subheading":"030441","parent_hs":null,"fact_layer":{"vn":"- - Cá hồi Thái Bình Dương (Oncorhynchus nerka, Oncorhynchus gorbuscha, Oncorhynchus keta, Oncorhynchus tschawytscha, Oncorhynchus kisutch, Oncorhynchus masou và Oncorhynchus rhodurus), cá hồi Đại Tây Dương (Salmo salar) và cá hồi sông Đa-nuýp (Hucho hucho)","en":null,"dvt":"kg","rates":{"tt":"22.5","mfn":"15","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch (01/2024/TT-BNNPTNT M5)","canh_bao_cs":true,"muc_canh_bao":"ORANGE","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(1) Phi-lê cá. Theo mục đích của nhóm này thuật ngữ phi-lê cá có nghĩa là những dải thịt được cắt dọc hai bên theo xương sống của con cá và tạo thành bên phải hoặc bên trái của con cá đến mức mà đầu, ruột, vây (lưng, hậu môn, đuôi, bụng, ngực) và xương (cột sống hoặc xương lưng chính, xương bụng hoặc sườn, xương mang hoặc xương bàn đạp...) đã được loại bỏ ra và hai bên không dính nhau, ví dụ như không còn dính ở phần lưng hoặc bụng.\n\nDa cá vẫn còn trên miếng phi-lê không ảnh hưởng đến việc phân loại các sản phẩm này vì cũng có khi phải để lại da cho miếng phi-lê chắc hoặc dễ thái lát sau này. Tương tự, việc phân loại cũng không bị ảnh hưởng nếu miếng phi-lê còn có xương dăm hoặc xương rất nhỏ chưa được loại bỏ hết.\n\nPhi-lê cá cắt thành miếng nhỏ cũng được phân loại như phi-lê trong nhóm này. Phi-lê cá đã chín, và phi-lê chỉ bao bột hoặc bao vụn bánh mì, có hoặc không đông lạnh, được phân loại vào nhóm 16.04.\n\n(2) Tất cả các loại thịt cá khác (đã hoặc chưa xay, nghiền) tức là thịt cá mà đã được loại bỏ xương. Như trong trường hợp phi-lê cá, sự có mặt của xương rất nhỏ có thể chưa được loại bỏ hoàn toàn cũng không thay đổi việc phân loại thịt cá.\n\n* *   * Nhóm này bao gồm phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:\n(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này.","chu_giai_dong":null,"bao_gom":["phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:","(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này."],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":"khối đông lạnh","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M5","co_quan":"BNNPTNT","loai":"kiem_dich_thuc_vat","tier":3,"loai_ten":"Kiểm dịch thực vật","don_vi":"Cục Bảo vệ thực vật"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.04","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.04"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030441","ahtn_8so":"03044100","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03044200":{"hs":"03044200","chapter":3,"heading":"0304","subheading":"030442","parent_hs":null,"fact_layer":{"vn":"- - Cá hồi chấm (trout) (Salmo trutta, Oncorhynchus mykiss, Oncorhynchus clarki, Oncorhynchus aguabonita, Oncorhynchus gilae, Oncorhynchus apache và Oncorhynchus chrysogaster)","en":null,"dvt":"kg","rates":{"tt":"22.5","mfn":"15","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch (01/2024/TT-BNNPTNT M5)","canh_bao_cs":true,"muc_canh_bao":"ORANGE","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(1) Phi-lê cá. Theo mục đích của nhóm này thuật ngữ phi-lê cá có nghĩa là những dải thịt được cắt dọc hai bên theo xương sống của con cá và tạo thành bên phải hoặc bên trái của con cá đến mức mà đầu, ruột, vây (lưng, hậu môn, đuôi, bụng, ngực) và xương (cột sống hoặc xương lưng chính, xương bụng hoặc sườn, xương mang hoặc xương bàn đạp...) đã được loại bỏ ra và hai bên không dính nhau, ví dụ như không còn dính ở phần lưng hoặc bụng.\n\nDa cá vẫn còn trên miếng phi-lê không ảnh hưởng đến việc phân loại các sản phẩm này vì cũng có khi phải để lại da cho miếng phi-lê chắc hoặc dễ thái lát sau này. Tương tự, việc phân loại cũng không bị ảnh hưởng nếu miếng phi-lê còn có xương dăm hoặc xương rất nhỏ chưa được loại bỏ hết.\n\nPhi-lê cá cắt thành miếng nhỏ cũng được phân loại như phi-lê trong nhóm này. Phi-lê cá đã chín, và phi-lê chỉ bao bột hoặc bao vụn bánh mì, có hoặc không đông lạnh, được phân loại vào nhóm 16.04.\n\n(2) Tất cả các loại thịt cá khác (đã hoặc chưa xay, nghiền) tức là thịt cá mà đã được loại bỏ xương. Như trong trường hợp phi-lê cá, sự có mặt của xương rất nhỏ có thể chưa được loại bỏ hoàn toàn cũng không thay đổi việc phân loại thịt cá.\n\n* *   * Nhóm này bao gồm phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:\n(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này.","chu_giai_dong":null,"bao_gom":["phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:","(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này."],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":"khối đông lạnh","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M5","co_quan":"BNNPTNT","loai":"kiem_dich_thuc_vat","tier":3,"loai_ten":"Kiểm dịch thực vật","don_vi":"Cục Bảo vệ thực vật"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.04","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.04"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030442","ahtn_8so":"03044200","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03044300":{"hs":"03044300","chapter":3,"heading":"0304","subheading":"030443","parent_hs":null,"fact_layer":{"vn":"- - Cá bơn (Pleuronectidae, Bothidae, Cynoglossidae, Soleidae, Scophthalmidae và Citharidae)","en":null,"dvt":"kg","rates":{"tt":"22.5","mfn":"15","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch (01/2024/TT-BNNPTNT M5)","canh_bao_cs":true,"muc_canh_bao":"ORANGE","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(1) Phi-lê cá. Theo mục đích của nhóm này thuật ngữ phi-lê cá có nghĩa là những dải thịt được cắt dọc hai bên theo xương sống của con cá và tạo thành bên phải hoặc bên trái của con cá đến mức mà đầu, ruột, vây (lưng, hậu môn, đuôi, bụng, ngực) và xương (cột sống hoặc xương lưng chính, xương bụng hoặc sườn, xương mang hoặc xương bàn đạp...) đã được loại bỏ ra và hai bên không dính nhau, ví dụ như không còn dính ở phần lưng hoặc bụng.\n\nDa cá vẫn còn trên miếng phi-lê không ảnh hưởng đến việc phân loại các sản phẩm này vì cũng có khi phải để lại da cho miếng phi-lê chắc hoặc dễ thái lát sau này. Tương tự, việc phân loại cũng không bị ảnh hưởng nếu miếng phi-lê còn có xương dăm hoặc xương rất nhỏ chưa được loại bỏ hết.\n\nPhi-lê cá cắt thành miếng nhỏ cũng được phân loại như phi-lê trong nhóm này. Phi-lê cá đã chín, và phi-lê chỉ bao bột hoặc bao vụn bánh mì, có hoặc không đông lạnh, được phân loại vào nhóm 16.04.\n\n(2) Tất cả các loại thịt cá khác (đã hoặc chưa xay, nghiền) tức là thịt cá mà đã được loại bỏ xương. Như trong trường hợp phi-lê cá, sự có mặt của xương rất nhỏ có thể chưa được loại bỏ hoàn toàn cũng không thay đổi việc phân loại thịt cá.\n\n* *   * Nhóm này bao gồm phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:\n(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này.","chu_giai_dong":null,"bao_gom":["phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:","(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này."],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":"khối đông lạnh","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M5","co_quan":"BNNPTNT","loai":"kiem_dich_thuc_vat","tier":3,"loai_ten":"Kiểm dịch thực vật","don_vi":"Cục Bảo vệ thực vật"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.04","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.04"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030443","ahtn_8so":"03044300","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03044400":{"hs":"03044400","chapter":3,"heading":"0304","subheading":"030444","parent_hs":null,"fact_layer":{"vn":"- - Cá thuộc các họ Bregmacerotidae, Euclichthyidae, Gadidae, Macrouridae, Melanonidae, Merlucciidae, Moridae và Muraenolepididae","en":null,"dvt":"kg","rates":{"tt":"22.5","mfn":"15","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch (01/2024/TT-BNNPTNT M5)","canh_bao_cs":true,"muc_canh_bao":"ORANGE","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(1) Phi-lê cá. Theo mục đích của nhóm này thuật ngữ phi-lê cá có nghĩa là những dải thịt được cắt dọc hai bên theo xương sống của con cá và tạo thành bên phải hoặc bên trái của con cá đến mức mà đầu, ruột, vây (lưng, hậu môn, đuôi, bụng, ngực) và xương (cột sống hoặc xương lưng chính, xương bụng hoặc sườn, xương mang hoặc xương bàn đạp...) đã được loại bỏ ra và hai bên không dính nhau, ví dụ như không còn dính ở phần lưng hoặc bụng.\n\nDa cá vẫn còn trên miếng phi-lê không ảnh hưởng đến việc phân loại các sản phẩm này vì cũng có khi phải để lại da cho miếng phi-lê chắc hoặc dễ thái lát sau này. Tương tự, việc phân loại cũng không bị ảnh hưởng nếu miếng phi-lê còn có xương dăm hoặc xương rất nhỏ chưa được loại bỏ hết.\n\nPhi-lê cá cắt thành miếng nhỏ cũng được phân loại như phi-lê trong nhóm này. Phi-lê cá đã chín, và phi-lê chỉ bao bột hoặc bao vụn bánh mì, có hoặc không đông lạnh, được phân loại vào nhóm 16.04.\n\n(2) Tất cả các loại thịt cá khác (đã hoặc chưa xay, nghiền) tức là thịt cá mà đã được loại bỏ xương. Như trong trường hợp phi-lê cá, sự có mặt của xương rất nhỏ có thể chưa được loại bỏ hoàn toàn cũng không thay đổi việc phân loại thịt cá.\n\n* *   * Nhóm này bao gồm phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:\n(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này.","chu_giai_dong":null,"bao_gom":["phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:","(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này."],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":"khối đông lạnh","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M5","co_quan":"BNNPTNT","loai":"kiem_dich_thuc_vat","tier":3,"loai_ten":"Kiểm dịch thực vật","don_vi":"Cục Bảo vệ thực vật"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.04","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.04"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030444","ahtn_8so":"03044400","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03044500":{"hs":"03044500","chapter":3,"heading":"0304","subheading":"030445","parent_hs":null,"fact_layer":{"vn":"- - Cá kiếm (Xiphias gladius)","en":null,"dvt":"kg","rates":{"tt":"22.5","mfn":"15","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch (01/2024/TT-BNNPTNT M5)","canh_bao_cs":true,"muc_canh_bao":"ORANGE","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(1) Phi-lê cá. Theo mục đích của nhóm này thuật ngữ phi-lê cá có nghĩa là những dải thịt được cắt dọc hai bên theo xương sống của con cá và tạo thành bên phải hoặc bên trái của con cá đến mức mà đầu, ruột, vây (lưng, hậu môn, đuôi, bụng, ngực) và xương (cột sống hoặc xương lưng chính, xương bụng hoặc sườn, xương mang hoặc xương bàn đạp...) đã được loại bỏ ra và hai bên không dính nhau, ví dụ như không còn dính ở phần lưng hoặc bụng.\n\nDa cá vẫn còn trên miếng phi-lê không ảnh hưởng đến việc phân loại các sản phẩm này vì cũng có khi phải để lại da cho miếng phi-lê chắc hoặc dễ thái lát sau này. Tương tự, việc phân loại cũng không bị ảnh hưởng nếu miếng phi-lê còn có xương dăm hoặc xương rất nhỏ chưa được loại bỏ hết.\n\nPhi-lê cá cắt thành miếng nhỏ cũng được phân loại như phi-lê trong nhóm này. Phi-lê cá đã chín, và phi-lê chỉ bao bột hoặc bao vụn bánh mì, có hoặc không đông lạnh, được phân loại vào nhóm 16.04.\n\n(2) Tất cả các loại thịt cá khác (đã hoặc chưa xay, nghiền) tức là thịt cá mà đã được loại bỏ xương. Như trong trường hợp phi-lê cá, sự có mặt của xương rất nhỏ có thể chưa được loại bỏ hoàn toàn cũng không thay đổi việc phân loại thịt cá.\n\n* *   * Nhóm này bao gồm phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:\n(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này.","chu_giai_dong":null,"bao_gom":["phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:","(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này."],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":"khối đông lạnh","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M5","co_quan":"BNNPTNT","loai":"kiem_dich_thuc_vat","tier":3,"loai_ten":"Kiểm dịch thực vật","don_vi":"Cục Bảo vệ thực vật"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.04","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.04"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030445","ahtn_8so":"03044500","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03044600":{"hs":"03044600","chapter":3,"heading":"0304","subheading":"030446","parent_hs":null,"fact_layer":{"vn":"- - Cá răng cưa (Dissostichus spp.)","en":null,"dvt":"kg","rates":{"tt":"22.5","mfn":"15","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch (01/2024/TT-BNNPTNT M5)","canh_bao_cs":true,"muc_canh_bao":"ORANGE","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(1) Phi-lê cá. Theo mục đích của nhóm này thuật ngữ phi-lê cá có nghĩa là những dải thịt được cắt dọc hai bên theo xương sống của con cá và tạo thành bên phải hoặc bên trái của con cá đến mức mà đầu, ruột, vây (lưng, hậu môn, đuôi, bụng, ngực) và xương (cột sống hoặc xương lưng chính, xương bụng hoặc sườn, xương mang hoặc xương bàn đạp...) đã được loại bỏ ra và hai bên không dính nhau, ví dụ như không còn dính ở phần lưng hoặc bụng.\n\nDa cá vẫn còn trên miếng phi-lê không ảnh hưởng đến việc phân loại các sản phẩm này vì cũng có khi phải để lại da cho miếng phi-lê chắc hoặc dễ thái lát sau này. Tương tự, việc phân loại cũng không bị ảnh hưởng nếu miếng phi-lê còn có xương dăm hoặc xương rất nhỏ chưa được loại bỏ hết.\n\nPhi-lê cá cắt thành miếng nhỏ cũng được phân loại như phi-lê trong nhóm này. Phi-lê cá đã chín, và phi-lê chỉ bao bột hoặc bao vụn bánh mì, có hoặc không đông lạnh, được phân loại vào nhóm 16.04.\n\n(2) Tất cả các loại thịt cá khác (đã hoặc chưa xay, nghiền) tức là thịt cá mà đã được loại bỏ xương. Như trong trường hợp phi-lê cá, sự có mặt của xương rất nhỏ có thể chưa được loại bỏ hoàn toàn cũng không thay đổi việc phân loại thịt cá.\n\n* *   * Nhóm này bao gồm phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:\n(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này.","chu_giai_dong":null,"bao_gom":["phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:","(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này."],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":"khối đông lạnh","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M5","co_quan":"BNNPTNT","loai":"kiem_dich_thuc_vat","tier":3,"loai_ten":"Kiểm dịch thực vật","don_vi":"Cục Bảo vệ thực vật"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.04","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.04"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030446","ahtn_8so":"03044600","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03044700":{"hs":"03044700","chapter":3,"heading":"0304","subheading":"030447","parent_hs":null,"fact_layer":{"vn":"- - Cá nhám góc và cá mập khác","en":null,"dvt":"kg","rates":{"tt":"22.5","mfn":"15","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES (17/2023/TT-BNNPTNT); Động vật, sản phẩm động vật thủy sản phải kiểm dịch (01/2024/TT-BNNPTNT M5)","canh_bao_cs":true,"muc_canh_bao":"ORANGE","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(1) Phi-lê cá. Theo mục đích của nhóm này thuật ngữ phi-lê cá có nghĩa là những dải thịt được cắt dọc hai bên theo xương sống của con cá và tạo thành bên phải hoặc bên trái của con cá đến mức mà đầu, ruột, vây (lưng, hậu môn, đuôi, bụng, ngực) và xương (cột sống hoặc xương lưng chính, xương bụng hoặc sườn, xương mang hoặc xương bàn đạp...) đã được loại bỏ ra và hai bên không dính nhau, ví dụ như không còn dính ở phần lưng hoặc bụng.\n\nDa cá vẫn còn trên miếng phi-lê không ảnh hưởng đến việc phân loại các sản phẩm này vì cũng có khi phải để lại da cho miếng phi-lê chắc hoặc dễ thái lát sau này. Tương tự, việc phân loại cũng không bị ảnh hưởng nếu miếng phi-lê còn có xương dăm hoặc xương rất nhỏ chưa được loại bỏ hết.\n\nPhi-lê cá cắt thành miếng nhỏ cũng được phân loại như phi-lê trong nhóm này. Phi-lê cá đã chín, và phi-lê chỉ bao bột hoặc bao vụn bánh mì, có hoặc không đông lạnh, được phân loại vào nhóm 16.04.\n\n(2) Tất cả các loại thịt cá khác (đã hoặc chưa xay, nghiền) tức là thịt cá mà đã được loại bỏ xương. Như trong trường hợp phi-lê cá, sự có mặt của xương rất nhỏ có thể chưa được loại bỏ hoàn toàn cũng không thay đổi việc phân loại thịt cá.\n\n* *   * Nhóm này bao gồm phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:\n(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này.","chu_giai_dong":null,"bao_gom":["phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:","(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này."],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":"khối đông lạnh","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES","van_ban":"17/2023/TT-BNNPTNT","danh_muc":null,"co_quan":"BNNPTNT","loai":"lam_san_cites","tier":3,"loai_ten":"Mẫu vật CITES — động vật rừng nguy cấp, quý, hiếm","don_vi":"Cơ quan Quản lý CITES Việt Nam"},{"mo_ta":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh