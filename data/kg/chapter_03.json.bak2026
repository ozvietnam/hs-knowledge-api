oại trong nhóm này. Phụ phẩm cá ăn được không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, tươi hoặc ướp lạnh, cũng được phân loại vào nhóm này.\n\n\no o   o","chu_giai_dong":null,"bao_gom":[],"khong_bao_gom":["phi-lê cá và thịt cá khác thuộc nhóm 03.04. Cá có thể được đóng gói với muối hoặc đá hoặc tưới nước muối để bảo quản tạm thời trong lúc vận chuyển. Cá được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm vẫn được phân loại trong nhóm này. Phụ phẩm cá ăn được không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, tươi hoặc ướp lạnh, cũng được phân loại vào nhóm này."],"loai_tru":["phi-lê cá và thịt cá khác thuộc\nnhóm 03.04"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":null,"nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M5","co_quan":"BNNPTNT","loai":"kiem_dich_thuc_vat","tier":3,"loai_ten":"Kiểm dịch thực vật","don_vi":"Cục Bảo vệ thực vật"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.02","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.02"],"conflict":{"has_conflict":true,"count":1,"items":[{"type":"C4","severity":"MEDIUM","desc":"FTA=0% nhưng MFN=20.0% (chênh lệch lớn)","detail":"ACFTA=0, EVFTA=None, MFN=20.0"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tr