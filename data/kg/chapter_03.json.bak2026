nh mì, có hoặc không đông lạnh, được phân loại vào nhóm 16.04.\n\n(2) Tất cả các loại thịt cá khác (đã hoặc chưa xay, nghiền) tức là thịt cá mà đã được loại bỏ xương. Như trong trường hợp phi-lê cá, sự có mặt của xương rất nhỏ có thể chưa được loại bỏ hoàn toàn cũng không thay đổi việc phân loại thịt cá.\n\n* *   * Nhóm này bao gồm phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:\n(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này.","chu_giai_dong":null,"bao_gom":["phi-lê cá và tất cả thịt cá khác (đã hoặc chưa xay, nghiền) chỉ ở các dạng sau:","(i) Tươi hoặc ướp lạnh, có hoặc không đóng gói với muối hoặc đá lạnh hoặc tưới nước muối để bảo quản tạm thời trong khi vận chuyển. (ii) Đông lạnh, thường dưới dạng khối đông lạnh. Phi-lê cá và thịt cá khác (đã hoặc chưa xay, nghiền) được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm cũng thuộc nhóm này."],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":"khối đông lạnh","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES","van_ban":"17/2023/TT-BNNPTNT","danh_muc":null,"co_quan":"BNNPTNT","loai":"lam_san_cites","tier":3,"loai_ten":"Mẫu vật CITES — động vật rừng nguy cấp, quý, hiếm","don_vi":"Cơ quan Quản lý CITES Việt Nam"},{"mo_ta":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M5","co_quan":"BNNPTNT","loai":"kiem_dich_thuc_vat","tier":3,"loai_ten":"Kiểm dịch thực vật","don_vi":"Cục Bảo vệ thực vật"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":true,"noi_dung":"Surimi đông lạnh là một sản phẩm protein từ cá để chế biến thêm. Nó được làm từ cá tươi bỏ đầu, rút ruột, làm sạch và tách xương cơ học. Thịt cá đã tách xương sau đó được rửa sạch, lọc, xay và khử nước, và sau đó trộn với các thành phần thực phẩm chống đông (cryoprotective) và được làm đông lạnh. Chất chống đông được thêm vào để ngăn chặn sự biến tính protein ở trạng thái đông lạnh, do đó thịt cá xay có thể được làm đông lạnh nhưng vẫn giữ được khả năng tạo gel khi xử lý nhiệt sau khi rã đông. Đường và/hoặc rượu đa chức thường được sử dụng làm chất chống đông. Tham khảo: 1. Quy phạm Thực hành đối với Cá và Sản phẩm Thủy sản- Phiên bản đầu tiên- Tổ chức Y tế Thế giới Tổ chức Nông lương của Liên hợp quốc (FAO). 2. Benjakul và cộng sự, 2004; Guenneugues và Morrissey, 2005; Perez-Mateos và Lanier, 2006; Rawdkuen và cộng sự, 2008; Campo-Deano và Tovar, 2009.","source":"SEN AHTN 2022 (CV 3866/TCHQ-TXNK 2023)","vi_du_sen":["SURIMI (THỊT CÁ XAY)"]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.04","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.04","SEN AHTN 2022 (CV 3866/TCHQ-TXNK 2023)"],"conflict":{"has_conflict":true,"count":1,"items":[{"type":"C2","severity":"MEDIUM","desc":"BNNPTNT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: lam_san_cites, kiem_dich_thuc_vat"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":true,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030499","ahtn_8so":"03049990","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03052010":{"hs":"03052010","chapter":3,"heading":"0305","subheading":"030520","parent_hs":null,"fact_layer":{"vn":"- - Của cá nước ngọt, làm khô, muối hoặc ngâm nước muối","en":null,"dvt":"kg","rates":{"tt":"30","mfn":"20","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới (42/2019/TT-BCT & 34/2025/TT-BCT ); HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES (17/2023/TT-BNNPTNT)","canh_bao_cs":true,"muc_canh_bao":"YELLOW","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(2) đã được muối hoặc ngâm nước muối; hoặc\n(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này.\n\nCá đã qua từ hai quá trình chế biến trở lên , thích hợp dùng làm thức ăn cho người, vẫn được phân loại vào nhóm này Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói.\n\n\nNhững loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này. Nhóm này không bao gồm:\n(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).\n(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04).","chu_giai_dong":null,"bao_gom":["các loại cá (nguyên con, không đầu, ở dạng miếng, dạng phi-lê hoặc đã được xay, nghiền) và các phụ phẩm ăn được của cá, mà các sản phẩm này:","(1) đã được làm khô;","(2) đã được muối hoặc ngâm nước muối; hoặc","(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này. Cá đã qua từ hai quá trình chế biến trở lên cũng được phân loại vào nhóm này, tương tự như bột mịn và bột thô của cá (đã hoặc chưa loại bỏ chất béo (ví dụ, tách chất béo bằng phương pháp chiết dung môi) hoặc xử lý bằng nhiệt) và viên cá, thích hợp dùng làm thức ăn cho người. Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói. Những loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này."],"khong_bao_gom":["(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).","(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).","(c) Súp cá (nhóm 21.04)."],"loai_tru":["ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11)","dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04)",", trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hai quá trình chế biến trở lên","cá (nhóm 05"],"cau_tao":"miếng, dạng phi-lê hoặc đã","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chế biến cá như để ướp muối hoặc ngâm nước muối","thức ăn cho người"],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES","van_ban":"17/2023/TT-BNNPTNT","danh_muc":null,"co_quan":"BNNPTNT","loai":"lam_san_cites","tier":3,"loai_ten":"Mẫu vật CITES — động vật rừng nguy cấp, quý, hiếm","don_vi":"Cơ quan Quản lý CITES Việt Nam"}],"ktcn_muc_canh_bao":"YELLOW","ktcn_co_quan":["BCT","BNNPTNT"],"agency_authority":["Bộ Công Thương","Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.05","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.05"],"conflict":{"has_conflict":true,"count":2,"items":[{"type":"C2","severity":"MEDIUM","desc":"BCT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: cua_khau_phu, cua_khau_phu"},{"type":"C4","severity":"MEDIUM","desc":"FTA=0% nhưng MFN=20.0% (chênh lệch lớn)","detail":"ACFTA=0, EVFTA=None, MFN=20.0"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"YELLOW"}},"precedent_layer":{"tb_tchq":[{"so_hieu":"4780/TB-TCHQ","nam":2022,"ngay_ban_hanh":"11/11/2022","loai":"Xac dinh truoc ma so","ten_san_pham":"Calgo® (Calcium Bone Powder)","ten_ky_thuat":"Bột xương cá hồi.","ma_hs":"03051000","nhom":"Nhóm 03.05","ly_do_phan_loai":"thuộc nhóm 03.05 “Cá, làm khô, muối hoặc ngâm nước muối; cá hun khói, đã hoặc chưa làm chín trước hoặc trong quá trình hun khói; bột mịn, bột thô và viên làm từ cá, thích hợp dùng làm thức ăn cho người” , mã số 0305.10.00 “- Bột mịn, bột thô và viên làm từ cá, thích hợp dùng làm thức ăn cho người” tại Danh mục hàng hóa xuất khẩu, nhập khẩu Việt Nam.","cong_dung":"Dùng làm nguyên liệu trong sản xuất thực phẩm.","co_che_hoat_dong":null,"ma_hang":"Không có thông tin.","hang_san_xuat":"Hofseth Biocare ASA.","doanh_nghiep":"Công ty TNHH DKSH Performance Materials Việt Nam (mã số thuế","url":"https://thuvienphapluat.vn/van-ban/Xuat-nhap-khau/Thong-bao-4780-TB-TCHQ-2022-ket-qua-xac-dinh-truoc-ma-so-Calgo-Calcium-Bone-Powder-538859.aspx"}],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":1},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030520","ahtn_8so":"03052010","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03052090":{"hs":"03052090","chapter":3,"heading":"0305","subheading":"030520","parent_hs":null,"fact_layer":{"vn":"- - Loại khác","en":null,"dvt":"kg","rates":{"tt":"30","mfn":"20","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới (42/2019/TT-BCT & 34/2025/TT-BCT ); HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES (17/2023/TT-BNNPTNT)","canh_bao_cs":true,"muc_canh_bao":"YELLOW","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(2) đã được muối hoặc ngâm nước muối; hoặc\n(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này.\n\nCá đã qua từ hai quá trình chế biến trở lên , thích hợp dùng làm thức ăn cho người, vẫn được phân loại vào nhóm này Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói.\n\n\nNhững loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này. Nhóm này không bao gồm:\n(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).\n(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04).","chu_giai_dong":null,"bao_gom":["các loại cá (nguyên con, không đầu, ở dạng miếng, dạng phi-lê hoặc đã được xay, nghiền) và các phụ phẩm ăn được của cá, mà các sản phẩm này:","(1) đã được làm khô;","(2) đã được muối hoặc ngâm nước muối; hoặc","(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này. Cá đã qua từ hai quá trình chế biến trở lên cũng được phân loại vào nhóm này, tương tự như bột mịn và bột thô của cá (đã hoặc chưa loại bỏ chất béo (ví dụ, tách chất béo bằng phương pháp chiết dung môi) hoặc xử lý bằng nhiệt) và viên cá, thích hợp dùng làm thức ăn cho người. Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói. Những loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này."],"khong_bao_gom":["(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).","(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).","(c) Súp cá (nhóm 21.04)."],"loai_tru":["ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11)","dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04)",", trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hai quá trình chế biến trở lên","cá (nhóm 05"],"cau_tao":"miếng, dạng phi-lê hoặc đã","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chế biến cá như để ướp muối hoặc ngâm nước muối","thức ăn cho người"],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES","van_ban":"17/2023/TT-BNNPTNT","danh_muc":null,"co_quan":"BNNPTNT","loai":"lam_san_cites","tier":3,"loai_ten":"Mẫu vật CITES — động vật rừng nguy cấp, quý, hiếm","don_vi":"Cơ quan Quản lý CITES Việt Nam"}],"ktcn_muc_canh_bao":"YELLOW","ktcn_co_quan":["BCT","BNNPTNT"],"agency_authority":["Bộ Công Thương","Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.05","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.05"],"conflict":{"has_conflict":true,"count":2,"items":[{"type":"C2","severity":"MEDIUM","desc":"BCT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: cua_khau_phu, cua_khau_phu"},{"type":"C4","severity":"MEDIUM","desc":"FTA=0% nhưng MFN=20.0% (chênh lệch lớn)","detail":"ACFTA=0, EVFTA=None, MFN=20.0"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"YELLOW"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":true,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030520","ahtn_8so":"03052090","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03053100":{"hs":"03053100","chapter":3,"heading":"0305","subheading":"030531","parent_hs":null,"fact_layer":{"vn":"- - Cá rô phi (Oreochromis spp.), cá da trơn (Pangasius spp., Silurus spp., Clarias spp., Ictalurus spp.), cá chép (Cyprinus spp., Carassius spp., Ctenopharyngodon idellus, Hypophthalmichthys spp., Cirrhinus spp., Mylopharyngodon piceus, Catla catla, Labeo spp., Osteochilus hasselti, Leptobarbus hoeveni, Megalobrama spp.), cá chình (Anguilla spp.), cá rô sông Nile (Lates niloticus) và cá quả (cá chuối hoặc cá lóc) (Channa spp.)","en":null,"dvt":"kg","rates":{"tt":"30","mfn":"20","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới (42/2019/TT-BCT & 34/2025/TT-BCT ); HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES (17/2023/TT-BNNPTNT)","canh_bao_cs":true,"muc_canh_bao":"YELLOW","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(2) đã được muối hoặc ngâm nước muối; hoặc\n(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này.\n\nCá đã qua từ hai quá trình chế biến trở lên , thích hợp dùng làm thức ăn cho người, vẫn được phân loại vào nhóm này Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói.\n\n\nNhững loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này. Nhóm này không bao gồm:\n(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).\n(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04).","chu_giai_dong":null,"bao_gom":["các loại cá (nguyên con, không đầu, ở dạng miếng, dạng phi-lê hoặc đã được xay, nghiền) và các phụ phẩm ăn được của cá, mà các sản phẩm này:","(1) đã được làm khô;","(2) đã được muối hoặc ngâm nước muối; hoặc","(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này. Cá đã qua từ hai quá trình chế biến trở lên cũng được phân loại vào nhóm này, tương tự như bột mịn và bột thô của cá (đã hoặc chưa loại bỏ chất béo (ví dụ, tách chất béo bằng phương pháp chiết dung môi) hoặc xử lý bằng nhiệt) và viên cá, thích hợp dùng làm thức ăn cho người. Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói. Những loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này."],"khong_bao_gom":["(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).","(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).","(c) Súp cá (nhóm 21.04)."],"loai_tru":["ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11)","dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04)",", trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hai quá trình chế biến trở lên","cá (nhóm 05"],"cau_tao":"miếng, dạng phi-lê hoặc đã","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chế biến cá như để ướp muối hoặc ngâm nước muối","thức ăn cho người"],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES","van_ban":"17/2023/TT-BNNPTNT","danh_muc":null,"co_quan":"BNNPTNT","loai":"lam_san_cites","tier":3,"loai_ten":"Mẫu vật CITES — động vật rừng nguy cấp, quý, hiếm","don_vi":"Cơ quan Quản lý CITES Việt Nam"}],"ktcn_muc_canh_bao":"YELLOW","ktcn_co_quan":["BCT","BNNPTNT"],"agency_authority":["Bộ Công Thương","Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.05","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.05"],"conflict":{"has_conflict":true,"count":2,"items":[{"type":"C2","severity":"MEDIUM","desc":"BCT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: cua_khau_phu, cua_khau_phu"},{"type":"C4","severity":"MEDIUM","desc":"FTA=0% nhưng MFN=20.0% (chênh lệch lớn)","detail":"ACFTA=0, EVFTA=None, MFN=20.0"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"YELLOW"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030531","ahtn_8so":"03053100","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03053200":{"hs":"03053200","chapter":3,"heading":"0305","subheading":"030532","parent_hs":null,"fact_layer":{"vn":"- - Cá thuộc các họ Bregmacerotidae, Euclichthyidae, Gadidae, Macrouridae, Melanonidae, Merlucciidae, Moridae và Muraenolepididae","en":null,"dvt":"kg","rates":{"tt":"30","mfn":"20","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới (42/2019/TT-BCT & 34/2025/TT-BCT )","canh_bao_cs":true,"muc_canh_bao":"YELLOW","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(2) đã được muối hoặc ngâm nước muối; hoặc\n(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này.\n\nCá đã qua từ hai quá trình chế biến trở lên , thích hợp dùng làm thức ăn cho người, vẫn được phân loại vào nhóm này Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói.\n\n\nNhững loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này. Nhóm này không bao gồm:\n(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).\n(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04).","chu_giai_dong":null,"bao_gom":["các loại cá (nguyên con, không đầu, ở dạng miếng, dạng phi-lê hoặc đã được xay, nghiền) và các phụ phẩm ăn được của cá, mà các sản phẩm này:","(1) đã được làm khô;","(2) đã được muối hoặc ngâm nước muối; hoặc","(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này. Cá đã qua từ hai quá trình chế biến trở lên cũng được phân loại vào nhóm này, tương tự như bột mịn và bột thô của cá (đã hoặc chưa loại bỏ chất béo (ví dụ, tách chất béo bằng phương pháp chiết dung môi) hoặc xử lý bằng nhiệt) và viên cá, thích hợp dùng làm thức ăn cho người. Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói. Những loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này."],"khong_bao_gom":["(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).","(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).","(c) Súp cá (nhóm 21.04)."],"loai_tru":["ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11)","dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04)",", trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hai quá trình chế biến trở lên","cá (nhóm 05"],"cau_tao":"miếng, dạng phi-lê hoặc đã","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chế biến cá như để ướp muối hoặc ngâm nước muối","thức ăn cho người"],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"}],"ktcn_muc_canh_bao":"YELLOW","ktcn_co_quan":["BCT"],"agency_authority":["Bộ Công Thương"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.05","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.05"],"conflict":{"has_conflict":true,"count":2,"items":[{"type":"C2","severity":"MEDIUM","desc":"BCT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: cua_khau_phu, cua_khau_phu"},{"type":"C4","severity":"MEDIUM","desc":"FTA=0% nhưng MFN=20.0% (chênh lệch lớn)","detail":"ACFTA=0, EVFTA=None, MFN=20.0"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"YELLOW"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030532","ahtn_8so":"03053200","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03053910":{"hs":"03053910","chapter":3,"heading":"0305","subheading":"030539","parent_hs":null,"fact_layer":{"vn":"- - - Cá nhói nước ngọt (Xenentodon cancila), cá phèn dải vàng (Upeneus vittatus) và cá khế lược mang dài (Ulua mentalis)","en":null,"dvt":"kg","rates":{"tt":"30","mfn":"20","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới (42/2019/TT-BCT & 34/2025/TT-BCT )","canh_bao_cs":true,"muc_canh_bao":"YELLOW","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(2) đã được muối hoặc ngâm nước muối; hoặc\n(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này.\n\nCá đã qua từ hai quá trình chế biến trở lên , thích hợp dùng làm thức ăn cho người, vẫn được phân loại vào nhóm này Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói.\n\n\nNhững loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này. Nhóm này không bao gồm:\n(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).\n(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04).","chu_giai_dong":null,"bao_gom":["các loại cá (nguyên con, không đầu, ở dạng miếng, dạng phi-lê hoặc đã được xay, nghiền) và các phụ phẩm ăn được của cá, mà các sản phẩm này:","(1) đã được làm khô;","(2) đã được muối hoặc ngâm nước muối; hoặc","(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này. Cá đã qua từ hai quá trình chế biến trở lên cũng được phân loại vào nhóm này, tương tự như bột mịn và bột thô của cá (đã hoặc chưa loại bỏ chất béo (ví dụ, tách chất béo bằng phương pháp chiết dung môi) hoặc xử lý bằng nhiệt) và viên cá, thích hợp dùng làm thức ăn cho người. Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói. Những loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này."],"khong_bao_gom":["(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).","(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).","(c) Súp cá (nhóm 21.04)."],"loai_tru":["ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11)","dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04)",", trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hai quá trình chế biến trở lên","cá (nhóm 05"],"cau_tao":"miếng, dạng phi-lê hoặc đã","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chế biến cá như để ướp muối hoặc ngâm nước muối","thức ăn cho người"],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"}],"ktcn_muc_canh_bao":"YELLOW","ktcn_co_quan":["BCT"],"agency_authority":["Bộ Công Thương"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.05","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.05"],"conflict":{"has_conflict":true,"count":2,"items":[{"type":"C2","severity":"MEDIUM","desc":"BCT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: cua_khau_phu, cua_khau_phu"},{"type":"C4","severity":"MEDIUM","desc":"FTA=0% nhưng MFN=20.0% (chênh lệch lớn)","detail":"ACFTA=0, EVFTA=None, MFN=20.0"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"YELLOW"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030539","ahtn_8so":"03053910","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03053920":{"hs":"03053920","chapter":3,"heading":"0305","subheading":"030539","parent_hs":null,"fact_layer":{"vn":"- - - Cá hố savalai (Lepturacanthus savala), cá đù Belanger (Johnius belangerii), cá đù Reeve (Chrysochir aureus) và cá đù mắt to (Pennahia anea)","en":null,"dvt":"kg","rates":{"tt":"30","mfn":"20","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới (42/2019/TT-BCT & 34/2025/TT-BCT )","canh_bao_cs":true,"muc_canh_bao":"YELLOW","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(2) đã được muối hoặc ngâm nước muối; hoặc\n(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này.\n\nCá đã qua từ hai quá trình chế biến trở lên , thích hợp dùng làm thức ăn cho người, vẫn được phân loại vào nhóm này Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói.\n\n\nNhững loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này. Nhóm này không bao gồm:\n(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).\n(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04).","chu_giai_dong":null,"bao_gom":["các loại cá (nguyên con, không đầu, ở dạng miếng, dạng phi-lê hoặc đã được xay, nghiền) và các phụ phẩm ăn được của cá, mà các sản phẩm này:","(1) đã được làm khô;","(2) đã được muối hoặc ngâm nước muối; hoặc","(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này. Cá đã qua từ hai quá trình chế biến trở lên cũng được phân loại vào nhóm này, tương tự như bột mịn và bột thô của cá (đã hoặc chưa loại bỏ chất béo (ví dụ, tách chất béo bằng phương pháp chiết dung môi) hoặc xử lý bằng nhiệt) và viên cá, thích hợp dùng làm thức ăn cho người. Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói. Những loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này."],"khong_bao_gom":["(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).","(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).","(c) Súp cá (nhóm 21.04)."],"loai_tru":["ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11)","dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04)",", trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hai quá trình chế biến trở lên","cá (nhóm 05"],"cau_tao":"miếng, dạng phi-lê hoặc đã","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chế biến cá như để ướp muối hoặc ngâm nước muối","thức ăn cho người"],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"}],"ktcn_muc_canh_bao":"YELLOW","ktcn_co_quan":["BCT"],"agency_authority":["Bộ Công Thương"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.05","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.05"],"conflict":{"has_conflict":true,"count":2,"items":[{"type":"C2","severity":"MEDIUM","desc":"BCT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: cua_khau_phu, cua_khau_phu"},{"type":"C4","severity":"MEDIUM","desc":"FTA=0% nhưng MFN=20.0% (chênh lệch lớn)","detail":"ACFTA=0, EVFTA=None, MFN=20.0"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"YELLOW"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030539","ahtn_8so":"03053920","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03053991":{"hs":"03053991","chapter":3,"heading":"0305","subheading":"030539","parent_hs":null,"fact_layer":{"vn":"- - - - Của cá nước ngọt","en":null,"dvt":"kg","rates":{"tt":"30","mfn":"20","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới (42/2019/TT-BCT & 34/2025/TT-BCT ); HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES (17/2023/TT-BNNPTNT)","canh_bao_cs":true,"muc_canh_bao":"YELLOW","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(2) đã được muối hoặc ngâm nước muối; hoặc\n(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này.\n\nCá đã qua từ hai quá trình chế biến trở lên , thích hợp dùng làm thức ăn cho người, vẫn được phân loại vào nhóm này Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói.\n\n\nNhững loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này. Nhóm này không bao gồm:\n(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).\n(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04).","chu_giai_dong":null,"bao_gom":["các loại cá (nguyên con, không đầu, ở dạng miếng, dạng phi-lê hoặc đã được xay, nghiền) và các phụ phẩm ăn được của cá, mà các sản phẩm này:","(1) đã được làm khô;","(2) đã được muối hoặc ngâm nước muối; hoặc","(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này. Cá đã qua từ hai quá trình chế biến trở lên cũng được phân loại vào nhóm này, tương tự như bột mịn và bột thô của cá (đã hoặc chưa loại bỏ chất béo (ví dụ, tách chất béo bằng phương pháp chiết dung môi) hoặc xử lý bằng nhiệt) và viên cá, thích hợp dùng làm thức ăn cho người. Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói. Những loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này."],"khong_bao_gom":["(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).","(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).","(c) Súp cá (nhóm 21.04)."],"loai_tru":["ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11)","dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04)",", trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hai quá trình chế biến trở lên","cá (nhóm 05"],"cau_tao":"miếng, dạng phi-lê hoặc đã","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chế biến cá như để ướp muối hoặc ngâm nước muối","thức ăn cho người"],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES","van_ban":"17/2023/TT-BNNPTNT","danh_muc":null,"co_quan":"BNNPTNT","loai":"lam_san_cites","tier":3,"loai_ten":"Mẫu vật CITES — động vật rừng nguy cấp, quý, hiếm","don_vi":"Cơ quan Quản lý CITES Việt Nam"}],"ktcn_muc_canh_bao":"YELLOW","ktcn_co_quan":["BCT","BNNPTNT"],"agency_authority":["Bộ Công Thương","Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.05","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.05"],"conflict":{"has_conflict":true,"count":2,"items":[{"type":"C2","severity":"MEDIUM","desc":"BCT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: cua_khau_phu, cua_khau_phu"},{"type":"C4","severity":"MEDIUM","desc":"FTA=0% nhưng MFN=20.0% (chênh lệch lớn)","detail":"ACFTA=0, EVFTA=None, MFN=20.0"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"YELLOW"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030539","ahtn_8so":"03053991","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03053992":{"hs":"03053992","chapter":3,"heading":"0305","subheading":"030539","parent_hs":null,"fact_layer":{"vn":"- - - - Của cá biển","en":null,"dvt":"kg","rates":{"tt":"30","mfn":"20","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới (42/2019/TT-BCT & 34/2025/TT-BCT ); HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES (17/2023/TT-BNNPTNT)","canh_bao_cs":true,"muc_canh_bao":"YELLOW","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(2) đã được muối hoặc ngâm nước muối; hoặc\n(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này.\n\nCá đã qua từ hai quá trình chế biến trở lên , thích hợp dùng làm thức ăn cho người, vẫn được phân loại vào nhóm này Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói.\n\n\nNhững loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này. Nhóm này không bao gồm:\n(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).\n(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04).","chu_giai_dong":null,"bao_gom":["các loại cá (nguyên con, không đầu, ở dạng miếng, dạng phi-lê hoặc đã được xay, nghiền) và các phụ phẩm ăn được của cá, mà các sản phẩm này:","(1) đã được làm khô;","(2) đã được muối hoặc ngâm nước muối; hoặc","(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này. Cá đã qua từ hai quá trình chế biến trở lên cũng được phân loại vào nhóm này, tương tự như bột mịn và bột thô của cá (đã hoặc chưa loại bỏ chất béo (ví dụ, tách chất béo bằng phương pháp chiết dung môi) hoặc xử lý bằng nhiệt) và viên cá, thích hợp dùng làm thức ăn cho người. Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói. Những loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này."],"khong_bao_gom":["(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).","(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).","(c) Súp cá (nhóm 21.04)."],"loai_tru":["ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11)","dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04)",", trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hai quá trình chế biến trở lên","cá (nhóm 05"],"cau_tao":"miếng, dạng phi-lê hoặc đã","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chế biến cá như để ướp muối hoặc ngâm nước muối","thức ăn cho người"],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES","van_ban":"17/2023/TT-BNNPTNT","danh_muc":null,"co_quan":"BNNPTNT","loai":"lam_san_cites","tier":3,"loai_ten":"Mẫu vật CITES — động vật rừng nguy cấp, quý, hiếm","don_vi":"Cơ quan Quản lý CITES Việt Nam"}],"ktcn_muc_canh_bao":"YELLOW","ktcn_co_quan":["BCT","BNNPTNT"],"agency_authority":["Bộ Công Thương","Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.05","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.05"],"conflict":{"has_conflict":true,"count":2,"items":[{"type":"C2","severity":"MEDIUM","desc":"BCT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: cua_khau_phu, cua_khau_phu"},{"type":"C4","severity":"MEDIUM","desc":"FTA=0% nhưng MFN=20.0% (chênh lệch lớn)","detail":"ACFTA=0, EVFTA=None, MFN=20.0"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"YELLOW"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030539","ahtn_8so":"03053992","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03053999":{"hs":"03053999","chapter":3,"heading":"0305","subheading":"030539","parent_hs":null,"fact_layer":{"vn":"- - - - Loại khác","en":null,"dvt":"kg","rates":{"tt":"30","mfn":"20","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới (42/2019/TT-BCT & 34/2025/TT-BCT )","canh_bao_cs":true,"muc_canh_bao":"YELLOW","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(2) đã được muối hoặc ngâm nước muối; hoặc\n(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này.\n\nCá đã qua từ hai quá trình chế biến trở lên , thích hợp dùng làm thức ăn cho người, vẫn được phân loại vào nhóm này Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói.\n\n\nNhững loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này. Nhóm này không bao gồm:\n(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).\n(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04).","chu_giai_dong":null,"bao_gom":["các loại cá (nguyên con, không đầu, ở dạng miếng, dạng phi-lê hoặc đã được xay, nghiền) và các phụ phẩm ăn được của cá, mà các sản phẩm này:","(1) đã được làm khô;","(2) đã được muối hoặc ngâm nước muối; hoặc","(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này. Cá đã qua từ hai quá trình chế biến trở lên cũng được phân loại vào nhóm này, tương tự như bột mịn và bột thô của cá (đã hoặc chưa loại bỏ chất béo (ví dụ, tách chất béo bằng phương pháp chiết dung môi) hoặc xử lý bằng nhiệt) và viên cá, thích hợp dùng làm thức ăn cho người. Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói. Những loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này."],"khong_bao_gom":["(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).","(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).","(c) Súp cá (nhóm 21.04)."],"loai_tru":["ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11)","dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04)",", trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hai quá trình chế biến trở lên","cá (nhóm 05"],"cau_tao":"miếng, dạng phi-lê hoặc đã","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chế biến cá như để ướp muối hoặc ngâm nước muối","thức ăn cho người"],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"}],"ktcn_muc_canh_bao":"YELLOW","ktcn_co_quan":["BCT"],"agency_authority":["Bộ Công Thương"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.05","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.05"],"conflict":{"has_conflict":true,"count":2,"items":[{"type":"C2","severity":"MEDIUM","desc":"BCT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: cua_khau_phu, cua_khau_phu"},{"type":"C4","severity":"MEDIUM","desc":"FTA=0% nhưng MFN=20.0% (chênh lệch lớn)","detail":"ACFTA=0, EVFTA=None, MFN=20.0"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"YELLOW"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030539","ahtn_8so":"03053999","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03054100":{"hs":"03054100","chapter":3,"heading":"0305","subheading":"030541","parent_hs":null,"fact_layer":{"vn":"- - Cá hồi Thái Bình Dương (Oncorhynchus nerka, Oncorhynchus gorbuscha, Oncorhynchus keta, Oncorhynchus tschawytscha, Oncorhynchus kisutch, Oncorhynchus masou và Oncorhynchus rhodurus), cá hồi Đại Tây Dương (Salmo salar) và cá hồi sông Đa-nuýp (Hucho hucho)","en":null,"dvt":"kg","rates":{"tt":"22.5","mfn":"15","vat":"8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới (42/2019/TT-BCT & 34/2025/TT-BCT )","canh_bao_cs":true,"muc_canh_bao":"YELLOW","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(2) đã được muối hoặc ngâm nước muối; hoặc\n(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này.\n\nCá đã qua từ hai quá trình chế biến trở lên , thích hợp dùng làm thức ăn cho người, vẫn được phân loại vào nhóm này Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói.\n\n\nNhững loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này. Nhóm này không bao gồm:\n(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).\n(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04).","chu_giai_dong":null,"bao_gom":["các loại cá (nguyên con, không đầu, ở dạng miếng, dạng phi-lê hoặc đã được xay, nghiền) và các phụ phẩm ăn được của cá, mà các sản phẩm này:","(1) đã được làm khô;","(2) đã được muối hoặc ngâm nước muối; hoặc","(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này. Cá đã qua từ hai quá trình chế biến trở lên cũng được phân loại vào nhóm này, tương tự như bột mịn và bột thô của cá (đã hoặc chưa loại bỏ chất béo (ví dụ, tách chất béo bằng phương pháp chiết dung môi) hoặc xử lý bằng nhiệt) và viên cá, thích hợp dùng làm thức ăn cho người. Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói. Những loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này."],"khong_bao_gom":["(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).","(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).","(c) Súp cá (nhóm 21.04)."],"loai_tru":["ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11)","dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04)",", trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hai quá trình chế biến trở lên","cá (nhóm 05"],"cau_tao":"miếng, dạng phi-lê hoặc đã","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chế biến cá như để ướp muối hoặc ngâm nước muối","thức ăn cho người"],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"}],"ktcn_muc_canh_bao":"YELLOW","ktcn_co_quan":["BCT"],"agency_authority":["Bộ Công Thương"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.05","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.05"],"conflict":{"has_conflict":true,"count":1,"items":[{"type":"C2","severity":"MEDIUM","desc":"BCT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: cua_khau_phu, cua_khau_phu"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"YELLOW"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030541","ahtn_8so":"03054100","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03054200":{"hs":"03054200","chapter":3,"heading":"0305","subheading":"030542","parent_hs":null,"fact_layer":{"vn":"- - Cá trích nước lạnh (Clupea harengus, Clupea pallasii)","en":null,"dvt":"kg","rates":{"tt":"30","mfn":"20","vat":"8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới (42/2019/TT-BCT & 34/2025/TT-BCT )","canh_bao_cs":true,"muc_canh_bao":"YELLOW","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(2) đã được muối hoặc ngâm nước muối; hoặc\n(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này.\n\nCá đã qua từ hai quá trình chế biến trở lên , thích hợp dùng làm thức ăn cho người, vẫn được phân loại vào nhóm này Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói.\n\n\nNhững loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này. Nhóm này không bao gồm:\n(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).\n(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04).","chu_giai_dong":null,"bao_gom":["các loại cá (nguyên con, không đầu, ở dạng miếng, dạng phi-lê hoặc đã được xay, nghiền) và các phụ phẩm ăn được của cá, mà các sản phẩm này:","(1) đã được làm khô;","(2) đã được muối hoặc ngâm nước muối; hoặc","(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này. Cá đã qua từ hai quá trình chế biến trở lên cũng được phân loại vào nhóm này, tương tự như bột mịn và bột thô của cá (đã hoặc chưa loại bỏ chất béo (ví dụ, tách chất béo bằng phương pháp chiết dung môi) hoặc xử lý bằng nhiệt) và viên cá, thích hợp dùng làm thức ăn cho người. Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói. Những loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này."],"khong_bao_gom":["(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).","(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).","(c) Súp cá (nhóm 21.04)."],"loai_tru":["ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11)","dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04)",", trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hai quá trình chế biến trở lên","cá (nhóm 05"],"cau_tao":"miếng, dạng phi-lê hoặc đã","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chế biến cá như để ướp muối hoặc ngâm nước muối","thức ăn cho người"],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"}],"ktcn_muc_canh_bao":"YELLOW","ktcn_co_quan":["BCT"],"agency_authority":["Bộ Công Thương"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.05","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.05"],"conflict":{"has_conflict":true,"count":2,"items":[{"type":"C2","severity":"MEDIUM","desc":"BCT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: cua_khau_phu, cua_khau_phu"},{"type":"C4","severity":"MEDIUM","desc":"FTA=0% nhưng MFN=20.0% (chênh lệch lớn)","detail":"ACFTA=0, EVFTA=None, MFN=20.0"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"YELLOW"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030542","ahtn_8so":"03054200","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03054300":{"hs":"03054300","chapter":3,"heading":"0305","subheading":"030543","parent_hs":null,"fact_layer":{"vn":"- - Cá hồi chấm (trout) (Salmo trutta, Oncorhynchus mykiss, Oncorhynchus clarki, Oncorhynchus aguabonita, Oncorhynchus gilae, Oncorhynchus apache và Oncorhynchus chrysogaster)","en":null,"dvt":"kg","rates":{"tt":"30","mfn":"20","vat":"8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới (42/2019/TT-BCT & 34/2025/TT-BCT )","canh_bao_cs":true,"muc_canh_bao":"YELLOW","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(2) đã được muối hoặc ngâm nước muối; hoặc\n(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này.\n\nCá đã qua từ hai quá trình chế biến trở lên , thích hợp dùng làm thức ăn cho người, vẫn được phân loại vào nhóm này Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói.\n\n\nNhững loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này. Nhóm này không bao gồm:\n(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).\n(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04).","chu_giai_dong":null,"bao_gom":["các loại cá (nguyên con, không đầu, ở dạng miếng, dạng phi-lê hoặc đã được xay, nghiền) và các phụ phẩm ăn được của cá, mà các sản phẩm này:","(1) đã được làm khô;","(2) đã được muối hoặc ngâm nước muối; hoặc","(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này. Cá đã qua từ hai quá trình chế biến trở lên cũng được phân loại vào nhóm này, tương tự như bột mịn và bột thô của cá (đã hoặc chưa loại bỏ chất béo (ví dụ, tách chất béo bằng phương pháp chiết dung môi) hoặc xử lý bằng nhiệt) và viên cá, thích hợp dùng làm thức ăn cho người. Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói. Những loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này."],"khong_bao_gom":["(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).","(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).","(c) Súp cá (nhóm 21.04)."],"loai_tru":["ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11)","dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04)",", trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hai quá trình chế biến trở lên","cá (nhóm 05"],"cau_tao":"miếng, dạng phi-lê hoặc đã","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chế biến cá như để ướp muối hoặc ngâm nước muối","thức ăn cho người"],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"}],"ktcn_muc_canh_bao":"YELLOW","ktcn_co_quan":["BCT"],"agency_authority":["Bộ Công Thương"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.05","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.05"],"conflict":{"has_conflict":true,"count":2,"items":[{"type":"C2","severity":"MEDIUM","desc":"BCT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: cua_khau_phu, cua_khau_phu"},{"type":"C4","severity":"MEDIUM","desc":"FTA=0% nhưng MFN=20.0% (chênh lệch lớn)","detail":"ACFTA=0, EVFTA=None, MFN=20.0"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"YELLOW"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030543","ahtn_8so":"03054300","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03054400":{"hs":"03054400","chapter":3,"heading":"0305","subheading":"030544","parent_hs":null,"fact_layer":{"vn":"- - Cá rô phi (Oreochromis spp.), cá da trơn (Pangasius spp., Silurus spp., Clarias spp., Ictalurus spp.), cá chép (Cyprinus spp., Carassius spp., Ctenopharyngodon idellus, Hypophthalmichthys spp., Cirrhinus spp., Mylopharyngodon piceus, Catla catla, Labeo spp., Osteochilus hasselti, Leptobarbus hoeveni, Megalobrama spp.), cá chình (Anguilla spp.), cá rô sông Nile (Lates niloticus) và cá quả (cá chuối hoặc cá lóc) (Channa spp.)","en":null,"dvt":"kg","rates":{"tt":"30","mfn":"20","vat":"8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới (42/2019/TT-BCT & 34/2025/TT-BCT ); HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES (17/2023/TT-BNNPTNT)","canh_bao_cs":true,"muc_canh_bao":"YELLOW","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"(2) đã được muối hoặc ngâm nước muối; hoặc\n(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này.\n\nCá đã qua từ hai quá trình chế biến trở lên , thích hợp dùng làm thức ăn cho người, vẫn được phân loại vào nhóm này Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói.\n\n\nNhững loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này. Nhóm này không bao gồm:\n(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).\n(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04).","chu_giai_dong":null,"bao_gom":["các loại cá (nguyên con, không đầu, ở dạng miếng, dạng phi-lê hoặc đã được xay, nghiền) và các phụ phẩm ăn được của cá, mà các sản phẩm này:","(1) đã được làm khô;","(2) đã được muối hoặc ngâm nước muối; hoặc","(3) đã được hun khói. Muối dùng trong chế biến cá như để ướp muối hoặc ngâm nước muối, có thể chứa nitrit natri hoặc nitrat natri. Có thể dùng một chút đường trong chế biến cá muối mà không làm thay đổi việc phân loại cá trong nhóm này. Cá đã qua từ hai quá trình chế biến trở lên cũng được phân loại vào nhóm này, tương tự như bột mịn và bột thô của cá (đã hoặc chưa loại bỏ chất béo (ví dụ, tách chất béo bằng phương pháp chiết dung môi) hoặc xử lý bằng nhiệt) và viên cá, thích hợp dùng làm thức ăn cho người. Cá hun khói đôi khi được xử lý nhiệt trước hoặc trong khi hun khói (hun khói nóng) để làm chín một phần hoặc toàn bộ thịt cá; điều này không ảnh hưởng đến việc phân loại vào nhóm này miễn là chúng không được chế biến thêm làm mất đi đặc tính của cá hun khói. Những loại cá chính được chế biến theo cách nêu tại nhóm này là cá trích dầu, cá cơm (cá trỏng), cá mòi cơm (pilchard), cá trích cơm, cá ngừ đại dương, cá nục hoa, cá hồi, cá trích nước lạnh, cá tuyết, cá tuyết chấm đen và cá bơn lưỡi ngựa. Phụ phẩm cá ăn được sau giết mổ không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, được làm khô, muối, ngâm nước muối hoặc hun khói, cũng được phân loại vào nhóm này."],"khong_bao_gom":["(a) Phụ phẩm cá không ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11).","(b) Cá đã chín (trừ nội dung nêu trên liên quan đến cá hun khói), cá được chế biến theo bất kỳ cách nào khác (ví dụ bảo quản trong dầu hay trong dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).","(c) Súp cá (nhóm 21.04)."],"loai_tru":["ăn được (ví dụ loại được sử dụng trong công nghiệp) và các phần phế liệu từ cá (nhóm 05.11)","dấm hoặc trong nước xốt), trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04)",", trứng cá muối và các sản phẩm thay thế trứng cá muối (nhóm 16.04).\n(c) Súp cá (nhóm 21.04)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hai quá trình chế biến trở lên","cá (nhóm 05"],"cau_tao":"miếng, dạng phi-lê hoặc đã","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chế biến cá như để ướp muối hoặc ngâm nước muối","thức ăn cho người"],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES","van_ban":"17/2023/TT-BNNPTNT","danh_muc":null,"co_quan":"BNNPTNT","loai":"lam_san_cites","tier":3,"loai_ten":"Mẫu vật CITES — động vật rừng nguy cấp, quý, hiếm","don_vi":"Cơ quan Quản lý CITES Việt Nam"}],"ktcn_muc_canh_bao":"YELLOW","ktcn_co_quan":["BCT","BNNPTNT"],"agency_authority":["Bộ Công Thương","Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":nu