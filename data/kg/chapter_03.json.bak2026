yet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"030255","ahtn_8so":"03025500","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"03025600":{"hs":"03025600","chapter":3,"heading":"0302","subheading":"030256","parent_hs":null,"fact_layer":{"vn":"- - Cá tuyết lam (Micromesistius poutassou, Micromesistius australis)","en":null,"dvt":"kg","rates":{"tt":"18","mfn":"12","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch (01/2024/TT-BNNPTNT M5)","canh_bao_cs":true,"muc_canh_bao":"ORANGE","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1.- Chương này không bao gồm:\n(a) Động vật có vú thuộc nhóm 01.06;\n(b) Thịt của động vật có vú thuộc nhóm 01.06 (nhóm 02.08 hoặc 02.10);\n(c) Cá (kể cả gan, sẹ và bọc trứng cá) hoặc động vật giáp xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"Cá được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm vẫn được phân loại trong nhóm này. Phụ phẩm cá ăn được không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, tươi hoặc ướp lạnh, cũng được phân loại vào nhóm này.\n\n\no o   o","chu_giai_dong":null,"bao_gom":[],"khong_bao_gom":["phi-lê cá và thịt cá khác thuộc nhóm 03.04. Cá có thể được đóng gói với muối hoặc đá hoặc tưới nước muối để bảo quản tạm thời trong lúc vận chuyển. Cá được ướp với ít đường hoặc được đóng gói với ít lá nguyệt quế thơm vẫn được phân loại trong nhóm này. Phụ phẩm cá ăn được không dính với các phần còn lại của thân cá (ví dụ: da, đuôi, bong bóng, đầu và nửa đầu (có hoặc không có óc, má, lưỡi, mắt, hàm hoặc miệng), dạ dày, vây, lưỡi), cũng như gan, sẹ và bọc trứng cá, tươi hoặc ướp lạnh, cũng được phân loại vào nhóm này."],"loai_tru":["phi-lê cá và thịt cá khác thuộc\nnhóm 03.04"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":null,"nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M5","co_quan":"BNNPTNT","loai":"kiem_dich_thuc_vat","tier":3,"loai_ten":"Kiểm dịch thực vật","don_vi":"Cục Bảo vệ thực vật"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.02","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.02"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":nul