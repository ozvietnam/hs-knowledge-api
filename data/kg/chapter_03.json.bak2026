p xác, động vật thân mềm hay động\nvật thuỷ sinh không xương sống khác, đã chết và không thích hợp dùng làm thức ăn cho\nngười hoặc vì lý do chủng loại hoặc vì trạng thái của chúng (Chương 5); các loại bột mịn,\nbột thô hoặc viên làm từ cá hoặc động vật giáp xác, động vật thân mềm hoặc động vật\nthuỷ sinh không xương sống khác, không thích hợp dùng làm thức ăn cho người (nhóm\n23.01); hoặc\n(d) Trứng cá tầm muối hoặc các sản phẩm thay thế trứng cá tầm muối từ trứng cá (nhóm\n16.04).\n2.- Trong Chương này khái niệm \"viên\" (pellets) có nghĩa là các sản phẩm được liên kết\nhoặc bằng cách nén trực tiếp hoặc bằng cách cho thêm một lượng nhỏ chất kết dính.","chu_giai_phan":"Chú giải.\n1. Trong phần này, khi đề cập đến một giống hoặc một loài động vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"Nhóm này bao gồm tất cả các loại cá sống, không kể công dụng như thế nào (ví dụ cá cảnh).\nCá thuộc nhóm này thường được chuyên chở trong những thùng chứa thích hợp (bể, thùng\ncá... ) có thể giữ cá còn sống trong điều kiện tương tự như ở môi trường tự nhiên.","chu_giai_dong":null,"bao_gom":["tất cả các loại cá sống, không kể công dụng như thế nào (ví dụ cá cảnh). Cá thuộc nhóm này thường được chuyên chở trong những thùng chứa thích hợp (bể, thùng cá... ) có thể giữ cá còn sống trong điều kiện tương tự như ở môi trường tự nhiên."],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":null,"nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M5","co_quan":"BNNPTNT","loai":"kiem_dich_thuc_vat","tier":3,"loai_ten":"Kiểm dịch thực vật","don_vi":"Cục Bảo vệ thực vật"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BCT","BNNPTNT"],"agency_authority":["Bộ Công Thương","Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":true,"noi_dung":"Giới: Animalia Ngành: Chordata Lớp: Actinopterygii Bộ: Perciformes Họ: Serranidae Chi: Plectropomus Loài: Plectropomus leopardus Khối lượng không dưới 600 gram. Kích thước: 35-120 cm","source":"SEN AHTN 2022 (CV 3866/TCHQ-TXNK 2023)","vi_du_sen":["CÁ MÚ CHẤM NHỎ (PLECTROPOMUS LEOPARDUS)"]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.01","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.01","SEN AHTN 2022 (CV 3866/TCHQ-TXNK 2023)"],"conflict":{"has_conflict":true,"count":2,"items":[{"type":"C2","severity":"MEDIUM","desc":"BCT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: cua_khau_phu, cua_khau_phu"},{"type":"C4","severity":"MEDIUM","desc":"FTA=0% nhưng MFN=20.0% (chênh lệch lớn)","detail":"ACFTA=0, EVFTA=None, MFN=20.0"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_l