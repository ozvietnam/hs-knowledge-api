g vật, trừ khi có yêu cầu khác,\ncần phải kể đến cả giống hoặc loài động vật đó còn non.\n2. Trừ khi có yêu cầu khác, trong toàn bộ Danh mục này bất cứ đề cập nào liên quan đến các\nsản phẩm \"được làm khô\" cũng bao gồm các sản phẩm được khử nước, làm bay hơi hoặc\nlàm khô bằng đông lạnh.","chu_giai_nhom":"Nội dung Chú giải nhóm 03.02 áp dụng, một cách tương tự, cho các sản phẩm của nhóm này\nvới những sửa đổi chi tiết thích hợp.","chu_giai_dong":null,"bao_gom":[],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":null,"nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật thủy sản phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M5","co_quan":"BNNPTNT","loai":"kiem_dich_thuc_vat","tier":3,"loai_ten":"Kiểm dịch thực vật","don_vi":"Cục Bảo vệ thực vật"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 3","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 3","Chú giải HS 2017 — Nhóm 03.03","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 03.03"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":nu