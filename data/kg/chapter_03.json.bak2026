 hàu nhỏ (con hàu nhỏ dùng để nuôi), thích hợp hoặc phù hợp dùng làm thức ăn cho người. Nhóm này không bao gồm động vật thân mềm đã chế biến hoặc bảo quản bằng cách không nêu trong nhóm (ví dụ, động vật thân mềm được luộc trong nước hoặc bảo quản trong dấm) (nhóm 16.05).","chu_giai_dong":null,"bao_gom":[],"khong_bao_gom":["động vật thân mềm đã chế biến hoặc bảo quản bằng cách không nêu trong nhóm (ví dụ, động vật thân mềm được luộc trong nước hoặc bảo quản trong dấm) (nhóm 16.05)."],"loai_tru":["ng nhóm (ví dụ, động vật thân mềm được luộc trong nước hoặc bảo quản trong dấm) (nhóm 16.05)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["động vật thân mềm"],"cau_tao":"sốc nhiệt khác (không đòi hỏi phải nấu chín), cần thiết để mở vỏ hoặc cố định nhuyễn thể trước khi vận chuyển hoặc đông lạnh, cũng vẫn thuộc Chương nà","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["nuôi)","thức ăn cho người"],"ktcn":[{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"42/2019/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"Hàng hóa được nhập khẩu dưới hình thức mua bán, trao đổi của cư dân biên giới","van_ban":"34/2025/TT-BCT","danh_muc":null,"co_quan":"BCT","loai":"cua_khau_phu","tier":3,"loai_ten":"Hàng hóa mua bán qua cửa khẩu phụ, lối mở biên giới","don_vi":"Cục Xuất nhập khẩu"},{"mo_ta":"HH là mẫu vật động vật rừng nguy cấp, quý, hiếm và động vật thuộc các phụ lụcCITES","van_ban":"17/2023/TT-BNNPTNT","danh_muc":null,"co_quan":"BNNPTNT","loai":"lam_san_cites","tier":3,"loai_ten":"Mẫu vật CITES — động vật rừng nguy cấp, quý, hiếm","don_vi":"Cơ quan Quản lý CITES Việt Nam"}],"ktcn_muc_canh_bao":"YELLOW","ktcn_co_quan":["BCT","BNNPTNT"],"agency_authority":["Bộ Công Thương","Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung"