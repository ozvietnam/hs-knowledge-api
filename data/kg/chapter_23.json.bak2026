àm thức ăn cho người.\nNhóm này không bao gồm cặn dầu (nhóm 15.22).","chu_giai_dong":null,"bao_gom":["các loại khô dầu và các phế liệu rắn khác, trừ các loại thuộc nhóm 23.04 hoặc 23.05, còn lại sau khi chiết xuất dầu từ hạt có dầu, quả có dầu và mầm ngũ cốc bằng dung môi hoặc bằng ép hoặc ép quay. Nhóm này cũng bao gồm cám gạo đã được khử dầu là loại phế liệu thu được sau khi chiết xuất dầu từ cám gạo. Một số khô dầu và các phế liệu rắn khác (khô dầu hạt lanh, hạt bông, vừng, cùi dừa,...) là một loại thức ăn chăn nuôi có giá trị; một số khác (ví dụ, khô dầu thầu dầu) không thích hợp làm thức ăn chăn nuôi và được sử dụng làm phân bón; một số khác (ví dụ, khô dầu hạnh nhân đắng và khô dầu mù tạt) được sử dụng để chiết xuất tinh dầu. Phế liệu được phân loại trong nhóm này có thể có dạng phiến dẹt (bánh), dạng bột thô hoặc viên (xem phần Chú giải Tổng quát của Chương này). Nhóm này cũng bao gồm loại bột đã khử dầu chưa được tạo liên kết, thích hợp dùng làm thức ăn cho người."],"khong_bao_gom":["cặn dầu (nhóm 15.22)."],"loai_tru":["cặn dầu (nhóm 15.22)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hạt có dầu","cám gạo"],"cau_tao":"phiến dẹt (bánh), dạng bột","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["thức ăn cho người"],"ktcn":[{"mo_ta":"Kiểm dịch thực vật","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M9","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.06","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.06"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230641","ahtn_8so":"23064120","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23064910":{"hs":"23064910","chapter":23,"heading":"2306","subheading":"230649","parent_hs":null,"fact_layer":{"vn":"- - - Từ hạt cải dầu rape khác","en":null,"dvt":"kg","rates":{"tt":"5","mfn":"0","vat":"5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Kiểm dịch thực vật (01/2024/TT-BNNPTNT M9)","canh_bao_cs":true,"muc_canh_bao":"ORANGE","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"Nhóm này bao gồm các loại khô dầu và các phế liệu rắn khác, trừ các loại thuộc\nnhóm 23.04 hoặc 23.05, còn lại sau khi chiết xuất dầu từ hạt có dầu, quả có\ndầu và mầm ngũ cốc bằng dung môi hoặc bằng ép hoặc ép quay.\nNhóm này cũng bao gồm cám gạo đã được khử dầu là loại phế liệu thu được sau\nkhi chiết xuất dầu từ cám gạo.\nMột số khô dầu và các phế liệu rắn khác (khô dầu hạt lanh, hạt bông, vừng, cùi\ndừa,...) là một loại thức ăn chăn nuôi có giá trị; một số khác (ví dụ, khô dầu\nthầu dầu) không thích hợp làm thức ăn chăn nuôi và được sử dụng làm phân\nbón; một số khác (ví dụ, khô dầu hạnh nhân đắng và khô dầu mù tạt) được sử\ndụng để chiết xuất tinh dầu.\nPhế liệu được phân loại trong nhóm này có thể có dạng phiến dẹt (bánh), dạng bột\nthô hoặc viên (xem phần Chú giải Tổng quát của Chương này).\nNhóm này cũng bao gồm loại bột đã khử dầu chưa được tạo liên kết, thích hợp\ndùng làm thức ăn cho người.\nNhóm này không bao gồm cặn dầu (nhóm 15.22).","chu_giai_dong":null,"bao_gom":["các loại khô dầu và các phế liệu rắn khác, trừ các loại thuộc nhóm 23.04 hoặc 23.05, còn lại sau khi chiết xuất dầu từ hạt có dầu, quả có dầu và mầm ngũ cốc bằng dung môi hoặc bằng ép hoặc ép quay. Nhóm này cũng bao gồm cám gạo đã được khử dầu là loại phế liệu thu được sau khi chiết xuất dầu từ cám gạo. Một số khô dầu và các phế liệu rắn khác (khô dầu hạt lanh, hạt bông, vừng, cùi dừa,...) là một loại thức ăn chăn nuôi có giá trị; một số khác (ví dụ, khô dầu thầu dầu) không thích hợp làm thức ăn chăn nuôi và được sử dụng làm phân bón; một số khác (ví dụ, khô dầu hạnh nhân đắng và khô dầu mù tạt) được sử dụng để chiết xuất tinh dầu. Phế liệu được phân loại trong nhóm này có thể có dạng phiến dẹt (bánh), dạng bột thô hoặc viên (xem phần Chú giải Tổng quát của Chương này). Nhóm này cũng bao gồm loại bột đã khử dầu chưa được tạo liên kết, thích hợp dùng làm thức ăn cho người."],"khong_bao_gom":["cặn dầu (nhóm 15.22)."],"loai_tru":["cặn dầu (nhóm 15.22)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hạt có dầu","cám gạo"],"cau_tao":"phiến dẹt (bánh), dạng bột","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["thức ăn cho người"],"ktcn":[{"mo_ta":"Kiểm dịch thực vật","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M9","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.06","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.06"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230649","ahtn_8so":"23064910","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23064920":{"h