uôi có giá trị; một số khác (ví dụ, khô dầu thầu dầu) không thích hợp làm thức ăn chăn nuôi và được sử dụng làm phân bón; một số khác (ví dụ, khô dầu hạnh nhân đắng và khô dầu mù tạt) được sử dụng để chiết xuất tinh dầu. Phế liệu được phân loại trong nhóm này có thể có dạng phiến dẹt (bánh), dạng bột thô hoặc viên (xem phần Chú giải Tổng quát của Chương này). Nhóm này cũng bao gồm loại bột đã khử dầu chưa được tạo liên kết, thích hợp dùng làm thức ăn cho người."],"khong_bao_gom":["cặn dầu (nhóm 15.22)."],"loai_tru":["cặn dầu (nhóm 15.22)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hạt có dầu","cám gạo"],"cau_tao":"phiến dẹt (bánh), dạng bột","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["thức ăn cho người"],"ktcn":[{"mo_ta":"Kiểm dịch thực vật","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M9","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.06","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.06"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gi