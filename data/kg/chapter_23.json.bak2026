hú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"Nhóm này bao gồm các loại khô dầu và các phế liệu rắn khác còn lại sau khi chiết xuất dầu từ hạt đậu tương bằng dung môi hoặc bằng ép hoặc ép quay. Các phế liệu này là loại thức ăn chăn nuôi có giá trị. Các phế liệu được phân loại trong nhóm này có thể có dạng bánh dẹt (bánh tròn mỏng), dạng bột thô hoặc dạng viên (xem phần Chú giải Tổng quát của Chương này). Nhóm này cũng bao gồm bột mịn của hạt đậu tương đã khử chất béo không có kết cấu thích hợp dùng làm thức ăn cho người. Nhóm này không bao gồm:\n(a) Cáu, cặn dầu (nhóm 15.22).\n(b) Protein cô đặc thu được bằng cách loại bỏ bớt một số thành phần của bột đậu tương đã khử chất béo (sử dụng như là phụ gia trong các chế phẩm thực phẩm) và bột đậu tương đã được tạo kết cấu (nhóm 21.06).","chu_giai_dong":null,"bao_gom":["các loại khô dầu và các phế liệu rắn khác còn lại sau khi chiết xuất dầu từ hạt đậu tương bằng dung môi hoặc bằng ép hoặc ép quay. Các phế liệu này là loại thức ăn chăn nuôi có giá trị. Các phế liệu được phân loại trong nhóm này có thể có dạng bánh dẹt (bánh tròn mỏng), dạng bột thô hoặc dạng viên (xem phần Chú giải Tổng quát của Chương này). Nhóm này cũng bao gồm bột mịn của hạt đậu tương đã khử chất béo không có kết cấu thích hợp dùng làm thức ăn cho người."],"khong_bao_gom":["(a) Cáu, cặn dầu (nhóm 15.22).","(b) Protein cô đặc thu được bằng cách loại bỏ bớt một số thành phần của bột đậu tương đã khử chất béo (sử dụng như là phụ gia trong các chế phẩm thực phẩm) và bột đậu tương đã được tạo kết cấu (nhóm 21.06)."],"loai_tru":["(a) Cáu, cặn dầu (nhóm 15.22)","ư là phụ gia trong các chế phẩm thực phẩm) và bột đậu tương đã được tạo kết cấu (nhóm 21.06)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hạt đậu tương bằng dung môi hoặc bằng ép hoặc ép quay"],"cau_tao":"bánh dẹt (bánh tròn mỏng), dạng bột thô hoặc dạng viên (xem phần Chú giải Tổng quát của Chương này)","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["thức ăn cho người"]},"phan_biet":[],"sen":{"co":true,"noi_dung":"ĂN CHO NGƯỜI Bột đậu tương thô, thích hợp dùng làm thức ăn cho người, là một loại khô dầu được tạo ra từ việc chiết xuất dầu đậu nành, được các cơ quan quốc gia có thẩm quyền coi là phù hợp để làm thức ăn cho người và thường được kèm theo chứng chỉ Non-GMO (Không biến đổi gen) do các cơ quan liên quan ở nước xuất khẩu cấp để chứng nhận chúng thích hợp dùng làm thức ăn cho người. Sản phẩm thường chứa độ ẩm không quá 12%, protein không ít hơn 46%, chất béo dưới 1,5%, chất xơ không quá 7% và tro không quá 6,5%. Hình 1. Đậu tương và bột đậu tương","source":"SEN AHTN 2022 (CV 3866/TCHQ-TXNK 2023)","vi_du_sen":["BỘT ĐẬU TƯƠNG THÔ, THÍCH HỢP DÙNG LÀM THỨC"]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.04","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.04","SEN AHTN 2022 (CV 3866/TCHQ-TXNK 2023)"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"GREEN"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230400","ahtn_8so":"23040021","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23040029":{"hs":"23040029","chapter":23,"heading":"2304","subheading":"230400","parent_hs":null,"fact_layer":{"vn":"- - Loại khác","en":null,"dvt":"kg","rates":{"tt":"0","mfn":"0","vat":"5/8/10","acfta":"0 (-MM, TH)","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":null,"canh_bao_cs":false,"muc_canh_bao":"GREEN","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"Nhóm này bao gồm các loại khô dầu và các phế liệu rắn khác còn lại sau khi chiết xuất dầu từ hạt đậu tương bằng dung môi hoặc bằng ép hoặc ép quay. Các phế liệu này là loại thức ăn chăn nuôi có giá trị. Các phế liệu được phân loại trong nhóm này có thể có dạng bánh dẹt (bánh tròn mỏng), dạng bột thô hoặc dạng viên (xem phần Chú giải Tổng quát của Chương này). Nhóm này cũng bao gồm bột mịn của hạt đậu tương đã khử chất béo không có kết cấu thích hợp dùng làm thức ăn cho người. Nhóm này không bao gồm:\n(a) Cáu, cặn dầu (nhóm 15.22).\n(b) Protein cô đặc thu được bằng cách loại bỏ bớt một số thành phần của bột đậu tương đã khử chất béo (sử dụng như là phụ gia trong các chế phẩm thực phẩm) và bột đậu tương đã được tạo kết cấu (nhóm 21.06).","chu_giai_dong":null,"bao_gom":["các loại khô dầu và các phế liệu rắn khác còn lại sau khi chiết xuất dầu từ hạt đậu tương bằng dung môi hoặc bằng ép hoặc ép quay. Các phế liệu này là loại thức ăn chăn nuôi có giá trị. Các phế liệu được phân loại trong nhóm này có thể có dạng bánh dẹt (bánh tròn mỏng), dạng bột thô hoặc dạng viên (xem phần Chú giải Tổng quát của Chương này). Nhóm này cũng bao gồm bột mịn của hạt đậu tương đã khử chất béo không có kết cấu thích hợp dùng làm thức ăn cho người."],"khong_bao_gom":["(a) Cáu, cặn dầu (nhóm 15.22).","(b) Protein cô đặc thu được bằng cách loại bỏ bớt một số thành phần của bột đậu tương đã khử chất béo (sử dụng như là phụ gia trong các chế phẩm thực phẩm) và bột đậu tương đã được tạo kết cấu (nhóm 21.06)."],"loai_tru":["(a) Cáu, cặn dầu (nhóm 15.22)","ư là phụ gia trong các chế phẩm thực phẩm) và bột đậu tương đã được tạo kết cấu (nhóm 21.06)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hạt đậu tương bằng dung môi hoặc bằng ép hoặc ép quay"],"cau_tao":"bánh dẹt (bánh tròn mỏng), dạng bột thô hoặc dạng viên (xem phần Chú giải Tổng quát của Chương này)","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["thức ăn cho người"]},"phan_biet":[],"sen":{"co":true,"noi_dung":"HỢP DÙNG LÀM THỨC ĂN CHO NGƯỜI Bột đậu tương đã được khử chất béo, thích hợp dùng làm thức ăn cho người, là một sản phẩm đã chế biến có độ ẩm dưới 8%, protein từ 50% trở lên, chất béo dưới 1%, và chất xơ dưới 1%. Bột đậu tương đã khử chất béo có chỉ số hòa tan nitơ từ 70% trở lên và tỷ lệ tối thiểu 95% lọt qua sàng với kích thước mắt sàng 100, được cơ quan nhà nước có thẩm quyền cho phép sử dụng làm thức ăn cho người.","source":"SEN AHTN 2022 (CV 3866/TCHQ-TXNK 2023)","vi_du_sen":["BỘT ĐẬU TƯƠNG ĐÃ ĐƯỢC KHỬ CHẤT BÉO, THÍCH"]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.04","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.04","SEN AHTN 2022 (CV 3866/TCHQ-TXNK 2023)"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"GREEN"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","che