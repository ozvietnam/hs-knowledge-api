 mịn và chứa chủ yếu các phần rất mịn của vỏ hạt còn sót lại sau khi rây, sàng và một ít bột.\n(B) Phế liệu thu được từ việc sàng, sảy hoặc từ các công đoạn xử lý khác của hạt ngũ cốc. Phế liệu chọn lọc thu được từ quá trình sàng sảy trước khi xay xát, chủ yếu gồm có:\n- hạt ngũ cốc cơ bản nhưng nhỏ hơn, biến dạng, vỡ mảnh hoặc vụn.\n- hạt của một số cây khác lẫn vào với hạt ngũ cốc cơ bản;\n- mảnh vụn của lá, cành, chất khoáng,... Mục này cũng bao gồm:\n(1) Các phế liệu từ quá trình làm sạch thùng chứa, hầm chứa của tàu, thuyền..., có thành phần tương tự với các thành phần nêu trên.\n(2) Vỏ lụa của gạo trong công đoạn tẩy trắng gạo.\n\n(3) Các phế liệu thu được từ quá trình tách vỏ hạt, nghiền mảnh, nghiền vụn, đánh bóng, sắt lát hoặc nghiền sơ hạt ngũ cốc.\n(C) Các phế liệu và phế thải của loại tương tự thu được từ quá trình nghiền hoặc từ các công đoạn chế biến khác của các loại cây họ đậu. Nhóm này cũng bao gồm các sản phẩm trên dưới dạng viên (xem\nChú giải Tổng quát của Chương này).\n\nNhóm này cũng bao gồm phần thu được từ việc nghiền ngô còn nguyên bắp đã hoặc chưa được bóc lá bao, không thỏa mãn tiêu chí về hàm lượng tinh bột và hàm lượng tro yêu cầu đối với các sản phẩm xay xát của ngô tại Chú giải 2 (A) của Chương 11. Vỏ, trấu ngũ cốc thu được trong quá trình đập ngũ cốc, được phân loại vào nhóm 12.13. Nhóm này không bao gồm khô dầu hoặc các loại phế liệu rắn khác thu được từ công đoạn chiết xuất chất béo hoặc d","chu_giai_dong":null,"bao_gom":[],"khong_bao_gom":["khô dầu hoặc các loại phế liệu rắn khác thu được từ công đoạn chiết xuất chất béo hoặc dầu thực vật (các nhóm từ 23.04 đến 23.06)."],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["các quá trình xay xát lúa mì","ngũ cốc nghiền như là một sản phẩm phụ trong chế biến bột mịn và chứa chủ yếu cá","việc sàng","các công đoạn xử lý khác của hạt ngũ cốc","quá trình sàng sảy trước khi xay xát","quá trình làm sạch thùng chứa","quá trình tách vỏ hạt","quá trình nghiền hoặc từ các công đoạn chế biến khác của các loại cây họ đậu","việc nghiền ngô còn nguyên bắp đã hoặc chưa được bóc lá bao","công đoạn chiết xuất chất béo hoặc dầu thực vật (các nhóm từ 23"],"cau_tao":"viên (xem","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"Kiểm dịch thực vật","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M9","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.02","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.02"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":true,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230240","ahtn_8so":"23024090","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23025000":{"hs":"23025000","chapter":23,"heading":"2302","subheading":"230250","parent_hs":null,"fact_layer":{"vn":"- Từ cây họ đậu","en":null,"dvt":"kg","rates":{"tt":"5","mfn":"0","vat":"5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Kiểm dịch thực vật (01/2024/TT-BNNPTNT M9)","canh_bao_cs":true,"muc_canh_bao":"ORANGE","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"(A) Cám, tấm và phế liệu khác của qui trình xay xát hạt ngũ cốc. Mục này chủ yếu bao gồm các sản phẩm phụ thu được từ các quá trình xay xát lúa mì, mạch đen, đại mạch, yến mạch, ngô, lúa, gạo, hạt cao lương hoặc kiều mạch, mà các loại này không đáp ứng được những điều kiện về hàm lượng tinh bột và hàm lượng tro được quy định tại\nChú giải 2 (A) của Chương 11. Các sản phẩm này chủ yếu là:\n(1) Cám gồm có phần vỏ ngoài của hạt ngũ cốc dính một phần nội nhũ và một ít bột.\n\n(2) Tấm (hoặc hạt tấm), thu được từ ngũ cốc nghiền như là một sản phẩm phụ trong chế biến bột mịn và chứa chủ yếu các phần rất mịn của vỏ hạt còn sót lại sau khi rây, sàng và một ít bột.\n(B) Phế liệu thu được từ việc sàng, sảy hoặc từ các công đoạn xử lý khác của hạt ngũ cốc. Phế liệu chọn lọc thu được từ quá trình sàng sảy trước khi xay xát, chủ yếu gồm có:\n- hạt ngũ cốc cơ bản nhưng nhỏ hơn, biến dạng, vỡ mảnh hoặc vụn.\n- hạt của một số cây khác lẫn vào với hạt ngũ cốc cơ bản;\n- mảnh vụn của lá, cành, chất khoáng,... Mục này cũng bao gồm:\n(1) Các phế liệu từ quá trình làm sạch thùng chứa, hầm chứa của tàu, thuyền..., có thành phần tương tự với các thành phần nêu trên.\n(2) Vỏ lụa của gạo trong công đoạn tẩy trắng gạo.\n\n(3) Các phế liệu thu được từ quá trình tách vỏ hạt, nghiền mảnh, nghiền vụn, đánh bóng, sắt lát hoặc nghiền sơ hạt ngũ cốc.\n(C) Các phế liệu và phế thải của loại tương tự thu được từ quá trình nghiền hoặc từ các công đoạn chế biến khác của các loại cây họ đậu. Nhóm này cũng bao gồm các sản phẩm trên dưới dạng viên (xem\nChú giải Tổng quát của Chương này).\n\nNhóm này cũng bao gồm phần thu được từ việc nghiền ngô còn nguyên bắp đã hoặc chưa được bóc lá bao, không thỏa mãn tiêu chí về hàm lượng tinh bột và hàm lượng tro yêu cầu đối với các sản phẩm xay xát của ngô tại Chú giải 2 (A) của Chương 11. Vỏ, trấu ngũ cốc thu được trong quá trình đập ngũ cốc, được phân loại vào nhóm 12.13. Nhóm này không bao gồm khô dầu hoặc các loại phế liệu rắn khác thu được từ công đoạn chiết xuất chất béo hoặc d","chu_giai_dong":null,"bao_gom":[],"khong_bao_gom":["khô dầu hoặc các loại phế liệu rắn khác thu được từ công đoạn chiết xuất chất béo hoặc dầu thực vật (các nhóm từ 23.04 đến 23.06)."],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["các quá trình xay xát lúa mì","ngũ cốc nghiền như là một sản phẩm phụ trong chế biến bột mịn và chứa chủ yếu cá","việc sàng","các công đoạn xử lý khác của hạt ngũ cốc","quá trình sàng sảy trước khi xay xát","quá trình làm sạch thùng chứa","quá trình tách vỏ hạt","quá trình nghiền hoặc từ các công đoạn chế biến khác của các loại cây họ đậu","việc nghiền ngô còn nguyên bắp đã hoặc chưa được bóc lá bao","công đoạn chiết xuất chất béo hoặc dầu thực vật (các nhóm từ 23"],"cau_tao":"viên (xem","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"Kiểm dịch thực vật","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M9","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.02","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.02"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230250","ahtn_8so":"23025000","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23031010":{"hs":"23031010","chapter":23,"heading":"2303","subheading":"230310","parent_hs":null,"fact_layer":{"vn":"- - Từ sắn hoặc cọ sago","en":null,"dvt":"kg","rates":{"tt":"5","mfn":"0","vat":"5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Kiểm dịch thực vật (01/2024/TT-BNNPTNT M9)","canh_bao_cs":true,"muc_canh_bao":"ORANGE","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"(A) Phế liệu từ quá trình sản xuất tinh bột và các phế liệu tương tự (từ ngô, gạo, khoai tây,...) có chứa chủ yếu là các chất xơ và protein thường ở dạng viên hoặc bột thô, đôi khi có dạng bánh. Chúng được sử dụng làm thức ăn chăn nuôi hoặc làm phân bón; một số trong các phế liệu này (ví dụ, nước ngâm ngô) được sử dụng làm môi trường cấy để sản xuất thuốc kháng sinh.\n\n(B) Bã ép củ cải đường là phế liệu còn lại sau khi đường đã được chiết xuất từ củ cải đường. Bã này được phân loại trong nhóm này có thể ở dạng ẩm hoặc khô nhưng nếu thêm mật vào bã hoặc chế biến cách khác thành thức ăn chăn nuôi thì bã ép củ cải đường lại thuộc nhóm 23.09.\n(C) Bã mía là loại phế liệu bao gồm các phần xơ, thớ của mía đường thu được sau công đoạn ép nước. Bã mía được sử dụng trong công nghiệp giấy hoặc trong chế biến thức ăn chăn nuôi.\n\n(D) Các phế liệu khác từ sản xuất đường thuộc nhóm này gồm bọt hớt ở dung dịch để lắng trong, các phế liệu đọng lại trong các dụng cụ lọc ép...\n(E) Bã và phế liệu của quá trình ủ hoặc chưng cất, bao gồm chủ yếu:\n(1) Bã ngũ cốc (đại mạch, mạch đen...), thu được trong quá trình sản xuất bia và bao gồm phần hạt đã được ép kiệt đọng lại trong các thùng ủ sau khi chắt nước hèm.\n(2) Mầm của malt tách ra từ hạt malt trong quá trình sấy trong lò.\n(3) Phế thải của hoa bia (houblon) đã hoàn toàn được ép kiệt.\n(4) Bã phế liệu của một số công đoạn chưng cất rượu từ các loại hạt, khoai tây...\n(5) Bã làm từ củ cải đường (phế thải thu được sau quá trình chưng cất mật của củ cải đường). (Tất cả các sản phẩm này vẫn được phân loại trong nhóm này khi ở trạng thái khô hoặc ẩm.) Nhóm này cũng bao gồm các sản phẩm kể trên ở dạng viên (xem phần Chú giải Tổng quát của Chương này).\n\nNhóm này không bao gồm:\n(a) Mật thu được từ quá trình chiết xuất hoặc tinh chế đường (nhóm 17.03).\n(b) Men ỳ hoặc men đã qua sử dụng (nhóm 21.02).\n(c) Các loại muối kali thô thu được khi đốt hoặc rửa phế liệu của mật củ cải đường (nhóm 26.21).\n(d) Bột giấy từ bã mía đường (nhóm 47.06).","chu_giai_dong":null,"bao_gom":[],"khong_bao_gom":["(a) Mật thu được từ quá trình chiết xuất hoặc tinh chế đường (nhóm 17.03).","(b) Men ỳ hoặc men đã qua sử dụng (nhóm 21.02).","(c) Các loại muối kali thô thu được khi đốt hoặc rửa phế liệu của mật củ cải đường (nhóm 26.21).","(d) Bột giấy từ bã mía đường (nhóm 47.06)."],"loai_tru":["(a) Mật thu được từ quá trình chiết xuất hoặc tinh chế đường (nhóm 17.03)","chiết xuất hoặc tinh chế đường (nhóm 17.03).\n(b) Men ỳ hoặc men đã qua sử dụng (nhóm 21.02)","Các loại muối kali thô thu được khi đốt hoặc rửa phế liệu của mật củ cải đường (nhóm 26.21)","ặc rửa phế liệu của mật củ cải đường (nhóm 26.21).\n(d) Bột giấy từ bã mía đường (nhóm 47.06)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["quá trình sản xuất tinh bột và các phế liệu tương tự (từ ngô","củ cải đường","sản xuất đường thuộc nhóm này gồm bọt hớt ở dung dịch để lắng trong","hạt malt trong quá trình sấy trong lò","các loại hạt","củ cải đường (phế thải thu được sau quá trình chưng cất mật của củ cải đường)","quá trình chiết xuất hoặc tinh chế đường (nhóm 17","bã mía đường (nhóm 47"],"cau_tao":"viên hoặc bột thô, đôi khi có dạng bánh","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[],"ktcn":[{"mo_ta":"Kiểm dịch thực vật","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M9","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.03","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.03"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230310","ahtn_8so":"23031010","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_