 khác (ví dụ, khô dầu hạnh nhân đắng và khô dầu mù tạt) được sử\ndụng để chiết xuất tinh dầu.\nPhế liệu được phân loại trong nhóm này có thể có dạng phiến dẹt (bánh), dạng bột\nthô hoặc viên (xem phần Chú giải Tổng quát của Chương này).\nNhóm này cũng bao gồm loại bột đã khử dầu chưa được tạo liên kết, thích hợp\ndùng làm thức ăn cho người.\nNhóm này không bao gồm cặn dầu (nhóm 15.22).","chu_giai_dong":null,"bao_gom":["các loại khô dầu và các phế liệu rắn khác, trừ các loại thuộc nhóm 23.04 hoặc 23.05, còn lại sau khi chiết xuất dầu từ hạt có dầu, quả có dầu và mầm ngũ cốc bằng dung môi hoặc bằng ép hoặc ép quay. Nhóm này cũng bao gồm cám gạo đã được khử dầu là loại phế liệu thu được sau khi chiết xuất dầu từ cám gạo. Một số khô dầu và các phế liệu rắn khác (khô dầu hạt lanh, hạt bông, vừng, cùi dừa,...) là một loại thức ăn chăn nuôi có giá trị; một số khác (ví dụ, khô dầu thầu dầu) không thích hợp làm thức ăn chăn nuôi và được sử dụng làm phân bón; một số khác (ví dụ, khô dầu hạnh nhân đắng và khô dầu mù tạt) được sử dụng để chiết xuất tinh dầu. Phế liệu được phân loại trong nhóm này có thể có dạng phiến dẹt (bánh), dạng bột thô hoặc viên (xem phần Chú giải Tổng quát của Chương này). Nhóm này cũng bao gồm loại bột đã khử dầu chưa được tạo liên kết, thích hợp dùng làm thức ăn cho người."],"khong_bao_gom":["cặn dầu (nhóm 15.22)."],"loai_tru":["cặn dầu (nhóm 15.22)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hạt có dầu","cám gạo"],"cau_tao":"phiến dẹt (bánh), dạng bột","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["thức ăn cho người"],"ktcn":[{"mo_ta":"Kiểm dịch thực vật","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M9","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null