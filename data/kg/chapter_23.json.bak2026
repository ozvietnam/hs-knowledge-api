" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"Nhóm này bao gồm các loại khô dầu và các phế liệu rắn khác, trừ các loại thuộc\nnhóm 23.04 hoặc 23.05, còn lại sau khi chiết xuất dầu từ hạt có dầu, quả có\ndầu và mầm ngũ cốc bằng dung môi hoặc bằng ép hoặc ép quay.\nNhóm này cũng bao gồm cám gạo đã được khử dầu là loại phế liệu thu được sau\nkhi chiết xuất dầu từ cám gạo.\nMột số khô dầu và các phế liệu rắn khác (khô dầu hạt lanh, hạt bông, vừng, cùi\ndừa,...) là một loại thức ăn chăn nuôi có giá trị; một số khác (ví dụ, khô dầu\nthầu dầu) không thích hợp làm thức ăn chăn nuôi và được sử dụng làm phân\nbón; một số khác (ví dụ, khô dầu hạnh nhân đắng và khô dầu mù tạt) được sử\ndụng để chiết xuất tinh dầu.\nPhế liệu được phân loại trong nhóm này có thể có dạng phiến dẹt (bánh), dạng bột\nthô hoặc viên (xem phần Chú giải Tổng quát của Chương này).\nNhóm này cũng bao gồm loại bột đã khử dầu chưa được tạo liên kết, thích hợp\ndùng làm thức ăn cho người.\nNhóm này không bao gồm cặn dầu (nhóm 15.22).","chu_giai_dong":null,"bao_gom":["các loại khô dầu và các phế liệu rắn khác, trừ các loại thuộc nhóm 23.04 hoặc 23.05, còn lại sau khi chiết xuất dầu từ hạt có dầu, quả có dầu và mầm ngũ cốc bằng dung môi hoặc bằng ép hoặc ép quay. Nhóm này cũng bao gồm cám gạo đã được khử dầu là loại phế liệu thu được sau khi chiết xuất dầu từ cám gạo. Một số khô dầu và các phế liệu rắn khác (khô dầu hạt lanh, hạt bông, vừng, cùi dừa,...) là một loại thức ăn chăn nuôi có giá trị; một số khác (ví dụ, khô dầu thầu dầu) không thích hợp làm thức ăn chăn nuôi và được sử dụng làm phân bón; một số khác (ví dụ, khô dầu hạnh nhân đắng và khô dầu mù tạt) được sử dụng để chiết xuất tinh dầu. Phế liệu được phân loại trong nhóm này có thể có dạng phiến dẹt (bánh), dạng bột thô hoặc viên (xem phần Chú giải Tổng quát của Chương này). Nhóm này cũng bao gồm loại bột đã khử dầu chưa được tạo liên kết, thích hợp dùng làm thức ăn cho người."],"khong_bao_gom":["cặn dầu (nhóm 15.22)."],"loai_tru":["cặn dầu (nhóm 15.22)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["hạt có dầu","cám gạo"],"cau_tao":"phiến dẹt (bánh), dạng bột","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["thức ăn cho người"],"ktcn":[{"mo_ta":"Kiểm dịch thực vật","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M9","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.06","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.06"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":true,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230690","ahtn_8so":"23069090","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23070000":{"hs":"23070000","chapter":23,"heading":"2307","subheading":"230700","parent_hs":null,"fact_layer":{"vn":"Bã rượu vang; cặn rượu","en":null,"dvt":"kg","rates":{"tt":"5","mfn":"0","vat":"5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":null,"canh_bao_cs":false,"muc_canh_bao":"GREEN","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"Nhóm này không bao gồm kem tartar (nhóm 29.18) và tartrate canxi (nhóm 29.18 hoặc 38.24, tuỳ theo từng trường hợp).","chu_giai_dong":null,"bao_gom":[],"khong_bao_gom":["kem tartar (nhóm 29.18) và tartrate canxi (nhóm 29.18 hoặc 38.24, tuỳ theo từng trường hợp)."],"loai_tru":["kem tartar (nhóm 29.18)","kem tartar (nhóm 29.18) và tartrate canxi (nhóm 29.18"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["xám đến"],"cau_tao":"bột hoặc dạng hạt, hoặc ở dạng mảnh vỡ không đều","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chế biến thức ăn chăn nuôi"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.07","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.07"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"GREEN"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230700","ahtn_8so":"23070000","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23080000":{"hs":"23080000","chapter":23,"heading":"2308","subheading":"230800","parent_hs":null,"fact_layer":{"vn":"Nguyên liệu thực vật và phế liệu thực vật, phế liệu và sản phẩm phụ từ thực vật, ở dạng viên hoặc không ở dạng viên, loại dùng trong chăn nuôi động vật, chưa được chi tiết hoặc ghi ở nơi khác","en":null,"dvt":"kg","rates":{"tt":"5","mfn":"0","vat":"5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Kiểm dịch thực vật (01/2024/TT-BNNPTNT M9)","canh_bao_cs":true,"muc_canh_bao":"ORANGE","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"Nhóm này có thể kể đến:\n(1) Sồi và hạt dẻ ngựa.\n(2) Lõi bắp ngô sau khi tách hạt; thân và lá ngô.\n\n(3) Cọng, lá của cà rốt hoặc của củ cải đường.\n(4) Phần vỏ ngoài của rau (vỏ quả đậu hoặc vỏ đậu Hà Lan,...).\n(5) Các phế thải từ quả (như vỏ và lõi táo, lê...) và bã quả (từ việc ép nho, táo, lê, quả chi cam quýt,...), ngay cả khi chúng cũng có thể được sử dụng để chiết xuất lấy pectine.\n\n(6) Cám thu được như là sản phẩm phụ từ việc nghiền hạt mù tạt.\n(7) Các phế liệu còn lại sau khi chế biến các chất thay thế cà phê (hoặc chiết xuất của chúng) từ hạt ngũ cốc hoặc từ nguyên liệu thực vật khác.\n(8) Các sản phẩm phụ thu được bằng cách chưng cô các loại nước phế thải của quá trình chế biến nước ép quả chi cam quýt, đôi khi được gọi là mật quả chi cam quýt.\n(9) Phế liệu thu được từ quá trình thuỷ phân lõi ngô để thu chất 2-furaldehyde, được gọi là “bột lõi ngô đã thuỷ phân”. Các sản phẩm của nhóm này cũng có thể ở dạng viên (xem Chú giải Tổng quát của Chương này).","chu_giai_dong":null,"bao_gom":["các sản phẩm thực vật, phế thải thực vật, và phế liệu và sản phẩm phụ từ quá trình chế biến công nghiệp các vật liệu thực vật để chiết xuất một số thành phần của chúng. Nhóm này có thể kể đến:","(1) Sồi và hạt dẻ ngựa.","(2) Lõi bắp ngô sau khi tách hạt; thân và lá ngô.","(3) Cọng, lá của cà rốt hoặc của củ cải đường.","(4) Phần vỏ ngoài của rau (vỏ quả đậu hoặc vỏ đậu Hà Lan,...).","(5) Các phế thải từ quả (như vỏ và lõi táo, lê...) và bã quả (từ việc ép nho, táo, lê, quả chi cam quýt,...), ngay cả khi chúng cũng có thể được sử dụng để chiết xuất lấy pectine.","(6) Cám thu được như là sản phẩm phụ từ việc nghiền hạt mù tạt.","(7) Các phế liệu còn lại sau khi chế biến các chất thay thế cà phê (hoặc chiết xuất của chúng) từ hạt ngũ cốc hoặc từ nguyên liệu thực vật khác.","(8) Các sản phẩm phụ thu được bằng cách chưng cô các loại nước phế thải của quá trình chế biến nước ép quả chi cam quýt, đôi khi được gọi là mật quả chi cam quýt.","(9) Phế liệu thu được từ quá trình thuỷ phân lõi ngô để thu chất 2-furaldehyde, được gọi là “bột lõi ngô đã thuỷ phân”. Các sản phẩm của nhóm này cũng có thể ở dạng viên (xem Chú giải Tổng quát của Chương này)."],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["quả (như vỏ và lõi táo","việc ép nho","việc nghiền hạt mù tạt","hạt ngũ cốc hoặc từ nguyên liệu thực vật khác","quá trình thuỷ phân lõi ngô để thu chất 2-furaldehyde"],"cau_tao":"viên (xem Chú giải Tổng quát của Chương này)","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chiết xuất lấy pectine"],"ktcn":[{"mo_ta":"Kiểm dịch thực vật","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M9","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"ORANGE","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.08","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.08"],"case_history":[{"so_hieu":"811/TB-TCHQ","ngay":"23/06/2014","hang_hoa":"Herb-All LIVER","noi_dung":"Tình trạng hiệu lực:\nĐã biết\nHiệu lực: Đã biết\nTình trạng hiệu lực: Đã biết\nBỘ TÀI CHÍNH\nTỔNG CỤC HẢI QUAN\n-------\nCỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM\nĐộc lập - Tự do - Hạnh phúc\n---------------\nSố: 811/TB-TCHQ\nHà Nội, ngày\n11\nth\ná\nng 3 năm 2022\nTHÔNG BÁO\nVề kết quả xác định trước mã số\nTỔNG CỤC TRƯỞ","co_tranh_chap":false,"ma_hs_ban_dau":"","url":"https://luatvietnam.vn/xuat-nhap-khau/thong-bao-811-tb-tchq-2022-ket-qua-xac-dinh-truoc-ma-so-doi-voi-herb-all-liver-294599-d6.html"},{"so_hieu":"810/TB-TCHQ","ngay":"11/03/2022","hang_hoa":"Herb-All GUT","noi_dung":"Tình trạng hiệu lực:\nĐã biết\nHiệu lực: Đã biết\nTình trạng hiệu lực: Đã biết\nBỘ TÀI CHÍNH\nTỔNG CỤC HẢI QUAN\n-------\nCỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM\nĐộc lập - Tự do - Hạnh phúc\n---------------\nSố: 810/TB-TCHQ\nHà Nội, ngày 11 tháng 3 năm 2022\nTHÔNG BÁO\nVề kết quả xác định trước mã số\nTỔNG CỤC TRƯỞNG","co_tranh_chap":false,"ma_hs_ban_dau":"","url":"https://luatvietnam.vn/xuat-nhap-khau/thong-bao-810-tb-tchq-2022-ket-qua-xac-dinh-truoc-ma-so-doi-voi-herb-all-gut-294600-d6.html"},{"so_hieu":"809/TB-TCHQ","ngay":"11/03/2022","hang_hoa":"Herb-All COCC-X","noi_dung":"Tình trạng hiệu lực:\nĐã biết\nHiệu lực: Đã biết\nTình trạng hiệu lực: Đã biết\nBỘ TÀI CHÍNH\nTỔNG CỤC HẢI QUAN\n-------\nCỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM\nĐộc lập - Tự do - Hạnh phúc\n---------------\nSố: 809/TB-TCHQ\nHà Nội, ngày 11 tháng 3 năm 2022\nTHÔNG BÁO\nVề kết quả xác định trước mã số\nTỔNG CỤC TRƯỞNG","co_tranh_chap":false,"ma_hs_ban_dau":"","url":"https://luatvietnam.vn/xuat-nhap-khau/thong-bao-809-tb-tchq-2022-ket-qua-xac-dinh-truoc-ma-so-doi-voi-herb-all-cocc-x-294605-d6.html"}]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"ORANGE"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230800","ahtn_8so":"23080000","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23091010":{"hs":"23091010","chapter":23,"heading":"2309","subheading":"230910","parent_hs":null,"fact_layer":{"vn":"- - Chứa thịt","en":null,"dvt":"kg","rates":{"tt":"10.5","mfn":"7","vat":"5/8/10","acfta":"0 (-TH)","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch (01/2024/TT-BNNPTNT M1); Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN (01/2024/TT-BNNPTNT M15)","canh_bao_cs":true,"muc_canh_bao":"RED","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"(1) để cung cấp cho động vật một khẩu phần ăn trong ngày hợp lý và cân bằng (thức ăn hoàn chỉnh);\n(2) để đạt được một chế độ ăn hàng ngày phù hợp bằng cách bổ sung vào thức ăn cơ bản được sản xuất ở trang trại bằng các chất hữu cơ hoặc vô cơ (thức ăn bổ sung); hoặc\n(3) để sử dụng trong sản xuất các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. Nhóm này bao gồm các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.\n(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn.\n\nTheo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC\n(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:\n\n(1) Các chấ","chu_giai_dong":null,"bao_gom":["các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.","(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn. Theo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC","(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","(1) Các chất dinh dưỡng \"năng lượng\", bao gồm các chất carbohydrate cao (calo cao) như tinh bột, đường, cellulose, và chất béo, được cơ thể động vật “đốt cháy” và chuyển hoá thành năng lượng cần thiết cho sự sống và đạt các mục tiêu của các nhà chăn nuôi. Thí dụ ta có thể kể ra đây một số thức ăn thuộc loại này như ngũ cốc, cải có ít đường, mỡ động vật, rơm.","(2) Các chất dinh dưỡng giầu protein hoặc muối khoáng được gọi là “các chất để xây dựng cơ thể”. Khác với các chất dinh dưỡng năng lượng ở mục trên, các chất dinh dưỡng này không bị “đốt cháy” trong cơ thể động vật mà tham gia vào việc xây dựng các mô hoặc vào các quá trình khác trong cơ thể vật (sản sinh sữa, trứng...). Chúng chủ yếu bao gồm protein hoặc muối khoáng. Ta có thể kể ví dụ ra đây một số chất giầu protein được sử dụng cho mục đích này là các loại rau đậu, bã của quá trình ủ, khô dầu, các sản phẩm phụ của sữa. Muối khoáng chủ yếu tham gia vào quá trình phát triển xương và đối với gia cầm là quá trình làm vỏ trứng. Loại thông dụng nhất được sử dụng có chứa canxi, phosphor, chlorine, natri, kali, sắt, iốt,...","(3) Các chất dinh dưỡng \"chức năng\". Các loại này là các chất thúc đẩy việc hấp thụ carbohydrate, protein và muối khoáng. Chúng bao gồm vitamin, các nguyên tố vi lượng và kháng sinh. Nếu thiếu hoặc không có các chất dinh dưỡng này sẽ dẫn đến rối loạn về sức khoẻ của động vật. Ba nhóm chất dinh dưỡng này đáp ứng nhu cầu về thực phẩm đầy đủ của động vật. Hỗn hợp và tỉ lệ các chất dinh dưỡng này phụ thuộc vào cách sản xuất sản phẩm cho động vật.","(B) CÁC CHẾ PHẨM SỬ DỤNG ĐỂ BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI BỔ SUNG) Các loại thức ăn được chế biến ở trang trại thường là thấp về protein, muối khoáng hoặc vitamin. Các chế phẩm được dùng để bù vào các phần thiếu hụt trên, để đảm bảo một khẩu phần ăn cho động vật được cân bằng, gồm protein, muối khoáng hoặc vitamin, có thêm các loại thức ăn bổ sung năng lượng (carbohydrate) được coi là chất mang cho các thành phần khác. Tuy rằng, về mặt chất lượng, các chế phẩm này có các thành phần tương tự như các thành phần của các chế phẩm được nêu ở mục (A) trên đây, chúng khác các chế phẩm trên ở chỗ trong thành phần của chúng có chứa hàm lượng tương đối lớn của một loại chất dinh dưỡng cụ thể. Nhóm này bao gồm:","(1) Các sản phẩm hòa tan được chiết xuất từ cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan trong nước như protein, vitamin B, muối,...), và được sản xuất từ dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển.","(2) Các protein cô đặc của lá cây có màu xanh và phần phân đoạn xanh của chất cô đặc protein từ lá cây, thu được từ xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng).","(C) CÁC CHẾ PHẨM SỬ DỤNG TRONG CHẾ BIẾN THỨC ĂN CHĂN NUÔI HOÀN CHỈNH HOẶC THỨC ĂN CHĂN NUÔI BỔ SUNG ĐƯỢC MÔ TẢ Ở MỤC (A) VÀ","(B) Ở TRÊN Các chế phẩm này, được biết đến với tên thư"],"khong_bao_gom":["(a) Viên được sản xuất từ một loại nguyên liệu, hoặc từ hỗn hợp của các nguyên liệu được phân loại vào một nhóm cụ thể, thậm chí được trộn thêm chất kết dính (mật, chất có tinh bột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14, 12.14, 23.01, …).","(b) Các hỗn hợp đơn giản của hạt ngũ cốc (Chương 10), của bột ngũ cốc hoặc của bột rau đậu (Chương 11).","(c) Các chế phẩm có thể được dùng để làm thức ăn chăn nuôi hoặc thức ăn cho người tuỳ theo bản chất, độ tinh khiết và tỉ lệ tương ứng của các thành phần, tuỳ theo điều kiện vệ sinh trong quá trình chế biến và nếu cần, tuỳ theo những chỉ dẫn được ghi trên bao bì hoặc tất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01 và 21.06).","(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08. 214","(e) Vitamin, xác định hoặc không xác định về mặt hóa học hoặc pha trộn hóa học, trong dung môi hoặc không trong dung môi hoặc được làm ổn định bằng việc bổ sung các chất chống oxy hóa hoặc các chất chống vón, hoặc bằng cách hút bám trên một chất nền hoặc bằng cách phủ bảo vệ bằng, ví dụ, galetin, sáp, chất béo,..., với điều kiện số lượng các chất bổ sung, chất nền hoặc chất phủ không vượt quá yêu cầu bảo quản hoặc vận chuyển và với điều kiện các chất bổ sung, chất nền hoặc chất phủ không làm thay đổi đặc tính của vitamin và không biến chúng đặc biệt phục vụ cho một nhu cầu một nhu cầu cụ thể mà không dùng cho việc sử dụng chung (nhóm 29.36).","(f) Các sản phẩm của Chương 29.","(g) Dược phẩm thuộc nhóm 30.03 và 30.04.","(h) Các chất protein thuộc Chương 35.","(ij) Các chế phẩm có bản chất là các chất tẩy uế chống vi trùng được sử dụng trong việc chế biến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm 38.08).","(k) Các sản phẩm trung gian của quá trình sản xuất thuốc kháng sinh thu được bằng việc lọc và chiết xuất lần đầu và phế liệu từ quá trình sản xuất này, với hàm lượng chất kháng sinh thường không quá 70% (nhóm 38.24). 215"],"loai_tru":["mật, chất có tinh\nbột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14","hi trên bao bì hoặc\ntất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01","các nhóm 19.01 và 21.06).\n(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08","phục vụ cho một nhu cầu một nhu cầu cụ thể mà\nkhông dùng cho việc sử dụng chung (nhóm 29.36)","sử dụng chung (nhóm 29.36).\n(f) Các sản phẩm của Chương 29.\n(g) Dược phẩm thuộc nhóm 30.03","chế\nbiến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm\n38.08)","u từ quá trình sản xuất này, với hàm lượng chất kháng sinh\nthường không quá 70% (nhóm 38.24)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chún","các nguyên liệu thực vật","mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bộ","dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển","lá cây","xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng)"],"cau_tao":"dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan tro","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chăn nuôi động vật","gia súc","chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung","BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI B","bù vào các phần thiếu hụt trên"],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M1","co_quan":"BNNPTNT","loai":"kiem_dich_dong_vat","tier":3,"loai_ten":"Kiểm dịch động vật và sản phẩm động vật trên cạn","don_vi":"Cục Thú y"},{"mo_ta":"Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M15","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"RED","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.09","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.09"],"conflict":{"has_conflict":true,"count":1,"items":[{"type":"C2","severity":"MEDIUM","desc":"BNNPTNT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: kiem_dich_dong_vat, thuc_an_chan_nuoi"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"RED"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230910","ahtn_8so":"23091010","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23091090":{"hs":"23091090","chapter":23,"heading":"2309","subheading":"230910","parent_hs":null,"fact_layer":{"vn":"- - Loại khác","en":null,"dvt":"kg","rates":{"tt":"10.5","mfn":"7","vat":"5/8/10","acfta":"0 (-TH)","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch (01/2024/TT-BNNPTNT M1); Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN (01/2024/TT-BNNPTNT M15)","canh_bao_cs":true,"muc_canh_bao":"RED","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"(1) để cung cấp cho động vật một khẩu phần ăn trong ngày hợp lý và cân bằng (thức ăn hoàn chỉnh);\n(2) để đạt được một chế độ ăn hàng ngày phù hợp bằng cách bổ sung vào thức ăn cơ bản được sản xuất ở trang trại bằng các chất hữu cơ hoặc vô cơ (thức ăn bổ sung); hoặc\n(3) để sử dụng trong sản xuất các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. Nhóm này bao gồm các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.\n(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn.\n\nTheo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC\n(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:\n\n(1) Các chấ","chu_giai_dong":null,"bao_gom":["các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.","(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn. Theo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC","(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","(1) Các chất dinh dưỡng \"năng lượng\", bao gồm các chất carbohydrate cao (calo cao) như tinh bột, đường, cellulose, và chất béo, được cơ thể động vật “đốt cháy” và chuyển hoá thành năng lượng cần thiết cho sự sống và đạt các mục tiêu của các nhà chăn nuôi. Thí dụ ta có thể kể ra đây một số thức ăn thuộc loại này như ngũ cốc, cải có ít đường, mỡ động vật, rơm.","(2) Các chất dinh dưỡng giầu protein hoặc muối khoáng được gọi là “các chất để xây dựng cơ thể”. Khác với các chất dinh dưỡng năng lượng ở mục trên, các chất dinh dưỡng này không bị “đốt cháy” trong cơ thể động vật mà tham gia vào việc xây dựng các mô hoặc vào các quá trình khác trong cơ thể vật (sản sinh sữa, trứng...). Chúng chủ yếu bao gồm protein hoặc muối khoáng. Ta có thể kể ví dụ ra đây một số chất giầu protein được sử dụng cho mục đích này là các loại rau đậu, bã của quá trình ủ, khô dầu, các sản phẩm phụ của sữa. Muối khoáng chủ yếu tham gia vào quá trình phát triển xương và đối với gia cầm là quá trình làm vỏ trứng. Loại thông dụng nhất được sử dụng có chứa canxi, phosphor, chlorine, natri, kali, sắt, iốt,...","(3) Các chất dinh dưỡng \"chức năng\". Các loại này là các chất thúc đẩy việc hấp thụ carbohydrate, protein và muối khoáng. Chúng bao gồm vitamin, các nguyên tố vi lượng và kháng sinh. Nếu thiếu hoặc không có các chất dinh dưỡng này sẽ dẫn đến rối loạn về sức khoẻ của động vật. Ba nhóm chất dinh dưỡng này đáp ứng nhu cầu về thực phẩm đầy đủ của động vật. Hỗn hợp và tỉ lệ các chất dinh dưỡng này phụ thuộc vào cách sản xuất sản phẩm cho động vật.","(B) CÁC CHẾ PHẨM SỬ DỤNG ĐỂ BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI BỔ SUNG) Các loại thức ăn được chế biến ở trang trại thường là thấp về protein, muối khoáng hoặc vitamin. Các chế phẩm được dùng để bù vào các phần thiếu hụt trên, để đảm bảo một khẩu phần ăn cho động vật được cân bằng, gồm protein, muối khoáng hoặc vitamin, có thêm các loại thức ăn bổ sung năng lượng (carbohydrate) được coi là chất mang cho các thành phần khác. Tuy rằng, về mặt chất lượng, các chế phẩm này có các thành phần tương tự như các thành phần của các chế phẩm được nêu ở mục (A) trên đây, chúng khác các chế phẩm trên ở chỗ trong thành phần của chúng có chứa hàm lượng tương đối lớn của một loại chất dinh dưỡng cụ thể. Nhóm này bao gồm:","(1) Các sản phẩm hòa tan được chiết xuất từ cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan trong nước như protein, vitamin B, muối,...), và được sản xuất từ dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển.","(2) Các protein cô đặc của lá cây có màu xanh và phần phân đoạn xanh của chất cô đặc protein từ lá cây, thu được từ xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng).","(C) CÁC CHẾ PHẨM SỬ DỤNG TRONG CHẾ BIẾN THỨC ĂN CHĂN NUÔI HOÀN CHỈNH HOẶC THỨC ĂN CHĂN NUÔI BỔ SUNG ĐƯỢC MÔ TẢ Ở MỤC (A) VÀ","(B) Ở TRÊN Các chế phẩm này, được biết đến với tên thư"],"khong_bao_gom":["(a) Viên được sản xuất từ một loại nguyên liệu, hoặc từ hỗn hợp của các nguyên liệu được phân loại vào một nhóm cụ thể, thậm chí được trộn thêm chất kết dính (mật, chất có tinh bột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14, 12.14, 23.01, …).","(b) Các hỗn hợp đơn giản của hạt ngũ cốc (Chương 10), của bột ngũ cốc hoặc của bột rau đậu (Chương 11).","(c) Các chế phẩm có thể được dùng để làm thức ăn chăn nuôi hoặc thức ăn cho người tuỳ theo bản chất, độ tinh khiết và tỉ lệ tương ứng của các thành phần, tuỳ theo điều kiện vệ sinh trong quá trình chế biến và nếu cần, tuỳ theo những chỉ dẫn được ghi trên bao bì hoặc tất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01 và 21.06).","(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08. 214","(e) Vitamin, xác định hoặc không xác định về mặt hóa học hoặc pha trộn hóa học, trong dung môi hoặc không trong dung môi hoặc được làm ổn định bằng việc bổ sung các chất chống oxy hóa hoặc các chất chống vón, hoặc bằng cách hút bám trên một chất nền hoặc bằng cách phủ bảo vệ bằng, ví dụ, galetin, sáp, chất béo,..., với điều kiện số lượng các chất bổ sung, chất nền hoặc chất phủ không vượt quá yêu cầu bảo quản hoặc vận chuyển và với điều kiện các chất bổ sung, chất nền hoặc chất phủ không làm thay đổi đặc tính của vitamin và không biến chúng đặc biệt phục vụ cho một nhu cầu một nhu cầu cụ thể mà không dùng cho việc sử dụng chung (nhóm 29.36).","(f) Các sản phẩm của Chương 29.","(g) Dược phẩm thuộc nhóm 30.03 và 30.04.","(h) Các chất protein thuộc Chương 35.","(ij) Các chế phẩm có bản chất là các chất tẩy uế chống vi trùng được sử dụng trong việc chế biến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm 38.08).","(k) Các sản phẩm trung gian của quá trình sản xuất thuốc kháng sinh thu được bằng việc lọc và chiết xuất lần đầu và phế liệu từ quá trình sản xuất này, với hàm lượng chất kháng sinh thường không quá 70% (nhóm 38.24). 215"],"loai_tru":["mật, chất có tinh\nbột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14","hi trên bao bì hoặc\ntất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01","các nhóm 19.01 và 21.06).\n(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08","phục vụ cho một nhu cầu một nhu cầu cụ thể mà\nkhông dùng cho việc sử dụng chung (nhóm 29.36)","sử dụng chung (nhóm 29.36).\n(f) Các sản phẩm của Chương 29.\n(g) Dược phẩm thuộc nhóm 30.03","chế\nbiến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm\n38.08)","u từ quá trình sản xuất này, với hàm lượng chất kháng sinh\nthường không quá 70% (nhóm 38.24)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chún","các nguyên liệu thực vật","mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bộ","dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển","lá cây","xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng)"],"cau_tao":"dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan tro","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chăn nuôi động vật","gia súc","chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung","BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI B","bù vào các phần thiếu hụt trên"],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M1","co_quan":"BNNPTNT","loai":"kiem_dich_dong_vat","tier":3,"loai_ten":"Kiểm dịch động vật và sản phẩm động vật trên cạn","don_vi":"Cục Thú y"},{"mo_ta":"Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M15","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"RED","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.09","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.09"],"conflict":{"has_conflict":true,"count":1,"items":[{"type":"C2","severity":"MEDIUM","desc":"BNNPTNT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: kiem_dich_dong_vat, thuc_an_chan_nuoi"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"RED"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":true,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230910","ahtn_8so":"23091090","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23099011":{"hs":"23099011","chapter":23,"heading":"2309","subheading":"230990","parent_hs":null,"fact_layer":{"vn":"- - - Loại dùng cho gia cầm","en":null,"dvt":"kg","rates":{"tt":"4.5","mfn":"3","vat":"5/8/10","acfta":"0 (-PH, TH)","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch (01/2024/TT-BNNPTNT M1); Kiểm dịch thực vật (01/2024/TT-BNNPTNT M9); Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN (01/2024/TT-BNNPTNT M15)","canh_bao_cs":true,"muc_canh_bao":"RED","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"(1) để cung cấp cho động vật một khẩu phần ăn trong ngày hợp lý và cân bằng (thức ăn hoàn chỉnh);\n(2) để đạt được một chế độ ăn hàng ngày phù hợp bằng cách bổ sung vào thức ăn cơ bản được sản xuất ở trang trại bằng các chất hữu cơ hoặc vô cơ (thức ăn bổ sung); hoặc\n(3) để sử dụng trong sản xuất các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. Nhóm này bao gồm các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.\n(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn.\n\nTheo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC\n(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:\n\n(1) Các chấ","chu_giai_dong":null,"bao_gom":["các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.","(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn. Theo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC","(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","(1) Các chất dinh dưỡng \"năng lượng\", bao gồm các chất carbohydrate cao (calo cao) như tinh bột, đường, cellulose, và chất béo, được cơ thể động vật “đốt cháy” và chuyển hoá thành năng lượng cần thiết cho sự sống và đạt các mục tiêu của các nhà chăn nuôi. Thí dụ ta có thể kể ra đây một số thức ăn thuộc loại này như ngũ cốc, cải có ít đường, mỡ động vật, rơm.","(2) Các chất dinh dưỡng giầu protein hoặc muối khoáng được gọi là “các chất để xây dựng cơ thể”. Khác với các chất dinh dưỡng năng lượng ở mục trên, các chất dinh dưỡng này không bị “đốt cháy” trong cơ thể động vật mà tham gia vào việc xây dựng các mô hoặc vào các quá trình khác trong cơ thể vật (sản sinh sữa, trứng...). Chúng chủ yếu bao gồm protein hoặc muối khoáng. Ta có thể kể ví dụ ra đây một số chất giầu protein được sử dụng cho mục đích này là các loại rau đậu, bã của quá trình ủ, khô dầu, các sản phẩm phụ của sữa. Muối khoáng chủ yếu tham gia vào quá trình phát triển xương và đối với gia cầm là quá trình làm vỏ trứng. Loại thông dụng nhất được sử dụng có chứa canxi, phosphor, chlorine, natri, kali, sắt, iốt,...","(3) Các chất dinh dưỡng \"chức năng\". Các loại này là các chất thúc đẩy việc hấp thụ carbohydrate, protein và muối khoáng. Chúng bao gồm vitamin, các nguyên tố vi lượng và kháng sinh. Nếu thiếu hoặc không có các chất dinh dưỡng này sẽ dẫn đến rối loạn về sức khoẻ của động vật. Ba nhóm chất dinh dưỡng này đáp ứng nhu cầu về thực phẩm đầy đủ của động vật. Hỗn hợp và tỉ lệ các chất dinh dưỡng này phụ thuộc vào cách sản xuất sản phẩm cho động vật.","(B) CÁC CHẾ PHẨM SỬ DỤNG ĐỂ BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI BỔ SUNG) Các loại thức ăn được chế biến ở trang trại thường là thấp về protein, muối khoáng hoặc vitamin. Các chế phẩm được dùng để bù vào các phần thiếu hụt trên, để đảm bảo một khẩu phần ăn cho động vật được cân bằng, gồm protein, muối khoáng hoặc vitamin, có thêm các loại thức ăn bổ sung năng lượng (carbohydrate) được coi là chất mang cho các thành phần khác. Tuy rằng, về mặt chất lượng, các chế phẩm này có các thành phần tương tự như các thành phần của các chế phẩm được nêu ở mục (A) trên đây, chúng khác các chế phẩm trên ở chỗ trong thành phần của chúng có chứa hàm lượng tương đối lớn của một loại chất dinh dưỡng cụ thể. Nhóm này bao gồm:","(1) Các sản phẩm hòa tan được chiết xuất từ cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan trong nước như protein, vitamin B, muối,...), và được sản xuất từ dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển.","(2) Các protein cô đặc của lá cây có màu xanh và phần phân đoạn xanh của chất cô đặc protein từ lá cây, thu được từ xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng).","(C) CÁC CHẾ PHẨM SỬ DỤNG TRONG CHẾ BIẾN THỨC ĂN CHĂN NUÔI HOÀN CHỈNH HOẶC THỨC ĂN CHĂN NUÔI BỔ SUNG ĐƯỢC MÔ TẢ Ở MỤC (A) VÀ","(B) Ở TRÊN Các chế phẩm này, được biết đến với tên thư"],"khong_bao_gom":["(a) Viên được sản xuất từ một loại nguyên liệu, hoặc từ hỗn hợp của các nguyên liệu được phân loại vào một nhóm cụ thể, thậm chí được trộn thêm chất kết dính (mật, chất có tinh bột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14, 12.14, 23.01, …).","(b) Các hỗn hợp đơn giản của hạt ngũ cốc (Chương 10), của bột ngũ cốc hoặc của bột rau đậu (Chương 11).","(c) Các chế phẩm có thể được dùng để làm thức ăn chăn nuôi hoặc thức ăn cho người tuỳ theo bản chất, độ tinh khiết và tỉ lệ tương ứng của các thành phần, tuỳ theo điều kiện vệ sinh trong quá trình chế biến và nếu cần, tuỳ theo những chỉ dẫn được ghi trên bao bì hoặc tất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01 và 21.06).","(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08. 214","(e) Vitamin, xác định hoặc không xác định về mặt hóa học hoặc pha trộn hóa học, trong dung môi hoặc không trong dung môi hoặc được làm ổn định bằng việc bổ sung các chất chống oxy hóa hoặc các chất chống vón, hoặc bằng cách hút bám trên một chất nền hoặc bằng cách phủ bảo vệ bằng, ví dụ, galetin, sáp, chất béo,..., với điều kiện số lượng các chất bổ sung, chất nền hoặc chất phủ không vượt quá yêu cầu bảo quản hoặc vận chuyển và với điều kiện các chất bổ sung, chất nền hoặc chất phủ không làm thay đổi đặc tính của vitamin và không biến chúng đặc biệt phục vụ cho một nhu cầu một nhu cầu cụ thể mà không dùng cho việc sử dụng chung (nhóm 29.36).","(f) Các sản phẩm của Chương 29.","(g) Dược phẩm thuộc nhóm 30.03 và 30.04.","(h) Các chất protein thuộc Chương 35.","(ij) Các chế phẩm có bản chất là các chất tẩy uế chống vi trùng được sử dụng trong việc chế biến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm 38.08).","(k) Các sản phẩm trung gian của quá trình sản xuất thuốc kháng sinh thu được bằng việc lọc và chiết xuất lần đầu và phế liệu từ quá trình sản xuất này, với hàm lượng chất kháng sinh thường không quá 70% (nhóm 38.24). 215"],"loai_tru":["mật, chất có tinh\nbột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14","hi trên bao bì hoặc\ntất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01","các nhóm 19.01 và 21.06).\n(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08","phục vụ cho một nhu cầu một nhu cầu cụ thể mà\nkhông dùng cho việc sử dụng chung (nhóm 29.36)","sử dụng chung (nhóm 29.36).\n(f) Các sản phẩm của Chương 29.\n(g) Dược phẩm thuộc nhóm 30.03","chế\nbiến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm\n38.08)","u từ quá trình sản xuất này, với hàm lượng chất kháng sinh\nthường không quá 70% (nhóm 38.24)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chún","các nguyên liệu thực vật","mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bộ","dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển","lá cây","xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng)"],"cau_tao":"dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan tro","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chăn nuôi động vật","gia súc","chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung","BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI B","bù vào các phần thiếu hụt trên"],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M1","co_quan":"BNNPTNT","loai":"kiem_dich_dong_vat","tier":3,"loai_ten":"Kiểm dịch động vật và sản phẩm động vật trên cạn","don_vi":"Cục Thú y"},{"mo_ta":"Kiểm dịch thực vật","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M9","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"},{"mo_ta":"Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M15","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"RED","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.09","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.09"],"conflict":{"has_conflict":true,"count":1,"items":[{"type":"C2","severity":"MEDIUM","desc":"BNNPTNT yêu cầu 3 loại kiểm tra khác nhau","detail":"Types: kiem_dich_dong_vat, thuc_an_chan_nuoi, thuc_an_chan_nuoi"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"RED"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230990","ahtn_8so":"23099011","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23099012":{"hs":"23099012","chapter":23,"heading":"2309","subheading":"230990","parent_hs":null,"fact_layer":{"vn":"- - - Loại dùng cho lợn","en":null,"dvt":"kg","rates":{"tt":"4.5","mfn":"3","vat":"5/8/10","acfta":"0 (-PH, TH)","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch (01/2024/TT-BNNPTNT M1); Kiểm dịch thực vật (01/2024/TT-BNNPTNT M9); Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN (01/2024/TT-BNNPTNT M15)","canh_bao_cs":true,"muc_canh_bao":"RED","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"(1) để cung cấp cho động vật một khẩu phần ăn trong ngày hợp lý và cân bằng (thức ăn hoàn chỉnh);\n(2) để đạt được một chế độ ăn hàng ngày phù hợp bằng cách bổ sung vào thức ăn cơ bản được sản xuất ở trang trại bằng các chất hữu cơ hoặc vô cơ (thức ăn bổ sung); hoặc\n(3) để sử dụng trong sản xuất các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. Nhóm này bao gồm các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.\n(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn.\n\nTheo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC\n(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:\n\n(1) Các chấ","chu_giai_dong":null,"bao_gom":["các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.","(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn. Theo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC","(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","(1) Các chất dinh dưỡng \"năng lượng\", bao gồm các chất carbohydrate cao (calo cao) như tinh bột, đường, cellulose, và chất béo, được cơ thể động vật “đốt cháy” và chuyển hoá thành năng lượng cần thiết cho sự sống và đạt các mục tiêu của các nhà chăn nuôi. Thí dụ ta có thể kể ra đây một số thức ăn thuộc loại này như ngũ cốc, cải có ít đường, mỡ động vật, rơm.","(2) Các chất dinh dưỡng giầu protein hoặc muối khoáng được gọi là “các chất để xây dựng cơ thể”. Khác với các chất dinh dưỡng năng lượng ở mục trên, các chất dinh dưỡng này không bị “đốt cháy” trong cơ thể động vật mà tham gia vào việc xây dựng các mô hoặc vào các quá trình khác trong cơ thể vật (sản sinh sữa, trứng...). Chúng chủ yếu bao gồm protein hoặc muối khoáng. Ta có thể kể ví dụ ra đây một số chất giầu protein được sử dụng cho mục đích này là các loại rau đậu, bã của quá trình ủ, khô dầu, các sản phẩm phụ của sữa. Muối khoáng chủ yếu tham gia vào quá trình phát triển xương và đối với gia cầm là quá trình làm vỏ trứng. Loại thông dụng nhất được sử dụng có chứa canxi, phosphor, chlorine, natri, kali, sắt, iốt,...","(3) Các chất dinh dưỡng \"chức năng\". Các loại này là các chất thúc đẩy việc hấp thụ carbohydrate, protein và muối khoáng. Chúng bao gồm vitamin, các nguyên tố vi lượng và kháng sinh. Nếu thiếu hoặc không có các chất dinh dưỡng này sẽ dẫn đến rối loạn về sức khoẻ của động vật. Ba nhóm chất dinh dưỡng này đáp ứng nhu cầu về thực phẩm đầy đủ của động vật. Hỗn hợp và tỉ lệ các chất dinh dưỡng này phụ thuộc vào cách sản xuất sản phẩm cho động vật.","(B) CÁC CHẾ PHẨM SỬ DỤNG ĐỂ BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI BỔ SUNG) Các loại thức ăn được chế biến ở trang trại thường là thấp về protein, muối khoáng hoặc vitamin. Các chế phẩm được dùng để bù vào các phần thiếu hụt trên, để đảm bảo một khẩu phần ăn cho động vật được cân bằng, gồm protein, muối khoáng hoặc vitamin, có thêm các loại thức ăn bổ sung năng lượng (carbohydrate) được coi là chất mang cho các thành phần khác. Tuy rằng, về mặt chất lượng, các chế phẩm này có các thành phần tương tự như các thành phần của các chế phẩm được nêu ở mục (A) trên đây, chúng khác các chế phẩm trên ở chỗ trong thành phần của chúng có chứa hàm lượng tương đối lớn của một loại chất dinh dưỡng cụ thể. Nhóm này bao gồm:","(1) Các sản phẩm hòa tan được chiết xuất từ cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan trong nước như protein, vitamin B, muối,...), và được sản xuất từ dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển.","(2) Các protein cô đặc của lá cây có màu xanh và phần phân đoạn xanh của chất cô đặc protein từ lá cây, thu được từ xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng).","(C) CÁC CHẾ PHẨM SỬ DỤNG TRONG CHẾ BIẾN THỨC ĂN CHĂN NUÔI HOÀN CHỈNH HOẶC THỨC ĂN CHĂN NUÔI BỔ SUNG ĐƯỢC MÔ TẢ Ở MỤC (A) VÀ","(B) Ở TRÊN Các chế phẩm này, được biết đến với tên thư"],"khong_bao_gom":["(a) Viên được sản xuất từ một loại nguyên liệu, hoặc từ hỗn hợp của các nguyên liệu được phân loại vào một nhóm cụ thể, thậm chí được trộn thêm chất kết dính (mật, chất có tinh bột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14, 12.14, 23.01, …).","(b) Các hỗn hợp đơn giản của hạt ngũ cốc (Chương 10), của bột ngũ cốc hoặc của bột rau đậu (Chương 11).","(c) Các chế phẩm có thể được dùng để làm thức ăn chăn nuôi hoặc thức ăn cho người tuỳ theo bản chất, độ tinh khiết và tỉ lệ tương ứng của các thành phần, tuỳ theo điều kiện vệ sinh trong quá trình chế biến và nếu cần, tuỳ theo những chỉ dẫn được ghi trên bao bì hoặc tất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01 và 21.06).","(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08. 214","(e) Vitamin, xác định hoặc không xác định về mặt hóa học hoặc pha trộn hóa học, trong dung môi hoặc không trong dung môi hoặc được làm ổn định bằng việc bổ sung các chất chống oxy hóa hoặc các chất chống vón, hoặc bằng cách hút bám trên một chất nền hoặc bằng cách phủ bảo vệ bằng, ví dụ, galetin, sáp, chất béo,..., với điều kiện số lượng các chất bổ sung, chất nền hoặc chất phủ không vượt quá yêu cầu bảo quản hoặc vận chuyển và với điều kiện các chất bổ sung, chất nền hoặc chất phủ không làm thay đổi đặc tính của vitamin và không biến chúng đặc biệt phục vụ cho một nhu cầu một nhu cầu cụ thể mà không dùng cho việc sử dụng chung (nhóm 29.36).","(f) Các sản phẩm của Chương 29.","(g) Dược phẩm thuộc nhóm 30.03 và 30.04.","(h) Các chất protein thuộc Chương 35.","(ij) Các chế phẩm có bản chất là các chất tẩy uế chống vi trùng được sử dụng trong việc chế biến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm 38.08).","(k) Các sản phẩm trung gian của quá trình sản xuất thuốc kháng sinh thu được bằng việc lọc và chiết xuất lần đầu và phế liệu từ quá trình sản xuất này, với hàm lượng chất kháng sinh thường không quá 70% (nhóm 38.24). 215"],"loai_tru":["mật, chất có tinh\nbột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14","hi trên bao bì hoặc\ntất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01","các nhóm 19.01 và 21.06).\n(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08","phục vụ cho một nhu cầu một nhu cầu cụ thể mà\nkhông dùng cho việc sử dụng chung (nhóm 29.36)","sử dụng chung (nhóm 29.36).\n(f) Các sản phẩm của Chương 29.\n(g) Dược phẩm thuộc nhóm 30.03","chế\nbiến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm\n38.08)","u từ quá trình sản xuất này, với hàm lượng chất kháng sinh\nthường không quá 70% (nhóm 38.24)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chún","các nguyên liệu thực vật","mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bộ","dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển","lá cây","xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng)"],"cau_tao":"dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan tro","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chăn nuôi động vật","gia súc","chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung","BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI B","bù vào các phần thiếu hụt trên"],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M1","co_quan":"BNNPTNT","loai":"kiem_dich_dong_vat","tier":3,"loai_ten":"Kiểm dịch động vật và sản phẩm động vật trên cạn","don_vi":"Cục Thú y"},{"mo_ta":"Kiểm dịch thực vật","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M9","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"},{"mo_ta":"Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M15","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"RED","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.09","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.09"],"conflict":{"has_conflict":true,"count":1,"items":[{"type":"C2","severity":"MEDIUM","desc":"BNNPTNT yêu cầu 3 loại kiểm tra khác nhau","detail":"Types: kiem_dich_dong_vat, thuc_an_chan_nuoi, thuc_an_chan_nuoi"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"RED"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230990","ahtn_8so":"23099012","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23099013":{"hs":"23099013","chapter":23,"heading":"2309","subheading":"230990","parent_hs":null,"fact_layer":{"vn":"- - - Loại dùng cho tôm","en":null,"dvt":"kg","rates":{"tt":"5","mfn":"0","vat":"5/8/10","acfta":"0 (-TH)","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch (01/2024/TT-BNNPTNT M1); Kiểm dịch thực vật (01/2024/TT-BNNPTNT M9); Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN (01/2024/TT-BNNPTNT M15)","canh_bao_cs":true,"muc_canh_bao":"RED","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"(1) để cung cấp cho động vật một khẩu phần ăn trong ngày hợp lý và cân bằng (thức ăn hoàn chỉnh);\n(2) để đạt được một chế độ ăn hàng ngày phù hợp bằng cách bổ sung vào thức ăn cơ bản được sản xuất ở trang trại bằng các chất hữu cơ hoặc vô cơ (thức ăn bổ sung); hoặc\n(3) để sử dụng trong sản xuất các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. Nhóm này bao gồm các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.\n(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn.\n\nTheo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC\n(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:\n\n(1) Các chấ","chu_giai_dong":null,"bao_gom":["các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.","(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn. Theo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC","(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","(1) Các chất dinh dưỡng \"năng lượng\", bao gồm các chất carbohydrate cao (calo cao) như tinh bột, đường, cellulose, và chất béo, được cơ thể động vật “đốt cháy” và chuyển hoá thành năng lượng cần thiết cho sự sống và đạt các mục tiêu của các nhà chăn nuôi. Thí dụ ta có thể kể ra đây một số thức ăn thuộc loại này như ngũ cốc, cải có ít đường, mỡ động vật, rơm.","(2) Các chất dinh dưỡng giầu protein hoặc muối khoáng được gọi là “các chất để xây dựng cơ thể”. Khác với các chất dinh dưỡng năng lượng ở mục trên, các chất dinh dưỡng này không bị “đốt cháy” trong cơ thể động vật mà tham gia vào việc xây dựng các mô hoặc vào các quá trình khác trong cơ thể vật (sản sinh sữa, trứng...). Chúng chủ yếu bao gồm protein hoặc muối khoáng. Ta có thể kể ví dụ ra đây một số chất giầu protein được sử dụng cho mục đích này là các loại rau đậu, bã của quá trình ủ, khô dầu, các sản phẩm phụ của sữa. Muối khoáng chủ yếu tham gia vào quá trình phát triển xương và đối với gia cầm là quá trình làm vỏ trứng. Loại thông dụng nhất được sử dụng có chứa canxi, phosphor, chlorine, natri, kali, sắt, iốt,...","(3) Các chất dinh dưỡng \"chức năng\". Các loại này là các chất thúc đẩy việc hấp thụ carbohydrate, protein và muối khoáng. Chúng bao gồm vitamin, các nguyên tố vi lượng và kháng sinh. Nếu thiếu hoặc không có các chất dinh dưỡng này sẽ dẫn đến rối loạn về sức khoẻ của động vật. Ba nhóm chất dinh dưỡng này đáp ứng nhu cầu về thực phẩm đầy đủ của động vật. Hỗn hợp và tỉ lệ các chất dinh dưỡng này phụ thuộc vào cách sản xuất sản phẩm cho động vật.","(B) CÁC CHẾ PHẨM SỬ DỤNG ĐỂ BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI BỔ SUNG) Các loại thức ăn được chế biến ở trang trại thường là thấp về protein, muối khoáng hoặc vitamin. Các chế phẩm được dùng để bù vào các phần thiếu hụt trên, để đảm bảo một khẩu phần ăn cho động vật được cân bằng, gồm protein, muối khoáng hoặc vitamin, có thêm các loại thức ăn bổ sung năng lượng (carbohydrate) được coi là chất mang cho các thành phần khác. Tuy rằng, về mặt chất lượng, các chế phẩm này có các thành phần tương tự như các thành phần của các chế phẩm được nêu ở mục (A) trên đây, chúng khác các chế phẩm trên ở chỗ trong thành phần của chúng có chứa hàm lượng tương đối lớn của một loại chất dinh dưỡng cụ thể. Nhóm này bao gồm:","(1) Các sản phẩm hòa tan được chiết xuất từ cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan trong nước như protein, vitamin B, muối,...), và được sản xuất từ dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển.","(2) Các protein cô đặc của lá cây có màu xanh và phần phân đoạn xanh của chất cô đặc protein từ lá cây, thu được từ xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng).","(C) CÁC CHẾ PHẨM SỬ DỤNG TRONG CHẾ BIẾN THỨC ĂN CHĂN NUÔI HOÀN CHỈNH HOẶC THỨC ĂN CHĂN NUÔI BỔ SUNG ĐƯỢC MÔ TẢ Ở MỤC (A) VÀ","(B) Ở TRÊN Các chế phẩm này, được biết đến với tên thư"],"khong_bao_gom":["(a) Viên được sản xuất từ một loại nguyên liệu, hoặc từ hỗn hợp của các nguyên liệu được phân loại vào một nhóm cụ thể, thậm chí được trộn thêm chất kết dính (mật, chất có tinh bột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14, 12.14, 23.01, …).","(b) Các hỗn hợp đơn giản của hạt ngũ cốc (Chương 10), của bột ngũ cốc hoặc của bột rau đậu (Chương 11).","(c) Các chế phẩm có thể được dùng để làm thức ăn chăn nuôi hoặc thức ăn cho người tuỳ theo bản chất, độ tinh khiết và tỉ lệ tương ứng của các thành phần, tuỳ theo điều kiện vệ sinh trong quá trình chế biến và nếu cần, tuỳ theo những chỉ dẫn được ghi trên bao bì hoặc tất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01 và 21.06).","(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08. 214","(e) Vitamin, xác định hoặc không xác định về mặt hóa học hoặc pha trộn hóa học, trong dung môi hoặc không trong dung môi hoặc được làm ổn định bằng việc bổ sung các chất chống oxy hóa hoặc các chất chống vón, hoặc bằng cách hút bám trên một chất nền hoặc bằng cách phủ bảo vệ bằng, ví dụ, galetin, sáp, chất béo,..., với điều kiện số lượng các chất bổ sung, chất nền hoặc chất phủ không vượt quá yêu cầu bảo quản hoặc vận chuyển và với điều kiện các chất bổ sung, chất nền hoặc chất phủ không làm thay đổi đặc tính của vitamin và không biến chúng đặc biệt phục vụ cho một nhu cầu một nhu cầu cụ thể mà không dùng cho việc sử dụng chung (nhóm 29.36).","(f) Các sản phẩm của Chương 29.","(g) Dược phẩm thuộc nhóm 30.03 và 30.04.","(h) Các chất protein thuộc Chương 35.","(ij) Các chế phẩm có bản chất là các chất tẩy uế chống vi trùng được sử dụng trong việc chế biến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm 38.08).","(k) Các sản phẩm trung gian của quá trình sản xuất thuốc kháng sinh thu được bằng việc lọc và chiết xuất lần đầu và phế liệu từ quá trình sản xuất này, với hàm lượng chất kháng sinh thường không quá 70% (nhóm 38.24). 215"],"loai_tru":["mật, chất có tinh\nbột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14","hi trên bao bì hoặc\ntất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01","các nhóm 19.01 và 21.06).\n(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08","phục vụ cho một nhu cầu một nhu cầu cụ thể mà\nkhông dùng cho việc sử dụng chung (nhóm 29.36)","sử dụng chung (nhóm 29.36).\n(f) Các sản phẩm của Chương 29.\n(g) Dược phẩm thuộc nhóm 30.03","chế\nbiến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm\n38.08)","u từ quá trình sản xuất này, với hàm lượng chất kháng sinh\nthường không quá 70% (nhóm 38.24)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chún","các nguyên liệu thực vật","mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bộ","dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển","lá cây","xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng)"],"cau_tao":"dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan tro","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chăn nuôi động vật","gia súc","chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung","BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI B","bù vào các phần thiếu hụt trên"],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M1","co_quan":"BNNPTNT","loai":"kiem_dich_dong_vat","tier":3,"loai_ten":"Kiểm dịch động vật và sản phẩm động vật trên cạn","don_vi":"Cục Thú y"},{"mo_ta":"Kiểm dịch thực vật","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M9","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"},{"mo_ta":"Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M15","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"RED","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.09","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.09"],"conflict":{"has_conflict":true,"count":1,"items":[{"type":"C2","severity":"MEDIUM","desc":"BNNPTNT yêu cầu 3 loại kiểm tra khác nhau","detail":"Types: kiem_dich_dong_vat, thuc_an_chan_nuoi, thuc_an_chan_nuoi"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"RED"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230990","ahtn_8so":"23099013","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23099014":{"hs":"23099014","chapter":23,"heading":"2309","subheading":"230990","parent_hs":null,"fact_layer":{"vn":"- - - Loại dùng cho động vật linh trưởng","en":null,"dvt":"kg","rates":{"tt":"4.5","mfn":"3","vat":"5/8/10","acfta":"0 (-PH, TH)","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch (01/2024/TT-BNNPTNT M1); Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN (01/2024/TT-BNNPTNT M15)","canh_bao_cs":true,"muc_canh_bao":"RED","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"(1) để cung cấp cho động vật một khẩu phần ăn trong ngày hợp lý và cân bằng (thức ăn hoàn chỉnh);\n(2) để đạt được một chế độ ăn hàng ngày phù hợp bằng cách bổ sung vào thức ăn cơ bản được sản xuất ở trang trại bằng các chất hữu cơ hoặc vô cơ (thức ăn bổ sung); hoặc\n(3) để sử dụng trong sản xuất các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. Nhóm này bao gồm các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.\n(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn.\n\nTheo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC\n(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:\n\n(1) Các chấ","chu_giai_dong":null,"bao_gom":["các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.","(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn. Theo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC","(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","(1) Các chất dinh dưỡng \"năng lượng\", bao gồm các chất carbohydrate cao (calo cao) như tinh bột, đường, cellulose, và chất béo, được cơ thể động vật “đốt cháy” và chuyển hoá thành năng lượng cần thiết cho sự sống và đạt các mục tiêu của các nhà chăn nuôi. Thí dụ ta có thể kể ra đây một số thức ăn thuộc loại này như ngũ cốc, cải có ít đường, mỡ động vật, rơm.","(2) Các chất dinh dưỡng giầu protein hoặc muối khoáng được gọi là “các chất để xây dựng cơ thể”. Khác với các chất dinh dưỡng năng lượng ở mục trên, các chất dinh dưỡng này không bị “đốt cháy” trong cơ thể động vật mà tham gia vào việc xây dựng các mô hoặc vào các quá trình khác trong cơ thể vật (sản sinh sữa, trứng...). Chúng chủ yếu bao gồm protein hoặc muối khoáng. Ta có thể kể ví dụ ra đây một số chất giầu protein được sử dụng cho mục đích này là các loại rau đậu, bã của quá trình ủ, khô dầu, các sản phẩm phụ của sữa. Muối khoáng chủ yếu tham gia vào quá trình phát triển xương và đối với gia cầm là quá trình làm vỏ trứng. Loại thông dụng nhất được sử dụng có chứa canxi, phosphor, chlorine, natri, kali, sắt, iốt,...","(3) Các chất dinh dưỡng \"chức năng\". Các loại này là các chất thúc đẩy việc hấp thụ carbohydrate, protein và muối khoáng. Chúng bao gồm vitamin, các nguyên tố vi lượng và kháng sinh. Nếu thiếu hoặc không có các chất dinh dưỡng này sẽ dẫn đến rối loạn về sức khoẻ của động vật. Ba nhóm chất dinh dưỡng này đáp ứng nhu cầu về thực phẩm đầy đủ của động vật. Hỗn hợp và tỉ lệ các chất dinh dưỡng này phụ thuộc vào cách sản xuất sản phẩm cho động vật.","(B) CÁC CHẾ PHẨM SỬ DỤNG ĐỂ BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI BỔ SUNG) Các loại thức ăn được chế biến ở trang trại thường là thấp về protein, muối khoáng hoặc vitamin. Các chế phẩm được dùng để bù vào các phần thiếu hụt trên, để đảm bảo một khẩu phần ăn cho động vật được cân bằng, gồm protein, muối khoáng hoặc vitamin, có thêm các loại thức ăn bổ sung năng lượng (carbohydrate) được coi là chất mang cho các thành phần khác. Tuy rằng, về mặt chất lượng, các chế phẩm này có các thành phần tương tự như các thành phần của các chế phẩm được nêu ở mục (A) trên đây, chúng khác các chế phẩm trên ở chỗ trong thành phần của chúng có chứa hàm lượng tương đối lớn của một loại chất dinh dưỡng cụ thể. Nhóm này bao gồm:","(1) Các sản phẩm hòa tan được chiết xuất từ cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan trong nước như protein, vitamin B, muối,...), và được sản xuất từ dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển.","(2) Các protein cô đặc của lá cây có màu xanh và phần phân đoạn xanh của chất cô đặc protein từ lá cây, thu được từ xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng).","(C) CÁC CHẾ PHẨM SỬ DỤNG TRONG CHẾ BIẾN THỨC ĂN CHĂN NUÔI HOÀN CHỈNH HOẶC THỨC ĂN CHĂN NUÔI BỔ SUNG ĐƯỢC MÔ TẢ Ở MỤC (A) VÀ","(B) Ở TRÊN Các chế phẩm này, được biết đến với tên thư"],"khong_bao_gom":["(a) Viên được sản xuất từ một loại nguyên liệu, hoặc từ hỗn hợp của các nguyên liệu được phân loại vào một nhóm cụ thể, thậm chí được trộn thêm chất kết dính (mật, chất có tinh bột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14, 12.14, 23.01, …).","(b) Các hỗn hợp đơn giản của hạt ngũ cốc (Chương 10), của bột ngũ cốc hoặc của bột rau đậu (Chương 11).","(c) Các chế phẩm có thể được dùng để làm thức ăn chăn nuôi hoặc thức ăn cho người tuỳ theo bản chất, độ tinh khiết và tỉ lệ tương ứng của các thành phần, tuỳ theo điều kiện vệ sinh trong quá trình chế biến và nếu cần, tuỳ theo những chỉ dẫn được ghi trên bao bì hoặc tất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01 và 21.06).","(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08. 214","(e) Vitamin, xác định hoặc không xác định về mặt hóa học hoặc pha trộn hóa học, trong dung môi hoặc không trong dung môi hoặc được làm ổn định bằng việc bổ sung các chất chống oxy hóa hoặc các chất chống vón, hoặc bằng cách hút bám trên một chất nền hoặc bằng cách phủ bảo vệ bằng, ví dụ, galetin, sáp, chất béo,..., với điều kiện số lượng các chất bổ sung, chất nền hoặc chất phủ không vượt quá yêu cầu bảo quản hoặc vận chuyển và với điều kiện các chất bổ sung, chất nền hoặc chất phủ không làm thay đổi đặc tính của vitamin và không biến chúng đặc biệt phục vụ cho một nhu cầu một nhu cầu cụ thể mà không dùng cho việc sử dụng chung (nhóm 29.36).","(f) Các sản phẩm của Chương 29.","(g) Dược phẩm thuộc nhóm 30.03 và 30.04.","(h) Các chất protein thuộc Chương 35.","(ij) Các chế phẩm có bản chất là các chất tẩy uế chống vi trùng được sử dụng trong việc chế biến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm 38.08).","(k) Các sản phẩm trung gian của quá trình sản xuất thuốc kháng sinh thu được bằng việc lọc và chiết xuất lần đầu và phế liệu từ quá trình sản xuất này, với hàm lượng chất kháng sinh thường không quá 70% (nhóm 38.24). 215"],"loai_tru":["mật, chất có tinh\nbột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14","hi trên bao bì hoặc\ntất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01","các nhóm 19.01 và 21.06).\n(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08","phục vụ cho một nhu cầu một nhu cầu cụ thể mà\nkhông dùng cho việc sử dụng chung (nhóm 29.36)","sử dụng chung (nhóm 29.36).\n(f) Các sản phẩm của Chương 29.\n(g) Dược phẩm thuộc nhóm 30.03","chế\nbiến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm\n38.08)","u từ quá trình sản xuất này, với hàm lượng chất kháng sinh\nthường không quá 70% (nhóm 38.24)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chún","các nguyên liệu thực vật","mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bộ","dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển","lá cây","xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng)"],"cau_tao":"dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan tro","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chăn nuôi động vật","gia súc","chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung","BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI B","bù vào các phần thiếu hụt trên"],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M1","co_quan":"BNNPTNT","loai":"kiem_dich_dong_vat","tier":3,"loai_ten":"Kiểm dịch động vật và sản phẩm động vật trên cạn","don_vi":"Cục Thú y"},{"mo_ta":"Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M15","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"RED","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.09","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.09"],"conflict":{"has_conflict":true,"count":1,"items":[{"type":"C2","severity":"MEDIUM","desc":"BNNPTNT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: kiem_dich_dong_vat, thuc_an_chan_nuoi"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"RED"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230990","ahtn_8so":"23099014","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23099019":{"hs":"23099019","chapter":23,"heading":"2309","subheading":"230990","parent_hs":null,"fact_layer":{"vn":"- - - Loại khác","en":null,"dvt":"kg","rates":{"tt":"4.5","mfn":"3","vat":"5/8/10","acfta":"0 (-PH, TH)","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch (01/2024/TT-BNNPTNT M1); Kiểm dịch thực vật (01/2024/TT-BNNPTNT M9); Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN (01/2024/TT-BNNPTNT M15)","canh_bao_cs":true,"muc_canh_bao":"RED","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"(1) để cung cấp cho động vật một khẩu phần ăn trong ngày hợp lý và cân bằng (thức ăn hoàn chỉnh);\n(2) để đạt được một chế độ ăn hàng ngày phù hợp bằng cách bổ sung vào thức ăn cơ bản được sản xuất ở trang trại bằng các chất hữu cơ hoặc vô cơ (thức ăn bổ sung); hoặc\n(3) để sử dụng trong sản xuất các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. Nhóm này bao gồm các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.\n(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn.\n\nTheo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC\n(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:\n\n(1) Các chấ","chu_giai_dong":null,"bao_gom":["các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.","(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn. Theo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC","(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","(1) Các chất dinh dưỡng \"năng lượng\", bao gồm các chất carbohydrate cao (calo cao) như tinh bột, đường, cellulose, và chất béo, được cơ thể động vật “đốt cháy” và chuyển hoá thành năng lượng cần thiết cho sự sống và đạt các mục tiêu của các nhà chăn nuôi. Thí dụ ta có thể kể ra đây một số thức ăn thuộc loại này như ngũ cốc, cải có ít đường, mỡ động vật, rơm.","(2) Các chất dinh dưỡng giầu protein hoặc muối khoáng được gọi là “các chất để xây dựng cơ thể”. Khác với các chất dinh dưỡng năng lượng ở mục trên, các chất dinh dưỡng này không bị “đốt cháy” trong cơ thể động vật mà tham gia vào việc xây dựng các mô hoặc vào các quá trình khác trong cơ thể vật (sản sinh sữa, trứng...). Chúng chủ yếu bao gồm protein hoặc muối khoáng. Ta có thể kể ví dụ ra đây một số chất giầu protein được sử dụng cho mục đích này là các loại rau đậu, bã của quá trình ủ, khô dầu, các sản phẩm phụ của sữa. Muối khoáng chủ yếu tham gia vào quá trình phát triển xương và đối với gia cầm là quá trình làm vỏ trứng. Loại thông dụng nhất được sử dụng có chứa canxi, phosphor, chlorine, natri, kali, sắt, iốt,...","(3) Các chất dinh dưỡng \"chức năng\". Các loại này là các chất thúc đẩy việc hấp thụ carbohydrate, protein và muối khoáng. Chúng bao gồm vitamin, các nguyên tố vi lượng và kháng sinh. Nếu thiếu hoặc không có các chất dinh dưỡng này sẽ dẫn đến rối loạn về sức khoẻ của động vật. Ba nhóm chất dinh dưỡng này đáp ứng nhu cầu về thực phẩm đầy đủ của động vật. Hỗn hợp và tỉ lệ các chất dinh dưỡng này phụ thuộc vào cách sản xuất sản phẩm cho động vật.","(B) CÁC CHẾ PHẨM SỬ DỤNG ĐỂ BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI BỔ SUNG) Các loại thức ăn được chế biến ở trang trại thường là thấp về protein, muối khoáng hoặc vitamin. Các chế phẩm được dùng để bù vào các phần thiếu hụt trên, để đảm bảo một khẩu phần ăn cho động vật được cân bằng, gồm protein, muối khoáng hoặc vitamin, có thêm các loại thức ăn bổ sung năng lượng (carbohydrate) được coi là chất mang cho các thành phần khác. Tuy rằng, về mặt chất lượng, các chế phẩm này có các thành phần tương tự như các thành phần của các chế phẩm được nêu ở mục (A) trên đây, chúng khác các chế phẩm trên ở chỗ trong thành phần của chúng có chứa hàm lượng tương đối lớn của một loại chất dinh dưỡng cụ thể. Nhóm này bao gồm:","(1) Các sản phẩm hòa tan được chiết xuất từ cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan trong nước như protein, vitamin B, muối,...), và được sản xuất từ dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển.","(2) Các protein cô đặc của lá cây có màu xanh và phần phân đoạn xanh của chất cô đặc protein từ lá cây, thu được từ xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng).","(C) CÁC CHẾ PHẨM SỬ DỤNG TRONG CHẾ BIẾN THỨC ĂN CHĂN NUÔI HOÀN CHỈNH HOẶC THỨC ĂN CHĂN NUÔI BỔ SUNG ĐƯỢC MÔ TẢ Ở MỤC (A) VÀ","(B) Ở TRÊN Các chế phẩm này, được biết đến với tên thư"],"khong_bao_gom":["(a) Viên được sản xuất từ một loại nguyên liệu, hoặc từ hỗn hợp của các nguyên liệu được phân loại vào một nhóm cụ thể, thậm chí được trộn thêm chất kết dính (mật, chất có tinh bột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14, 12.14, 23.01, …).","(b) Các hỗn hợp đơn giản của hạt ngũ cốc (Chương 10), của bột ngũ cốc hoặc của bột rau đậu (Chương 11).","(c) Các chế phẩm có thể được dùng để làm thức ăn chăn nuôi hoặc thức ăn cho người tuỳ theo bản chất, độ tinh khiết và tỉ lệ tương ứng của các thành phần, tuỳ theo điều kiện vệ sinh trong quá trình chế biến và nếu cần, tuỳ theo những chỉ dẫn được ghi trên bao bì hoặc tất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01 và 21.06).","(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08. 214","(e) Vitamin, xác định hoặc không xác định về mặt hóa học hoặc pha trộn hóa học, trong dung môi hoặc không trong dung môi hoặc được làm ổn định bằng việc bổ sung các chất chống oxy hóa hoặc các chất chống vón, hoặc bằng cách hút bám trên một chất nền hoặc bằng cách phủ bảo vệ bằng, ví dụ, galetin, sáp, chất béo,..., với điều kiện số lượng các chất bổ sung, chất nền hoặc chất phủ không vượt quá yêu cầu bảo quản hoặc vận chuyển và với điều kiện các chất bổ sung, chất nền hoặc chất phủ không làm thay đổi đặc tính của vitamin và không biến chúng đặc biệt phục vụ cho một nhu cầu một nhu cầu cụ thể mà không dùng cho việc sử dụng chung (nhóm 29.36).","(f) Các sản phẩm của Chương 29.","(g) Dược phẩm thuộc nhóm 30.03 và 30.04.","(h) Các chất protein thuộc Chương 35.","(ij) Các chế phẩm có bản chất là các chất tẩy uế chống vi trùng được sử dụng trong việc chế biến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm 38.08).","(k) Các sản phẩm trung gian của quá trình sản xuất thuốc kháng sinh thu được bằng việc lọc và chiết xuất lần đầu và phế liệu từ quá trình sản xuất này, với hàm lượng chất kháng sinh thường không quá 70% (nhóm 38.24). 215"],"loai_tru":["mật, chất có tinh\nbột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14","hi trên bao bì hoặc\ntất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01","các nhóm 19.01 và 21.06).\n(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08","phục vụ cho một nhu cầu một nhu cầu cụ thể mà\nkhông dùng cho việc sử dụng chung (nhóm 29.36)","sử dụng chung (nhóm 29.36).\n(f) Các sản phẩm của Chương 29.\n(g) Dược phẩm thuộc nhóm 30.03","chế\nbiến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm\n38.08)","u từ quá trình sản xuất này, với hàm lượng chất kháng sinh\nthường không quá 70% (nhóm 38.24)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chún","các nguyên liệu thực vật","mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bộ","dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển","lá cây","xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng)"],"cau_tao":"dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan tro","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chăn nuôi động vật","gia súc","chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung","BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI B","bù vào các phần thiếu hụt trên"],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M1","co_quan":"BNNPTNT","loai":"kiem_dich_dong_vat","tier":3,"loai_ten":"Kiểm dịch động vật và sản phẩm động vật trên cạn","don_vi":"Cục Thú y"},{"mo_ta":"Kiểm dịch thực vật","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M9","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"},{"mo_ta":"Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M15","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"RED","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.09","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.09"],"case_history":[{"so_hieu":"3218/TB-TCHQ","ngay":"23/06/2023","hang_hoa":"Thiết bị cung cấp nguồn cho máy chủ Thiết bị chuyển\r\n    đổi từ điện xoay chiều sang điện một chiều, hoặc từ điện một chiều điện áp\r\n    cao sang điện","noi_dung":"","co_tranh_chap":true,"ma_hs_ban_dau":null,"url":"https://thuvienphapluat.vn/van-ban/Xuat-nhap-khau/Thong-bao-3218-TB-TCHQ-2023-ket-qua-xac-dinh-truoc-ma-so-Thiet-bi-cung-cap-nguon-cho-may-chu-570757.aspx","vector_matched":true,"match_confidence":0.7765,"match_type":"suggested"}],"conflict":{"has_conflict":true,"count":1,"items":[{"type":"C2","severity":"MEDIUM","desc":"BNNPTNT yêu cầu 3 loại kiểm tra khác nhau","detail":"Types: kiem_dich_dong_vat, thuc_an_chan_nuoi, thuc_an_chan_nuoi"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"RED"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":true,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230990","ahtn_8so":"23099019","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23099020":{"hs":"23099020","chapter":23,"heading":"2309","subheading":"230990","parent_hs":null,"fact_layer":{"vn":"- - Chất tổng hợp, chất bổ sung thức ăn hoặc phụ gia thức ăn","en":null,"dvt":"kg","rates":{"tt":"5","mfn":"0","vat":"5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch (01/2024/TT-BNNPTNT M1); Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN (01/2024/TT-BNNPTNT M15)","canh_bao_cs":true,"muc_canh_bao":"RED","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"(1) để cung cấp cho động vật một khẩu phần ăn trong ngày hợp lý và cân bằng (thức ăn hoàn chỉnh);\n(2) để đạt được một chế độ ăn hàng ngày phù hợp bằng cách bổ sung vào thức ăn cơ bản được sản xuất ở trang trại bằng các chất hữu cơ hoặc vô cơ (thức ăn bổ sung); hoặc\n(3) để sử dụng trong sản xuất các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. Nhóm này bao gồm các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.\n(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn.\n\nTheo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC\n(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:\n\n(1) Các chấ","chu_giai_dong":null,"bao_gom":["các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.","(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn. Theo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC","(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","(1) Các chất dinh dưỡng \"năng lượng\", bao gồm các chất carbohydrate cao (calo cao) như tinh bột, đường, cellulose, và chất béo, được cơ thể động vật “đốt cháy” và chuyển hoá thành năng lượng cần thiết cho sự sống và đạt các mục tiêu của các nhà chăn nuôi. Thí dụ ta có thể kể ra đây một số thức ăn thuộc loại này như ngũ cốc, cải có ít đường, mỡ động vật, rơm.","(2) Các chất dinh dưỡng giầu protein hoặc muối khoáng được gọi là “các chất để xây dựng cơ thể”. Khác với các chất dinh dưỡng năng lượng ở mục trên, các chất dinh dưỡng này không bị “đốt cháy” trong cơ thể động vật mà tham gia vào việc xây dựng các mô hoặc vào các quá trình khác trong cơ thể vật (sản sinh sữa, trứng...). Chúng chủ yếu bao gồm protein hoặc muối khoáng. Ta có thể kể ví dụ ra đây một số chất giầu protein được sử dụng cho mục đích này là các loại rau đậu, bã của quá trình ủ, khô dầu, các sản phẩm phụ của sữa. Muối khoáng chủ yếu tham gia vào quá trình phát triển xương và đối với gia cầm là quá trình làm vỏ trứng. Loại thông dụng nhất được sử dụng có chứa canxi, phosphor, chlorine, natri, kali, sắt, iốt,...","(3) Các chất dinh dưỡng \"chức năng\". Các loại này là các chất thúc đẩy việc hấp thụ carbohydrate, protein và muối khoáng. Chúng bao gồm vitamin, các nguyên tố vi lượng và kháng sinh. Nếu thiếu hoặc không có các chất dinh dưỡng này sẽ dẫn đến rối loạn về sức khoẻ của động vật. Ba nhóm chất dinh dưỡng này đáp ứng nhu cầu về thực phẩm đầy đủ của động vật. Hỗn hợp và tỉ lệ các chất dinh dưỡng này phụ thuộc vào cách sản xuất sản phẩm cho động vật.","(B) CÁC CHẾ PHẨM SỬ DỤNG ĐỂ BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI BỔ SUNG) Các loại thức ăn được chế biến ở trang trại thường là thấp về protein, muối khoáng hoặc vitamin. Các chế phẩm được dùng để bù vào các phần thiếu hụt trên, để đảm bảo một khẩu phần ăn cho động vật được cân bằng, gồm protein, muối khoáng hoặc vitamin, có thêm các loại thức ăn bổ sung năng lượng (carbohydrate) được coi là chất mang cho các thành phần khác. Tuy rằng, về mặt chất lượng, các chế phẩm này có các thành phần tương tự như các thành phần của các chế phẩm được nêu ở mục (A) trên đây, chúng khác các chế phẩm trên ở chỗ trong thành phần của chúng có chứa hàm lượng tương đối lớn của một loại chất dinh dưỡng cụ thể. Nhóm này bao gồm:","(1) Các sản phẩm hòa tan được chiết xuất từ cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan trong nước như protein, vitamin B, muối,...), và được sản xuất từ dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển.","(2) Các protein cô đặc của lá cây có màu xanh và phần phân đoạn xanh của chất cô đặc protein từ lá cây, thu được từ xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng).","(C) CÁC CHẾ PHẨM SỬ DỤNG TRONG CHẾ BIẾN THỨC ĂN CHĂN NUÔI HOÀN CHỈNH HOẶC THỨC ĂN CHĂN NUÔI BỔ SUNG ĐƯỢC MÔ TẢ Ở MỤC (A) VÀ","(B) Ở TRÊN Các chế phẩm này, được biết đến với tên thư"],"khong_bao_gom":["(a) Viên được sản xuất từ một loại nguyên liệu, hoặc từ hỗn hợp của các nguyên liệu được phân loại vào một nhóm cụ thể, thậm chí được trộn thêm chất kết dính (mật, chất có tinh bột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14, 12.14, 23.01, …).","(b) Các hỗn hợp đơn giản của hạt ngũ cốc (Chương 10), của bột ngũ cốc hoặc của bột rau đậu (Chương 11).","(c) Các chế phẩm có thể được dùng để làm thức ăn chăn nuôi hoặc thức ăn cho người tuỳ theo bản chất, độ tinh khiết và tỉ lệ tương ứng của các thành phần, tuỳ theo điều kiện vệ sinh trong quá trình chế biến và nếu cần, tuỳ theo những chỉ dẫn được ghi trên bao bì hoặc tất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01 và 21.06).","(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08. 214","(e) Vitamin, xác định hoặc không xác định về mặt hóa học hoặc pha trộn hóa học, trong dung môi hoặc không trong dung môi hoặc được làm ổn định bằng việc bổ sung các chất chống oxy hóa hoặc các chất chống vón, hoặc bằng cách hút bám trên một chất nền hoặc bằng cách phủ bảo vệ bằng, ví dụ, galetin, sáp, chất béo,..., với điều kiện số lượng các chất bổ sung, chất nền hoặc chất phủ không vượt quá yêu cầu bảo quản hoặc vận chuyển và với điều kiện các chất bổ sung, chất nền hoặc chất phủ không làm thay đổi đặc tính của vitamin và không biến chúng đặc biệt phục vụ cho một nhu cầu một nhu cầu cụ thể mà không dùng cho việc sử dụng chung (nhóm 29.36).","(f) Các sản phẩm của Chương 29.","(g) Dược phẩm thuộc nhóm 30.03 và 30.04.","(h) Các chất protein thuộc Chương 35.","(ij) Các chế phẩm có bản chất là các chất tẩy uế chống vi trùng được sử dụng trong việc chế biến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm 38.08).","(k) Các sản phẩm trung gian của quá trình sản xuất thuốc kháng sinh thu được bằng việc lọc và chiết xuất lần đầu và phế liệu từ quá trình sản xuất này, với hàm lượng chất kháng sinh thường không quá 70% (nhóm 38.24). 215"],"loai_tru":["mật, chất có tinh\nbột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14","hi trên bao bì hoặc\ntất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01","các nhóm 19.01 và 21.06).\n(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08","phục vụ cho một nhu cầu một nhu cầu cụ thể mà\nkhông dùng cho việc sử dụng chung (nhóm 29.36)","sử dụng chung (nhóm 29.36).\n(f) Các sản phẩm của Chương 29.\n(g) Dược phẩm thuộc nhóm 30.03","chế\nbiến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm\n38.08)","u từ quá trình sản xuất này, với hàm lượng chất kháng sinh\nthường không quá 70% (nhóm 38.24)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chún","các nguyên liệu thực vật","mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bộ","dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển","lá cây","xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng)"],"cau_tao":"dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan tro","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chăn nuôi động vật","gia súc","chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung","BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI B","bù vào các phần thiếu hụt trên"],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M1","co_quan":"BNNPTNT","loai":"kiem_dich_dong_vat","tier":3,"loai_ten":"Kiểm dịch động vật và sản phẩm động vật trên cạn","don_vi":"Cục Thú y"},{"mo_ta":"Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M15","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"RED","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.09","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.09"],"case_history":[{"so_hieu":"87\n/TB-TCHQ","ngay":"23/04/2020","hang_hoa":"theo khai báo:","noi_dung":"Tình trạng hiệu lực:\nĐã biết\nHiệu lực: Đã biết\nTình trạng hiệu lực: Đã biết\nBỘ TÀI CHÍNH\nTỔNG CỤC HẢI QUAN\n-------\nCỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM\nĐộc lập - Tự do - Hạnh phúc\n---------------\nSố: 25\n87\n/TB-TCHQ\nHà Nội, ngày\n23\ntháng\n4\nnăm\n2020\nTHÔNG BÁO\nVề kết quả phân loại đối với hàng hóa xuất k","co_tranh_chap":false,"ma_hs_ban_dau":"","url":"https://luatvietnam.vn/xuat-nhap-khau/thong-bao-2587-tb-tchq-2020-phan-loai-nguyen-lieu-san-xuat-thuc-an-chan-nuoi-294771-d6.html"},{"so_hieu":"3978/TB-TCHQ","ngay":"17/06/2019","hang_hoa":"theo khai báo:","noi_dung":"Tình trạng hiệu lực:\nĐã biết\nHiệu lực: Đã biết\nTình trạng hiệu lực: Đã biết\nBỘ TÀI CHÍNH\nTỔNG CỤC HẢI QUAN\n-------\nCỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM\nĐộc lập - Tự do - Hạnh phúc\n---------------\nSố: 3978/TB-TCHQ\nHà Nội, ngày 17 tháng 6 năm 2019\nTHÔNG BÁO\nVề kết quả phân loại đối với hàng hóa xuất khẩ","co_tranh_chap":false,"ma_hs_ban_dau":"","url":"https://luatvietnam.vn/xuat-nhap-khau/thong-bao-3978-tb-tchq-2019-phan-loai-hang-hoa-vitamin-b12-feed-additive-296982-d6.html"},{"so_hieu":"218/TB-TCHQ","ngay":"09/01/2019","hang_hoa":"theo khai báo:","noi_dung":"Tình trạng hiệu lực:\nĐã biết\nHiệu lực: Đã biết\nTình trạng hiệu lực: Đã biết\nBỘ TÀI CHÍNH\nTỔNG CỤC HẢI QUAN\n-------\nCỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM\nĐộc lập - Tự do - Hạnh phúc\n---------------\nSố: 218/TB-TCHQ\nHà Nội, ngày 09 tháng 01 năm 2019\nTHÔNG BÁO\nVề kết quả phân loại đối với hàng hóa xuất khẩ","co_tranh_chap":false,"ma_hs_ban_dau":"","url":"https://luatvietnam.vn/xuat-nhap-khau/thong-bao-218-tb-tchq-tong-cuc-hai-quan-298115-d6.html"}],"conflict":{"has_conflict":true,"count":1,"items":[{"type":"C2","severity":"MEDIUM","desc":"BNNPTNT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: kiem_dich_dong_vat, thuc_an_chan_nuoi"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"RED"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230990","ahtn_8so":"23099020","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"23099090":{"hs":"23099090","chapter":23,"heading":"2309","subheading":"230990","parent_hs":null,"fact_layer":{"vn":"- - Loại khác","en":null,"dvt":"kg","rates":{"tt":"5","mfn":"0","vat":"5/8/10","acfta":"0 (-TH)","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch (01/2024/TT-BNNPTNT M1); Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN (01/2024/TT-BNNPTNT M15)","canh_bao_cs":true,"muc_canh_bao":"RED","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Nhóm 23.09 kể cả các sản phẩm dùng trong chăn nuôi động vật, chưa được ghi hoặc\nchi tiết ở nơi khác, thu được từ quá trình chế biến nguyên liệu gốc thực vật hoặc động\nvật đến mức các nguyên liệu đó mất hết tính chất cơ bản của nguyên liệu ban đầu, trừ\ncác phế liệu thực vật, phế thải thực vật và các sản phẩm phụ từ quá trình chế biến đó\nChú giải phân nhóm.\n1.- Theo mục đích của phân nhóm 2306.41, khái niệm “hạt cải dầu (rape seeds\nhoặc colza seeds) có hàm lượng axit eruxic thấp” có nghĩa là các loại hạt đã\nđược định nghĩa trong Chú giải Phân nhóm 1 của Chương 12.","chu_giai_phan":"VÀ GIẤM; THUỐC LÁ VÀ CÁC LOẠI NGUYÊN LIỆU THAY\nTHẾ THUỐC LÁ ĐÃ CHẾ BIẾN\nChú giải.\n1. Trong Phần này khái niệm \"viên\" chỉ các sản phẩm được liên kết bằng phương pháp ép trực\ntiếp hay bằng cách pha thêm chất kết dính theo tỷ lệ không quá 3% tính theo trọng lượng.\n146","chu_giai_nhom":"(1) để cung cấp cho động vật một khẩu phần ăn trong ngày hợp lý và cân bằng (thức ăn hoàn chỉnh);\n(2) để đạt được một chế độ ăn hàng ngày phù hợp bằng cách bổ sung vào thức ăn cơ bản được sản xuất ở trang trại bằng các chất hữu cơ hoặc vô cơ (thức ăn bổ sung); hoặc\n(3) để sử dụng trong sản xuất các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. Nhóm này bao gồm các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.\n(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn.\n\nTheo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC\n(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:\n\n(1) Các chấ","chu_giai_dong":null,"bao_gom":["các sản phẩm dùng trong chăn nuôi động vật, thu được từ quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chúng mất đi các đặc trưng cơ bản của các nguyên liệu ban đầu, ví dụ, trong trường hợp các sản phẩm thu được từ các nguyên liệu thực vật, các sản phẩm này đã được xử lý đến mức mà cấu trúc tế bào đặc trưng của nguyên liệu thực vật ban đầu không còn được nhận ra dưới kính hiển vi.","(I) THỨC ĂN GIA SÚC ĐÃ ĐƯỢC LÀM NGỌT Thức ăn gia súc đã được làm ngọt là một hỗn hợp của mật hoặc các chất làm ngọt tương tự khác (thường trên 10% tính theo trọng lượng) với ít nhất là một chất dinh dưỡng khác. Thức ăn này chủ yếu được dùng cho gia súc, cừu, ngựa hoặc lợn. Bên cạnh các chất có giá trị dinh dưỡng cao, mật làm tăng vị ngon của thực phẩm và vì vậy mở rộng việc sử dụng các sản phẩm có giá trị dinh dưỡng thấp như rơm, vỏ hay trấu ngũ cốc, vẩy hạt lanh và bã quả đã ép nước mà động vật không thích ăn. Theo đó, các chế phẩm được làm ngọt này thường được dùng trực tiếp làm thức ăn cho động vật. Tuy nhiên, một số trong các chế phẩm này là sự kết hợp của mật với các loại thức ăn có giá trị dinh dưỡng cao như cám lúa mì, khô dầu hạt cọ hoặc khô dầu dừa, và được dùng để chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung. (II) CÁC CHẾ PHẨM KHÁC","(A) CÁC CHẾ PHẨM ĐƯỢC SẢN XUẤT ĐỂ CUNG CẤP CHO ĐỘNG VẬT TOÀN BỘ CÁC YẾU TỐ DINH DƯỠNG CẦN THIẾT ĐỂ BẢO ĐẢM MỘT KHẨU PHẦN ĂN HÀNG NGÀY HỢP LÝ VÀ CÂN ĐỐI (THỨC ĂN CHĂN NUÔI HOÀN CHỈNH) Đặc trưng của các chế phẩm này là chúng có chứa các sản phẩm từ mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","(1) Các chất dinh dưỡng \"năng lượng\", bao gồm các chất carbohydrate cao (calo cao) như tinh bột, đường, cellulose, và chất béo, được cơ thể động vật “đốt cháy” và chuyển hoá thành năng lượng cần thiết cho sự sống và đạt các mục tiêu của các nhà chăn nuôi. Thí dụ ta có thể kể ra đây một số thức ăn thuộc loại này như ngũ cốc, cải có ít đường, mỡ động vật, rơm.","(2) Các chất dinh dưỡng giầu protein hoặc muối khoáng được gọi là “các chất để xây dựng cơ thể”. Khác với các chất dinh dưỡng năng lượng ở mục trên, các chất dinh dưỡng này không bị “đốt cháy” trong cơ thể động vật mà tham gia vào việc xây dựng các mô hoặc vào các quá trình khác trong cơ thể vật (sản sinh sữa, trứng...). Chúng chủ yếu bao gồm protein hoặc muối khoáng. Ta có thể kể ví dụ ra đây một số chất giầu protein được sử dụng cho mục đích này là các loại rau đậu, bã của quá trình ủ, khô dầu, các sản phẩm phụ của sữa. Muối khoáng chủ yếu tham gia vào quá trình phát triển xương và đối với gia cầm là quá trình làm vỏ trứng. Loại thông dụng nhất được sử dụng có chứa canxi, phosphor, chlorine, natri, kali, sắt, iốt,...","(3) Các chất dinh dưỡng \"chức năng\". Các loại này là các chất thúc đẩy việc hấp thụ carbohydrate, protein và muối khoáng. Chúng bao gồm vitamin, các nguyên tố vi lượng và kháng sinh. Nếu thiếu hoặc không có các chất dinh dưỡng này sẽ dẫn đến rối loạn về sức khoẻ của động vật. Ba nhóm chất dinh dưỡng này đáp ứng nhu cầu về thực phẩm đầy đủ của động vật. Hỗn hợp và tỉ lệ các chất dinh dưỡng này phụ thuộc vào cách sản xuất sản phẩm cho động vật.","(B) CÁC CHẾ PHẨM SỬ DỤNG ĐỂ BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI BỔ SUNG) Các loại thức ăn được chế biến ở trang trại thường là thấp về protein, muối khoáng hoặc vitamin. Các chế phẩm được dùng để bù vào các phần thiếu hụt trên, để đảm bảo một khẩu phần ăn cho động vật được cân bằng, gồm protein, muối khoáng hoặc vitamin, có thêm các loại thức ăn bổ sung năng lượng (carbohydrate) được coi là chất mang cho các thành phần khác. Tuy rằng, về mặt chất lượng, các chế phẩm này có các thành phần tương tự như các thành phần của các chế phẩm được nêu ở mục (A) trên đây, chúng khác các chế phẩm trên ở chỗ trong thành phần của chúng có chứa hàm lượng tương đối lớn của một loại chất dinh dưỡng cụ thể. Nhóm này bao gồm:","(1) Các sản phẩm hòa tan được chiết xuất từ cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan trong nước như protein, vitamin B, muối,...), và được sản xuất từ dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển.","(2) Các protein cô đặc của lá cây có màu xanh và phần phân đoạn xanh của chất cô đặc protein từ lá cây, thu được từ xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng).","(C) CÁC CHẾ PHẨM SỬ DỤNG TRONG CHẾ BIẾN THỨC ĂN CHĂN NUÔI HOÀN CHỈNH HOẶC THỨC ĂN CHĂN NUÔI BỔ SUNG ĐƯỢC MÔ TẢ Ở MỤC (A) VÀ","(B) Ở TRÊN Các chế phẩm này, được biết đến với tên thư"],"khong_bao_gom":["(a) Viên được sản xuất từ một loại nguyên liệu, hoặc từ hỗn hợp của các nguyên liệu được phân loại vào một nhóm cụ thể, thậm chí được trộn thêm chất kết dính (mật, chất có tinh bột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14, 12.14, 23.01, …).","(b) Các hỗn hợp đơn giản của hạt ngũ cốc (Chương 10), của bột ngũ cốc hoặc của bột rau đậu (Chương 11).","(c) Các chế phẩm có thể được dùng để làm thức ăn chăn nuôi hoặc thức ăn cho người tuỳ theo bản chất, độ tinh khiết và tỉ lệ tương ứng của các thành phần, tuỳ theo điều kiện vệ sinh trong quá trình chế biến và nếu cần, tuỳ theo những chỉ dẫn được ghi trên bao bì hoặc tất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01 và 21.06).","(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08. 214","(e) Vitamin, xác định hoặc không xác định về mặt hóa học hoặc pha trộn hóa học, trong dung môi hoặc không trong dung môi hoặc được làm ổn định bằng việc bổ sung các chất chống oxy hóa hoặc các chất chống vón, hoặc bằng cách hút bám trên một chất nền hoặc bằng cách phủ bảo vệ bằng, ví dụ, galetin, sáp, chất béo,..., với điều kiện số lượng các chất bổ sung, chất nền hoặc chất phủ không vượt quá yêu cầu bảo quản hoặc vận chuyển và với điều kiện các chất bổ sung, chất nền hoặc chất phủ không làm thay đổi đặc tính của vitamin và không biến chúng đặc biệt phục vụ cho một nhu cầu một nhu cầu cụ thể mà không dùng cho việc sử dụng chung (nhóm 29.36).","(f) Các sản phẩm của Chương 29.","(g) Dược phẩm thuộc nhóm 30.03 và 30.04.","(h) Các chất protein thuộc Chương 35.","(ij) Các chế phẩm có bản chất là các chất tẩy uế chống vi trùng được sử dụng trong việc chế biến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm 38.08).","(k) Các sản phẩm trung gian của quá trình sản xuất thuốc kháng sinh thu được bằng việc lọc và chiết xuất lần đầu và phế liệu từ quá trình sản xuất này, với hàm lượng chất kháng sinh thường không quá 70% (nhóm 38.24). 215"],"loai_tru":["mật, chất có tinh\nbột,...) với hàm lượng không quá 3% tính theo trọng lượng (các nhóm 07.14","hi trên bao bì hoặc\ntất cả các hướng dẫn sử dụng khác (chủ yếu phân loại vào các nhóm 19.01","các nhóm 19.01 và 21.06).\n(d) Phế thải, phế liệu và sản phẩm phụ thực vật thuộc nhóm 23.08","phục vụ cho một nhu cầu một nhu cầu cụ thể mà\nkhông dùng cho việc sử dụng chung (nhóm 29.36)","sử dụng chung (nhóm 29.36).\n(f) Các sản phẩm của Chương 29.\n(g) Dược phẩm thuộc nhóm 30.03","chế\nbiến thức ăn chăn nuôi nhằm kiểm soát các loại vi sinh vật không mong muốn (nhóm\n38.08)","u từ quá trình sản xuất này, với hàm lượng chất kháng sinh\nthường không quá 70% (nhóm 38.24)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["quá trình chế biến các nguyên liệu thực vật hoặc động vật đến một mức độ mà chún","các nguyên liệu thực vật","mỗi trong số ba nhóm chất dinh dưỡng được mô tả sau đây:","cá hoặc động vật có vú ở biển có dạng dung dịch lỏng hoặc nhầy hoặc dưới dạng bộ","dầu hoặc bột thô từ cá hoặc từ động vật có vú ở biển","lá cây","xử lý bằng nhiệt nước ép cỏ alfalfa (cỏ linh lăng)"],"cau_tao":"dung dịch lỏng hoặc nhầy hoặc dưới dạng bột nhão hoặc dạng khô, nhờ quá trình cô đặc và ổn định lượng nước còn lại (có chứa các thành phần hòa tan tro","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["chăn nuôi động vật","gia súc","chế biến các loại thức ăn chăn nuôi hoàn chỉnh hoặc thức ăn chăn nuôi bổ sung","BỔ SUNG (LÀM CÂN ĐỐI) CÁC SẢN PHẨM THỨC ĂN CHĂN NUÔI ĐƯỢC CHẾ BIẾN Ở TRANG TRẠI (THỨC ĂN CHĂN NUÔI B","bù vào các phần thiếu hụt trên"],"ktcn":[{"mo_ta":"Động vật, sản phẩm động vật trên cạn phải kiểm dịch","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M1","co_quan":"BNNPTNT","loai":"kiem_dich_dong_vat","tier":3,"loai_ten":"Kiểm dịch động vật và sản phẩm động vật trên cạn","don_vi":"Cục Thú y"},{"mo_ta":"Hóa chất, SP sinh học, vi sinh vật cấm SD trong TACN","van_ban":"01/2024/TT-BNNPTNT","danh_muc":"M15","co_quan":"BNNPTNT","loai":"thuc_an_chan_nuoi","tier":3,"loai_ten":"Thức ăn chăn nuôi, chất phụ gia","don_vi":"Cục Chăn nuôi"}],"ktcn_muc_canh_bao":"RED","ktcn_co_quan":["BNNPTNT"],"agency_authority":["Bộ Nông nghiệp và Phát triển Nông thôn"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 23","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 23","Chú giải HS 2017 — Nhóm 23.09","Chú giải HS 2022 (CV 1810/TCHQ-TXNK 2024) — Nhóm 23.09"],"conflict":{"has_conflict":true,"count":1,"items":[{"type":"C2","severity":"MEDIUM","desc":"BNNPTNT yêu cầu 2 loại kiểm tra khác nhau","detail":"Types: kiem_dich_dong_vat, thuc_an_chan_nuoi"}]}},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":true,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"RED"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":true,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"230990","ahtn_8so":"23099090","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"a