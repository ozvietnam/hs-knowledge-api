{"71011000":{"hs":"71011000","chapter":71,"heading":"7101","subheading":"710110","parent_hs":null,"fact_layer":{"vn":"- Ngọc trai tự nhiên","en":null,"dvt":"kg/chiếc","rates":{"tt":"4.5","mfn":"3","vat":"*/5/8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":null,"canh_bao_cs":false,"muc_canh_bao":"GREEN","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Theo Chú giải 1 (A) của Phần VI và loại trừ\nnhững sản phẩm được liệt kê ở các mục dưới đây,\nthì tất cả các sản phẩm gồm toàn bộ hoặc từng\nphần bằng:\n(a) Ngọc trai tự nhiên hoặc nuôi cấy hoặc bằng đá\nquý hoặc đá bán quý (tự nhiên, tổng hợp hoặc tái\ntạo), hoặc\n(b) Kim loại quý hoặc kim loại dát phủ kim loại\nquý, được phân loại trong Chương này.\n2. (A) Nhóm 71.13, 71.14 và 71.15 không bao gồm\ncác sản phẩm mà trong đó kim loại quý hoặc kim\nloại được dát phủ kim loại quý chỉ đóng vai trò như\nlà th","chu_giai_phan":"HOẶC ĐÁ BÁN QUÝ, KIM LOẠI QUÝ, KIM LOẠI ĐƯỢC DÁT\nPHỦ KIM LOẠI QUÝ, VÀ CÁC SẢN PHẨM CỦA CHÚNG; ĐỒ\nTRANG SỨC LÀM BẰNG CHẤT LIỆU KHÁC; TIỀN KIM LOẠI","chu_giai_nhom":"Ngọc trai được phân loại trong nhóm này, chẳng hạn như xà cừ, là kết quả của sự tiết chất tự\nnhiên của nhiều loại động vật thân mềm nước biển và nước ngọt (đặc biệt là của con sò ngọc\ntrai và con trai ngọc trai).\nNgọc trai có bề mặt sáng bóng và chủ yếu bao gồm những lớp bằng cacbonat canxi được phủ\nlên một vật liệu sừng (conchiolin- vỏ ốc, vỏ cuộn xà cừ). Những lớp cacbonat này tạo ra sự\nnhiễu quang và sự nhiễu xạ và chính những hiện tượng này sẽ tạo ra ánh xà cừ đặc trưng của\nngọc trai (\"nước ánh của ngọc trai\"); conchiolin (vỏ ốc, vỏ cuộn xà cừ) cho ngọc trai độ trong\nmờ hoặc \"nước bóng láng\".\nNgọc trai thường trắng, nhưng có thể chuyển mầu đậm hoặc bị nhuộm mầu (ví dụ: xám, đen,\nđỏ tía, đỏ, vàng, xanh lục hoặc xanh da trời).\nNgọc trai thường có hình dáng tròn, nhưng đôi khi có dạng bán nguyệt (ngọc trai hình khuy)\nhoặc không đều (ngọc trai Baroc hoặc ngọc trai có bọt khí), và kích thước của chúng rất khác\nnhau. Xà cừ (các nhóm 05.08 và 96.01) gần như có cấu tạo rất giống với ngọc trai, nhưng\nthường là mang hình dáng những tấm mỏng.\nNhóm này cũng bao gồm ngọc trai nuôi cấy (có nghĩa là những ngọc trai được tạo ra với sự\ncan thiệp của con người). Việc này được làm bằng cách gắn một hạt xà cừ vào một nang cắt từ\nmàng áo của một con trai và sau đó cấy ghép bao nang này vào mô của một con sò khoẻ mạnh\nkhác. Sau một khoảng thời gian dài, hạt này sẽ từ từ bị bao trùm bởi các lớp đồng tâm của xà\ncừ. Vì vậy, ngọc trai nuôi cấy có dáng vẻ bề ngoài rất giống với ngọc trai thật nhưng vẫn có\nthể phân biệt được ngọc trai thật bằng thiết bị đặc biệt (thiết bị nội soi) hoặc bằng sự soi tia X.\nNhóm này bao gồm ngọc trai tự nhiên hoặc nuôi cấy, có thể chưa được gia công, ví dụ chỉ\nđược thu lượm lại và làm sạch để khử bỏ tạp chất một cách đơn thuần (ví dụ: như nhờ trung\ngian là muối và nước), hoặc đã được gia công, có nghĩa là được mài để loại bỏ những chi tiết\nkhuyết tật, khoan hoặc cắt (ví dụ: một nửa hoặc ba phần tư ngọc trai). Ngọc trai thuộc nhóm\nnày, có thể được xâu thành ch","chu_giai_dong":null,"bao_gom":["ngọc trai tự nhiên hoặc nuôi cấy, có thể chưa được gia công, ví dụ chỉ được thu lượm lại và làm sạch để khử bỏ tạp chất một cách đơn thuần (ví dụ: như nhờ trung gian là muối và nước), hoặc đã được gia công, có nghĩa là được mài để loại bỏ những chi tiết khuyết tật, khoan hoặc cắt (ví dụ: một nửa hoặc ba phần tư ngọc trai). Ngọc trai thuộc nhóm này, có thể được xâu thành chuỗi tạm thời để tiện vận chuyển. Những ngọc trai đã được nạm dát, gắn hoặc những ngọc trai đã được xâu chuỗi sau khi phân loại được loại trừ (ví dụ: tuỳ trường hợp có thể là nhóm 71.13, 71.14 hoặc 71.16). 347 Cần lưu ý rằng ngọc trai tự nhiên hoặc nhân tạo bị loại trừ khỏi Chương 97 (các đồ sưu tập quý hiếm, đồ cổ của các nhà sưu tập,...) và do đó mà vẫn được phân loại trong chương này."],"khong_bao_gom":["(a) Đồ giả ngọc trai (chất dẻo- nhóm 39.26, thuỷ tinh- nhóm 70.18; sáp- nhóm 96.02).","(b) Xà cừ, chưa được gia công hoặc mới được sơ chế (nhóm 05.08) hoặc đã gia công (nhóm 96.01)."],"loai_tru":["loại trừ (ví dụ: tuỳ\ntrường hợp có thể là nhóm 71.13, 71.14 hoặc 71.16)","(a) Đồ giả ngọc trai (chất dẻo- nhóm 39.26","(a) Đồ giả ngọc trai (chất dẻo- nhóm 39.26, thuỷ tinh- nhóm 70.18","(a) Đồ giả ngọc trai (chất dẻo- nhóm 39.26, thuỷ tinh- nhóm 70.18; sáp- nhóm 96.02)","hóm 70.18; sáp- nhóm 96.02).\n(b) Xà cừ, chưa được gia công hoặc mới được sơ chế (nhóm 05.08)","b) Xà cừ, chưa được gia công hoặc mới được sơ chế (nhóm 05.08) hoặc đã gia công (nhóm\n96.01)"],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":["màng áo của một con trai và sau đó cấy ghép bao nang này vào mô của một con sò k","từ bị bao trùm bởi các lớp đồng tâm của xà"],"cau_tao":"bán nguyệt (ngọc trai hình khuy)","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":[]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 71","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 71","Chú giải HS 2017 — Nhóm 71.01"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"GREEN"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"fil