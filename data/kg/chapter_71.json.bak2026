sự kiểm tra qua\nkính hiển vi (tốt nhất là trong một môi trường trừ không khí), kính hiển vi sẽ biểu hiện những vân\nvà bọt khí nhỏ.\nCác quy định của Chú giải cho các nhóm 71.02 và 71.03, đặc biệt liên quan đến sự gia công\nmà những loại đá này có thể phải chịu, cũng có thể được áp dụng ở đây.\nĐá tổng hợp và tái tạo không được nhầm với đá quý hoặc bán quý giả bằng thuỷ tinh thuộc\nnhóm 70.18 (xem chú giải tương ứng).\n°\n° °\nChú giải phân nhóm:\nPhân nhóm 7104.10\nThạch anh áp điện khi chịu áp suất cơ học thì có đặc tính sinh ra điện tích có cường độ thay\nđổi theo áp suất đó và ngược lại, thạch anh áp điện có tính chất chuyển hoá ","chu_giai_dong":null,"bao_gom":[],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":"những tấm mỏng, bản mỏng, thanh,","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["làm giả kim cương"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 71","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 71","Chú giải HS 2017 — Nhóm 71.04"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"GREEN"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"710410","ahtn_8so":"71041020","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"71042100":{"hs":"71042100","chapter":71,"heading":"7104","subheading":"710421","parent_hs":null,"fact_layer":{"vn":"- - Kim cương","en":null,"dvt":"carat","rates":{"tt":"5","mfn":"0","vat":"8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":null,"canh_bao_cs":false,"muc_canh_bao":"GREEN","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Theo Chú giải 1 (A) của Phần VI và loại trừ\nnhững sản phẩm được liệt kê ở các mục dưới đây,\nthì tất cả các sản phẩm gồm toàn bộ hoặc từng\nphần bằng:\n(a) Ngọc trai tự nhiên hoặc nuôi cấy hoặc bằng đá\nquý hoặc đá bán quý (tự nhiên, tổng hợp hoặc tái\ntạo), hoặc\n(b) Kim loại quý hoặc kim loại dát phủ kim loại\nquý, được phân loại trong Chương này.\n2. (A) Nhóm 71.13, 71.14 và 71.15 không bao gồm\ncác sản phẩm mà trong đó kim loại quý hoặc kim\nloại được dát phủ kim loại quý chỉ đóng vai trò như\nlà th","chu_giai_phan":"HOẶC ĐÁ BÁN QUÝ, KIM LOẠI QUÝ, KIM LOẠI ĐƯỢC DÁT\nPHỦ KIM LOẠI QUÝ, VÀ CÁC SẢN PHẨM CỦA CHÚNG; ĐỒ\nTRANG SỨC LÀM BẰNG CHẤT LIỆU KHÁC; TIỀN KIM LOẠI","chu_giai_nhom":"Những đá này được sử dụng với cùng mục đích như đá quý hoặc đá bán quý tự nhiên thuộc\nhai nhóm trước.\n(A) Đá quý và đá bán quý tổng hợp. Khái niệm này bao gồm một loạt các loại đá được sản\nxuất bằng phương pháp hoá học mà:\n- vó cùng một thành phần hoá học và cấu trúc tinh thể như một đá tự nhiên nào đó (ví\ndụ: như đá rubi, saphia, emerald, kim cương công nghiệp, thạch anh áp điện); hoặc:\n- do màu sắc, độ sáng chói, độ bền, và độ cứng mà được những người làm đồ nữ trang,\nthợ vàng và thợ bạc sử dụng thay thế cho những đá quý hoặc bán quý tự nhiên, thậm\nchí nếu chúng không có cùng thành phần hoá học và cấu trúc tinh thể như những đá\nmà chúng giống, ví dụ: như đá garnet nhôm ytri và đá zircon lập phương tổng hợp, cả\nhai loại đá này được sử dụng để làm giả kim cương.\nKhi chưa được gia công, đá tổng hợp thường có hình trụ hoặc hình giọt sương, hình quả\nlê và được biết đến như là \"ngọc nhân tạo\"; những đá này thường được tách dọc theo chiều\ndài của chúng hoặc được cắt thành các chi tiết hình đĩa.\n(B) Đá quý và đá bán quý tái tạo thu được theo cách nhân tạo bằng nhiều phương pháp khác\nnhau, ví dụ như thiêu kết (kết tụ), nén ép hoặc nung chảy (thường với sự trợ giúp của ống\nthổi tinh luyện) các mảnh đá quý hoặc đá bán quý tự nhiên, những mảnh đá mà thường bị\nnghiền ra thành bột.\nĐá tổng hợp và tái tạo thông thường có thể được phân biệt với đá tự nhiên bằng sự kiểm tra qua\nkính hiển vi (tốt nhất là trong một môi trường trừ không khí), kính hiển vi sẽ biểu hiện những vân\nvà bọt khí nhỏ.\nCác quy định của Chú giải cho các nhóm 71.02 và 71.03, đặc biệt liên quan đến sự gia công\nmà những loại đá này có thể phải chịu, cũng có thể được áp dụng ở đây.\nĐá tổng hợp và tái tạo không được nhầm với đá quý hoặc bán quý giả bằng thuỷ tinh thuộc\nnhóm 70.18 (xem chú giải tương ứng).\n°\n° °\nChú giải phân nhóm:\nPhân nhóm 7104.10\nThạch anh áp điện khi chịu áp suất cơ học thì có đặc tính sinh ra điện tích có cường độ thay\nđổi theo áp suất đó và ngược lại, thạch anh áp điện có tính chất chuyển hoá ","chu_giai_dong":null,"bao_gom":[],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":"những tấm mỏng, bản mỏng, thanh,","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["làm giả kim cương"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 71","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 71","Chú giải HS 2017 — Nhóm 71.04"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"GREEN"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":false,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"710421","ahtn_8so":"71042100","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"71042900":{"hs":"71042900","chapter":71,"heading":"7104","subheading":"710429","parent_hs":null,"fact_layer":{"vn":"- - Loại khác","en":null,"dvt":"kg","rates":{"tt":"5","mfn":"0","vat":"8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":null,"canh_bao_cs":false,"muc_canh_bao":"GREEN","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Theo Chú giải 1 (A) của Phần VI và loại trừ\nnhững sản phẩm được liệt kê ở các mục dưới đây,\nthì tất cả các sản phẩm gồm toàn bộ hoặc từng\nphần bằng:\n(a) Ngọc trai tự nhiên hoặc nuôi cấy hoặc bằng đá\nquý hoặc đá bán quý (tự nhiên, tổng hợp hoặc tái\ntạo), hoặc\n(b) Kim loại quý hoặc kim loại dát phủ kim loại\nquý, được phân loại trong Chương này.\n2. (A) Nhóm 71.13, 71.14 và 71.15 không bao gồm\ncác sản phẩm mà trong đó kim loại quý hoặc kim\nloại được dát phủ kim loại quý chỉ đóng vai trò như\nlà th","chu_giai_phan":"HOẶC ĐÁ BÁN QUÝ, KIM LOẠI QUÝ, KIM LOẠI ĐƯỢC DÁT\nPHỦ KIM LOẠI QUÝ, VÀ CÁC SẢN PHẨM CỦA CHÚNG; ĐỒ\nTRANG SỨC LÀM BẰNG CHẤT LIỆU KHÁC; TIỀN KIM LOẠI","chu_giai_nhom":"Những đá này được sử dụng với cùng mục đích như đá quý hoặc đá bán quý tự nhiên thuộc\nhai nhóm trước.\n(A) Đá quý và đá bán quý tổng hợp. Khái niệm này bao gồm một loạt các loại đá được sản\nxuất bằng phương pháp hoá học mà:\n- vó cùng một thành phần hoá học và cấu trúc tinh thể như một đá tự nhiên nào đó (ví\ndụ: như đá rubi, saphia, emerald, kim cương công nghiệp, thạch anh áp điện); hoặc:\n- do màu sắc, độ sáng chói, độ bền, và độ cứng mà được những người làm đồ nữ trang,\nthợ vàng và thợ bạc sử dụng thay thế cho những đá quý hoặc bán quý tự nhiên, thậm\nchí nếu chúng không có cùng thành phần hoá học và cấu trúc tinh thể như những đá\nmà chúng giống, ví dụ: như đá garnet nhôm ytri và đá zircon lập phương tổng hợp, cả\nhai loại đá này được sử dụng để làm giả kim cương.\nKhi chưa được gia công, đá tổng hợp thường có hình trụ hoặc hình giọt sương, hình quả\nlê và được biết đến như là \"ngọc nhân tạo\"; những đá này thường được tách dọc theo chiều\ndài của chúng hoặc được cắt thành các chi tiết hình đĩa.\n(B) Đá quý và đá bán quý tái tạo thu được theo cách nhân tạo bằng nhiều phương pháp khác\nnhau, ví dụ như thiêu kết (kết tụ), nén ép hoặc nung chảy (thường với sự trợ giúp của ống\nthổi tinh luyện) các mảnh đá quý hoặc đá bán quý tự nhiên, những mảnh đá mà thường bị\nnghiền ra thành bột.\nĐá tổng hợp và tái tạo thông thường có thể được phân biệt với đá tự nhiên bằng sự kiểm tra qua\nkính hiển vi (tốt nhất là trong một môi trường trừ không khí), kính hiển vi sẽ biểu hiện những vân\nvà bọt khí nhỏ.\nCác quy định của Chú giải cho các nhóm 71.02 và 71.03, đặc biệt liên quan đến sự gia công\nmà những loại đá này có thể phải chịu, cũng có thể được áp dụng ở đây.\nĐá tổng hợp và tái tạo không được nhầm với đá quý hoặc bán quý giả bằng thuỷ tinh thuộc\nnhóm 70.18 (xem chú giải tương ứng).\n°\n° °\nChú giải phân nhóm:\nPhân nhóm 7104.10\nThạch anh áp điện khi chịu áp suất cơ học thì có đặc tính sinh ra điện tích có cường độ thay\nđổi theo áp suất đó và ngược lại, thạch anh áp điện có tính chất chuyển hoá ","chu_giai_dong":null,"bao_gom":[],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":"những tấm mỏng, bản mỏng, thanh,","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["làm giả kim cương"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 71","vi_du_sen":[]},"nguon_phap_ly":["TT31/2022/TT-BTC — Chú giải Chương 71","Chú giải HS 2017 — Nhóm 71.04"]},"regulatory_layer":{"hien_hanh":[],"het_hieu_luc":[],"yeu_cau_tong_hop":{"giay_phep_nhap_khau":false,"kiem_tra_chuyen_nganh":false,"co_quan_kiem_tra":null,"dang_ky_luu_hanh":false,"kiem_dinh_chat_luong":false,"kiem_dich":false,"cap_phep_truoc_thong_quan":false,"muc_canh_bao":"GREEN"}},"precedent_layer":{"tb_tchq":[],"cong_van_tchq":[],"quyet_dinh_khieu_nai":[],"wco_opinions":[],"tong_so_tien_le":0},"conflict_layer":{"mau_thuan":[],"diem_mu_logic":[],"risk_map":{"muc_rui_ro":"unknown","chenh_lech_thue_max":null,"ma_de_nham":[],"ly_do_tranh_chap_thuong_gap":[]},"crowdsource":[]},"classification_layer":{"gir_checklist":{"gir1":null,"gir2a":null,"gir2b":null,"gir3a":null,"gir3b":null,"gir3c":null,"gir4":null,"gir5":null,"gir6":null,"ap_dung_gir":[]},"filtering_questions":[],"la_hang_loai_khac":true,"expert_flag":false,"expert_reason":null,"confidence_threshold":0.85},"cross_border_layer":{"wco_6so":"710429","ahtn_8so":"71042900","mapping":{"CN":null,"TH":null,"KR":null,"JP":null,"EU":null,"US_HTS":null},"rui_ro_mapping":[],"ghi_chu_xuat_xu":null},"logistics_layer":{"cua_khau_cho_phep":[],"phuong_thuc_van_chuyen":[],"kho_ngoai_quan":false,"gia_tham_chieu":{"don_vi":null,"gia_min":null,"gia_max":null,"nguon":null,"cap_nhat":null},"trong_luong_tinh":null,"ghi_chu_logistics":null},"ai_layer":{"dynamic_schema":{"giai_thich_don_gian":null,"vi_du_thuc_te":[],"tu_khoa_tim_kiem":[],"canh_bao_rui_ro":null,"mo_ta_ky_thuat":null},"ai_contributions":[],"external_validation":{"zonos":null,"digicust":null,"last_validated":null,"consensus":null},"gap_score":1.0,"last_enriched_at":null,"feedback":{"helpful_count":0,"report_count":0,"expert_reviewed":false}},"meta":{"status":"raw","completeness":{"fact":true,"legal":false,"regulatory":false,"precedent":false,"conflict":false,"classification":false,"cross_border":false,"logistics":false,"ai":false},"version":1,"created_at":"2026-04-02T03:46:57Z","updated_at":"2026-04-02T03:46:57Z"}},"71049100":{"hs":"71049100","chapter":71,"heading":"7104","subheading":"710491","parent_hs":null,"fact_layer":{"vn":"- - Kim cương","en":null,"dvt":"carat","rates":{"tt":"5","mfn":"0","vat":"8/10","acfta":"0","atiga":null,"vjepa":null,"vcfta":null,"ukvfta":null,"evfta":null,"bvmt":null,"giam_vat":null},"chinh_sach":null,"canh_bao_cs":false,"muc_canh_bao":"GREEN","source_doc":"TT31/2022/TT-BTC","effective_date":"2022-06-08","expiration_date":null,"version":1},"legal_layer":{"chu_giai_chuong":"1. Theo Chú giải 1 (A) của Phần VI và loại trừ\nnhững sản phẩm được liệt kê ở các mục dưới đây,\nthì tất cả các sản phẩm gồm toàn bộ hoặc từng\nphần bằng:\n(a) Ngọc trai tự nhiên hoặc nuôi cấy hoặc bằng đá\nquý hoặc đá bán quý (tự nhiên, tổng hợp hoặc tái\ntạo), hoặc\n(b) Kim loại quý hoặc kim loại dát phủ kim loại\nquý, được phân loại trong Chương này.\n2. (A) Nhóm 71.13, 71.14 và 71.15 không bao gồm\ncác sản phẩm mà trong đó kim loại quý hoặc kim\nloại được dát phủ kim loại quý chỉ đóng vai trò như\nlà th","chu_giai_phan":"HOẶC ĐÁ BÁN QUÝ, KIM LOẠI QUÝ, KIM LOẠI ĐƯỢC DÁT\nPHỦ KIM LOẠI QUÝ, VÀ CÁC SẢN PHẨM CỦA CHÚNG; ĐỒ\nTRANG SỨC LÀM BẰNG CHẤT LIỆU KHÁC; TIỀN KIM LOẠI","chu_giai_nhom":"Những đá này được sử dụng với cùng mục đích như đá quý hoặc đá bán quý tự nhiên thuộc\nhai nhóm trước.\n(A) Đá quý và đá bán quý tổng hợp. Khái niệm này bao gồm một loạt các loại đá được sản\nxuất bằng phương pháp hoá học mà:\n- vó cùng một thành phần hoá học và cấu trúc tinh thể như một đá tự nhiên nào đó (ví\ndụ: như đá rubi, saphia, emerald, kim cương công nghiệp, thạch anh áp điện); hoặc:\n- do màu sắc, độ sáng chói, độ bền, và độ cứng mà được những người làm đồ nữ trang,\nthợ vàng và thợ bạc sử dụng thay thế cho những đá quý hoặc bán quý tự nhiên, thậm\nchí nếu chúng không có cùng thành phần hoá học và cấu trúc tinh thể như những đá\nmà chúng giống, ví dụ: như đá garnet nhôm ytri và đá zircon lập phương tổng hợp, cả\nhai loại đá này được sử dụng để làm giả kim cương.\nKhi chưa được gia công, đá tổng hợp thường có hình trụ hoặc hình giọt sương, hình quả\nlê và được biết đến như là \"ngọc nhân tạo\"; những đá này thường được tách dọc theo chiều\ndài của chúng hoặc được cắt thành các chi tiết hình đĩa.\n(B) Đá quý và đá bán quý tái tạo thu được theo cách nhân tạo bằng nhiều phương pháp khác\nnhau, ví dụ như thiêu kết (kết tụ), nén ép hoặc nung chảy (thường với sự trợ giúp của ống\nthổi tinh luyện) các mảnh đá quý hoặc đá bán quý tự nhiên, những mảnh đá mà thường bị\nnghiền ra thành bột.\nĐá tổng hợp và tái tạo thông thường có thể được phân biệt với đá tự nhiên bằng sự kiểm tra qua\nkính hiển vi (tốt nhất là trong một môi trường trừ không khí), kính hiển vi sẽ biểu hiện những vân\nvà bọt khí nhỏ.\nCác quy định của Chú giải cho các nhóm 71.02 và 71.03, đặc biệt liên quan đến sự gia công\nmà những loại đá này có thể phải chịu, cũng có thể được áp dụng ở đây.\nĐá tổng hợp và tái tạo không được nhầm với đá quý hoặc bán quý giả bằng thuỷ tinh thuộc\nnhóm 70.18 (xem chú giải tương ứng).\n°\n° °\nChú giải phân nhóm:\nPhân nhóm 7104.10\nThạch anh áp điện khi chịu áp suất cơ học thì có đặc tính sinh ra điện tích có cường độ thay\nđổi theo áp suất đó và ngược lại, thạch anh áp điện có tính chất chuyển hoá ","chu_giai_dong":null,"bao_gom":[],"khong_bao_gom":[],"loai_tru":[],"dieu_kien_bat_buoc":[],"tinh_chat":{"nguyen_lieu":[],"cau_tao":"những tấm mỏng, bản mỏng, thanh,","nguyen_ly_hoat_dong":null,"tinh_chat_vat_ly":null,"tinh_chat_hoa_hoc":null,"muc_dich_su_dung":["làm giả kim cương"]},"phan_biet":[],"sen":{"co":false,"noi_dung":null,"source":"SEN WCO 2022 — Chapter 71","vi_du_sen":[]},"nguon_phap_ly":["TT31/2